---
const { config, routeVariants } = Astro.props;
const routeVariantMetadata = Object.fromEntries(Object.entries(routeVariants).map(([id, variant]) => [id, {
  id,
  label: variant.label,
  visibleSpotCount: variant.visibleSpotSlugs?.length,
  fieldVerified: variant.fieldVerified,
  verified: variant.verified,
  note: variant.note,
}]));
const configJson = JSON.stringify({ ...config, routeVariants: routeVariantMetadata }).replace(/</g, "\\u003c");
const initialSituation = config.situations[0];
const initialResult = config.recommendations[initialSituation.recommendation];
const initialSpotCount = routeVariantMetadata[initialResult.routeVariant].visibleSpotCount;
---

<section class="situation-adjuster" id="situation-adjuster" aria-labelledby="situation-adjuster-heading" data-situation-adjuster tabindex="-1">
  <div class="section-heading">
    <h2 id="situation-adjuster-heading">{config.title}</h2>
  </div>

  <details class="information-details">
    <summary>入力情報の扱い</summary>
    <ul>{config.privacyItems.map((item) => <li>{item}</li>)}</ul>
  </details>

  <fieldset class="situation-fieldset">
    <legend class="visually-hidden">現在の状況</legend>
    <div class="situation-options">
      {config.situations.map((situation, index) => {
        const inputId = `route-situation-${situation.value}`;
        return (
          <label class="choice-card" for={inputId} role="radio" aria-checked={index === 0 ? "true" : "false"}>
            <input id={inputId} type="radio" name="route-situation" value={situation.value} checked={index === 0} data-situation={situation.value} />
            <strong>{situation.label}</strong>
            <small>{situation.helper}</small>
            <span class="selection-check" aria-hidden="true" hidden={index !== 0}>✓</span>
          </label>
        );
      })}
    </div>
  </fieldset>

  {Object.entries(config.conditionGroups).map(([groupId, group]) => (
    <fieldset class="condition-group" hidden data-condition-group={groupId}>
      <legend>{group.label}</legend>
      <div class="condition-options">
        {group.options.map((option) => {
          const inputId = `route-condition-${groupId}-${option.value}`;
          return (
            <label class="choice-card choice-card--condition" for={inputId} role="radio" aria-checked="false">
              <input id={inputId} type="radio" name={`route-condition-${groupId}`} value={option.value} data-condition={option.value} />
              <strong>{option.label}</strong>
              <small>{option.helper}</small>
              <span class="selection-check" aria-hidden="true" hidden>✓</span>
            </label>
          );
        })}
      </div>
    </fieldset>
  ))}

  <article class="situation-result" aria-live="polite" data-situation-result>
    <h3 data-result-title>{initialResult.label}</h3>
    <div class="result-meta">
      <strong data-result-timing>{initialResult.timing}</strong>
      <span data-result-spots>{initialSpotCount}地点</span>
    </div>
    <div class="result-actions">
      <a href={initialResult.href} data-situation-cta>{initialResult.cta}</a>
      <a hidden data-situation-secondary></a>
    </div>
    <details class="result-details">
      <summary>注意</summary>
      <p class="result-note" data-result-note>{initialResult.note}</p>
    </details>
  </article>

  <details class="information-details">
    <summary>この案内について</summary>
    <p>{config.commonNotice}</p>
  </details>

  <details class="situation-criteria">
    <summary>状況別の判定基準を見る</summary>
    <div class="criteria-list">
      {Object.values(config.recommendations).map((result) => (
        <article>
          <dl>
            <div><dt>条件</dt><dd>{result.condition}</dd></div>
            <div><dt>提案結果</dt><dd>{result.label}</dd></div>
            <div><dt>時間・重要な注意</dt><dd>{result.timing}</dd></div>
          </dl>
        </article>
      ))}
    </div>
  </details>

  <script type="application/json" data-situation-config set:html={configJson}></script>
</section>

<style>
  .situation-adjuster { margin-top: 18px; padding: 24px; background: var(--guide-card); font-size: 16px; line-height: 1.6; scroll-margin-top: 88px; }
  .situation-adjuster:focus { outline: none; }
  .section-heading h2 { margin: 0; padding: 0; border: 0; font-size: clamp(24px, 4vw, 30px); }
  .information-details, .situation-criteria { margin-top: 16px; border-top: 1px solid var(--guide-border); color: var(--guide-sub); font-size: 14px; }
  .information-details summary, .situation-criteria summary, .result-details summary { width: fit-content; padding: 12px 2px 2px; color: var(--guide-secondary); font-weight: 800; cursor: pointer; }
  .information-details ul { margin: 10px 0 0; padding-left: 1.4em; }
  .information-details p { margin: 10px 0 0; }
  summary:focus-visible { outline: 3px solid var(--guide-accent); outline-offset: 3px; }
  .situation-fieldset { margin: 0; padding: 0; border: 0; }
  .situation-options, .condition-options { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 10px; margin-top: 16px; }
  .choice-card { position: relative; display: grid; min-height: 82px; grid-template-rows: auto 1fr; gap: 2px; padding: 12px 40px 12px 13px; border: 1px solid var(--guide-border); border-radius: 10px; background: var(--guide-card); color: var(--guide-text); cursor: pointer; }
  .choice-card:hover { border-color: var(--guide-accent); background: var(--guide-accent-soft); }
  .choice-card:has(input:checked) { border: 2px solid var(--guide-accent); background: var(--guide-accent-soft); color: var(--guide-text); }
  .choice-card:has(input:focus-visible) { outline: 3px solid var(--guide-accent); outline-offset: 3px; }
  .choice-card input { position: absolute; width: 1px; height: 1px; opacity: 0; }
  .choice-card strong { font-size: 16px; line-height: 1.4; }
  .choice-card small { color: var(--guide-sub); font-size: 14px; line-height: 1.45; }
  .selection-check { position: absolute; top: 12px; right: 12px; display: grid; width: 22px; height: 22px; place-items: center; border-radius: 50%; background: var(--guide-accent); color: #fff; font-size: 14px; font-weight: 900; }
  .selection-check[hidden] { display: none; }
  .condition-group { margin: 20px 0 0; padding: 14px; border: 1px solid var(--guide-border); border-radius: 10px; }
  .condition-group legend { padding: 0 7px; font-size: 14px; font-weight: 800; }
  .condition-options { margin-top: 0; }
  .choice-card--condition { min-height: 76px; }
  .situation-result { display: grid; grid-template-columns: minmax(200px, 1fr) auto; gap: 6px 20px; align-items: center; margin-top: 18px; padding: 16px 18px; border: 1px solid var(--guide-border); border-radius: 12px; background: var(--guide-accent-soft); }
  .situation-result h3 { margin: 0; font-size: clamp(20px, 3vw, 24px); line-height: 1.4; }
  .result-meta { display: flex; flex-wrap: wrap; gap: 7px 14px; font-size: 16px; }
  .result-note { margin: 8px 0 0; font-size: 14px; }
  .result-actions { grid-column: 2; grid-row: 1 / span 2; display: flex; flex-wrap: wrap; align-items: center; gap: 10px; }
  .result-actions a { display: inline-flex; min-height: 44px; align-items: center; padding: 8px 15px; border-radius: 8px; background: var(--guide-accent); color: #fff; font-size: 16px; font-weight: 800; }
  .result-actions a:hover { background: var(--primary-hover); }
  .result-actions a[data-situation-secondary] { min-height: auto; padding: 4px 1px; border-radius: 0; background: transparent; color: var(--guide-secondary); font-size: 14px; text-decoration: underline; }
  .result-actions a:focus-visible { outline: 3px solid var(--guide-accent); outline-offset: 3px; }
  .result-details { grid-column: 1 / -1; color: var(--guide-sub); font-size: 14px; }
  .criteria-list { display: grid; gap: 9px; margin-top: 12px; }
  .criteria-list article { min-width: 0; padding: 13px; border: 1px solid var(--guide-border); border-radius: 8px; background: var(--card-subtle); overflow-wrap: anywhere; }
  .criteria-list dl { display: grid; gap: 6px; margin: 0; }
  .criteria-list dl div { display: grid; grid-template-columns: 140px minmax(0, 1fr); gap: 8px; }
  .criteria-list dt { font-weight: 800; }
  .criteria-list dd { min-width: 0; margin: 0; }
  .visually-hidden { position: absolute; width: 1px; height: 1px; padding: 0; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0; }
  @media (max-width: 960px) {
    .situation-options, .condition-options { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 600px) {
    .situation-adjuster { padding: 20px 14px; }
    .choice-card { min-height: 78px; }
    .situation-result { grid-template-columns: 1fr; }
    .result-actions { grid-column: 1; grid-row: auto; }
    .result-actions a { width: 100%; justify-content: center; }
    .criteria-list dl div { grid-template-columns: 1fr; gap: 1px; }
  }
  @media (max-width: 410px) {
    .situation-options, .condition-options { grid-template-columns: 1fr; }
  }
</style>

<script>
  import { setupRouteSituationAdjusters } from "../../scripts/routeSituationAdjuster.js";
  setupRouteSituationAdjusters();
</script>
