---
const { config } = Astro.props;
const configJson = JSON.stringify(config).replace(/</g, "\\u003c");
const initialSituation = config.situations[0];
const initialResult = config.recommendations[initialSituation.recommendation];
---

<section class="situation-adjuster" aria-labelledby="situation-adjuster-heading" data-situation-adjuster>
  <div class="section-heading">
    <p class="section-label">状況を自己申告</p>
    <h2 id="situation-adjuster-heading">{config.title}</h2>
    <p>{config.description}</p>
  </div>

  <details class="information-details">
    <summary>入力情報の扱い</summary>
    <ul>{config.privacyItems.map((item) => <li>{item}</li>)}</ul>
  </details>

  <div class="situation-options" aria-label="現在の状況">
    {config.situations.map((situation, index) => (
      <button type="button" aria-pressed={index === 0 ? "true" : "false"} data-situation={situation.value}>
        <span class="selection-check" aria-hidden="true">{index === 0 ? "✓" : ""}</span>
        <span class="selection-label">{situation.label}</span>
        <span data-selection-status hidden={index !== 0}>選択中</span>
      </button>
    ))}
  </div>

  {Object.entries(config.conditionGroups).map(([groupId, group]) => (
    <fieldset class="condition-group" hidden data-condition-group={groupId}>
      <legend>{group.label}</legend>
      <div class="condition-options">
        {group.options.map((option) => (
          <button type="button" aria-pressed="false" data-condition={option.value}>
            <span class="selection-check" aria-hidden="true"></span>
            <span class="selection-label">{option.label}</span>
            <span data-selection-status hidden>選択中</span>
          </button>
        ))}
      </div>
    </fieldset>
  ))}

  <article class="situation-result" aria-live="polite" data-situation-result>
    <p class="result-label">提案する回り方</p>
    <h3 data-result-title>{initialResult.label}</h3>
    <p class="result-timing" data-result-timing>{initialResult.timing}</p>
    <p class="result-note" data-result-note>{initialResult.note}</p>
    <div class="result-actions">
      <a href={initialResult.href} data-situation-cta>{initialResult.cta}</a>
      <a hidden data-situation-secondary></a>
    </div>
  </article>

  <details class="information-details">
    <summary>この案内について</summary>
    <p>{config.commonNotice}</p>
  </details>

  <details class="situation-criteria">
    <summary>状況別の判定基準を見る</summary>
    <div class="criteria-list">
      {Object.values(config.recommendations).map((result) => (
        <article>
          <dl>
            <div><dt>条件</dt><dd>{result.condition}</dd></div>
            <div><dt>提案結果</dt><dd>{result.label}</dd></div>
            <div><dt>時間・重要な注意</dt><dd>{result.timing}</dd></div>
          </dl>
        </article>
      ))}
    </div>
  </details>

  <script type="application/json" data-situation-config set:html={configJson}></script>
</section>

<style>
  .situation-adjuster { margin-top: 18px; padding: 24px; background: var(--guide-card); font-size: 16px; line-height: 1.6; }
  .section-label { margin: 0 0 6px; color: var(--guide-accent); font-size: 14px; font-weight: 700; }
  .section-heading h2 { margin: 0; padding: 0; border: 0; font-size: clamp(24px, 4vw, 30px); }
  .section-heading > p:last-child { margin: 8px 0 0; color: var(--guide-sub); }
  .information-details, .situation-criteria { margin-top: 16px; border-top: 1px solid var(--guide-border); color: var(--guide-sub); font-size: 14px; }
  .information-details summary, .situation-criteria summary { width: fit-content; padding: 12px 2px 2px; color: var(--guide-accent); font-weight: 800; cursor: pointer; }
  .information-details ul { margin: 10px 0 0; padding-left: 1.4em; }
  .information-details p { margin: 10px 0 0; }
  summary:focus-visible { outline: 3px solid #9a8053; outline-offset: 3px; }
  .situation-options { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; margin-top: 18px; }
  .situation-options button, .condition-options button { display: grid; grid-template-columns: 22px minmax(0, 1fr) auto; gap: 9px; align-items: center; min-height: 52px; padding: 11px 13px; border: 1px solid var(--guide-border); border-radius: 9px; background: rgba(255,255,255,.62); color: var(--guide-text); font: inherit; font-size: 16px; text-align: left; cursor: pointer; }
  .situation-options button:hover, .condition-options button:hover { border-color: var(--guide-accent); }
  .situation-options button[aria-pressed="true"], .condition-options button[aria-pressed="true"] { border-color: var(--guide-accent); background: var(--guide-accent-soft); }
  button:focus-visible { outline: 3px solid #9a8053; outline-offset: 3px; }
  .selection-check { display: grid; width: 20px; height: 20px; place-items: center; border: 1px solid var(--guide-border); border-radius: 50%; font-size: 14px; font-weight: 900; }
  [aria-pressed="true"] > .selection-check { border-color: var(--guide-accent); background: var(--guide-accent); color: #fff; }
  .selection-label { font-weight: 800; line-height: 1.5; }
  [data-selection-status] { color: var(--guide-accent); font-size: 14px; font-weight: 800; white-space: nowrap; }
  .condition-group { margin: 20px 0 0; padding: 14px; border: 1px solid var(--guide-border); border-radius: 9px; }
  .condition-group legend { padding: 0 7px; font-size: 14px; font-weight: 800; }
  .condition-options { display: flex; flex-wrap: wrap; gap: 8px; }
  .condition-options button { min-height: 44px; padding: 8px 12px; background: transparent; }
  .situation-result { margin-top: 22px; padding: 22px; border: 1px solid #b8ceca; border-radius: 12px; background: #e9f1ef; }
  .result-label { margin: 0; color: var(--guide-accent); font-size: 14px; font-weight: 800; }
  .situation-result h3 { margin: 4px 0 0; font-size: clamp(22px, 3vw, 24px); line-height: 1.45; }
  .result-timing, .result-note { margin: 10px 0 0; font-size: 16px; }
  .result-timing { font-weight: 800; }
  .result-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 12px; margin-top: 18px; }
  .result-actions a { display: inline-flex; min-height: 46px; align-items: center; padding: 9px 16px; border-radius: 8px; background: #31575a; color: #fff; font-size: 16px; font-weight: 800; }
  .result-actions a[data-situation-secondary] { min-height: auto; padding: 4px 1px; border-radius: 0; background: transparent; color: var(--guide-accent); font-size: 14px; text-decoration: underline; }
  .criteria-list { display: grid; gap: 9px; margin-top: 12px; }
  .criteria-list article { min-width: 0; padding: 13px; border: 1px solid var(--guide-border); border-radius: 8px; background: #faf9f6; overflow-wrap: anywhere; }
  .criteria-list dl { display: grid; gap: 6px; margin: 0; }
  .criteria-list dl div { display: grid; grid-template-columns: 140px minmax(0, 1fr); gap: 8px; }
  .criteria-list dt { font-weight: 800; }
  .criteria-list dd { min-width: 0; margin: 0; }
  @media (max-width: 600px) {
    .situation-adjuster { padding: 20px 14px; }
    .situation-options { grid-template-columns: 1fr; }
    .condition-options { display: grid; grid-template-columns: 1fr; }
    .result-actions a { width: 100%; justify-content: center; }
    .criteria-list dl div { grid-template-columns: 1fr; gap: 1px; }
  }
</style>

<script>
  import { setupRouteSituationAdjusters } from "../../scripts/routeSituationAdjuster.js";
  setupRouteSituationAdjusters();
</script>
