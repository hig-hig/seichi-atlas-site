---
const { config, routeVariants } = Astro.props;
const routeVariantMetadata = Object.fromEntries(Object.entries(routeVariants).map(([id, variant]) => [id, {
  id,
  label: variant.label,
  visibleSpotCount: variant.visibleSpotSlugs?.length,
  fieldVerified: variant.fieldVerified,
  verified: variant.verified,
  note: variant.note,
}]));
const configJson = JSON.stringify({ ...config, routeVariants: routeVariantMetadata }).replace(/</g, "\\u003c");
const initialSituation = config.situations[0];
const initialResult = config.recommendations[initialSituation.recommendation];
const choiceByRecommendation = new Map();
config.situations.forEach((situation) => {
  if (situation.recommendation && !choiceByRecommendation.has(situation.recommendation)) {
    choiceByRecommendation.set(situation.recommendation, situation);
  }
  if (!situation.conditionGroup) return;
  config.conditionGroups[situation.conditionGroup].options.forEach((option) => {
    if (!choiceByRecommendation.has(option.recommendation)) choiceByRecommendation.set(option.recommendation, option);
  });
});
const primaryEntrySections = config.entrySections.filter((section) => !section.secondary);
const secondaryEntrySections = config.entrySections.filter((section) => section.secondary);
---

<section class="situation-adjuster" id="situation-adjuster" aria-labelledby="situation-adjuster-heading" data-situation-adjuster tabindex="-1">
  <div class="section-heading">
    <h2 id="situation-adjuster-heading">{config.title}</h2>
    <p>{config.description}</p>
  </div>

  <div class="entry-sections">
    {primaryEntrySections.map((section) => (
      <fieldset class="entry-section">
        <legend>{section.label}</legend>
        <div class="situation-options">
          {section.recommendations.map((recommendation) => {
            const choice = choiceByRecommendation.get(recommendation);
            const inputId = `route-entry-${recommendation}`;
            return (
              <label class="choice-card" for={inputId} aria-checked="false">
                <input id={inputId} type="radio" name="route-entry" value={recommendation} data-recommendation-choice={recommendation} />
                <strong>{choice.label}</strong>
                <small>{choice.helper}</small>
                <span class="selection-check" aria-hidden="true" hidden>✓</span>
              </label>
            );
          })}
        </div>
      </fieldset>
    ))}
  </div>

  <details class="additional-adjustments">
    <summary>さらに調整する</summary>
    {secondaryEntrySections.map((section) => (
      <fieldset class="entry-section entry-section--secondary">
        <legend class="visually-hidden">{section.label}</legend>
        <div class="condition-options">
          {section.recommendations.map((recommendation) => {
            const choice = choiceByRecommendation.get(recommendation);
            const inputId = `route-entry-${recommendation}`;
            return (
              <label class="choice-card choice-card--condition" for={inputId} aria-checked="false">
                <input id={inputId} type="radio" name="route-entry" value={recommendation} data-recommendation-choice={recommendation} />
                <strong>{choice.label}</strong>
                <small>{choice.helper}</small>
                <span class="selection-check" aria-hidden="true" hidden>✓</span>
              </label>
            );
          })}
        </div>
      </fieldset>
    ))}
  </details>

  <div class="selection-actions">
    <p data-selection-status>条件を1つ選択</p>
    <div>
      <button type="button" disabled data-recommendation-submit>おすすめを見る</button>
      <a href={initialResult.href} data-standard-direct>標準ルートを見る</a>
    </div>
  </div>

  <details class="information-details">
    <summary>入力情報の扱い</summary>
    <ul>{config.privacyItems.map((item) => <li>{item}</li>)}</ul>
  </details>

  <details class="information-details">
    <summary>この案内について</summary>
    <p>{config.commonNotice}</p>
  </details>

  <details class="situation-criteria">
    <summary>状況別の判定基準を見る</summary>
    <div class="criteria-list">
      {Object.values(config.recommendations).map((result) => (
        <article>
          <dl>
            <div><dt>条件</dt><dd>{result.condition}</dd></div>
            <div><dt>提案結果</dt><dd>{result.label}</dd></div>
            <div><dt>時間・重要な注意</dt><dd>{result.timing}</dd></div>
          </dl>
        </article>
      ))}
    </div>
  </details>

  <script type="application/json" data-situation-config set:html={configJson}></script>
</section>

<style>
  .situation-adjuster { width: min(100%, 1200px); margin: 18px auto 0; padding: 24px; background: var(--guide-card); font-size: 16px; line-height: 1.6; scroll-margin-top: 88px; }
  .situation-adjuster:focus { outline: none; }
  .section-heading h2 { margin: 0; padding: 0; border: 0; font-size: clamp(24px, 4vw, 30px); }
  .section-heading p { margin: 5px 0 0; color: var(--guide-sub); }
  .information-details, .situation-criteria { margin-top: 16px; border-top: 1px solid var(--guide-border); color: var(--guide-sub); font-size: 14px; }
  .information-details summary, .situation-criteria summary { width: fit-content; padding: 12px 2px 2px; color: var(--guide-secondary); font-weight: 800; cursor: pointer; }
  .information-details ul { margin: 10px 0 0; padding-left: 1.4em; }
  .information-details p { margin: 10px 0 0; }
  summary:focus-visible { outline: 3px solid var(--guide-accent); outline-offset: 3px; }
  .entry-sections { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; margin-top: 18px; }
  .entry-section { min-width: 0; margin: 0; padding: 13px; border: 1px solid var(--guide-border); border-radius: 10px; }
  .entry-section legend { padding: 0 6px; color: var(--guide-text); font-size: 16px; font-weight: 900; }
  .situation-options { display: grid; gap: 8px; }
  .condition-options { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 10px; }
  .choice-card { position: relative; display: grid; min-height: 82px; grid-template-rows: auto 1fr; gap: 2px; padding: 12px 40px 12px 13px; border: 1px solid var(--guide-border); border-radius: 10px; background: var(--guide-card); color: var(--guide-text); cursor: pointer; }
  .choice-card:hover { border-color: var(--guide-accent); background: var(--guide-accent-soft); }
  .choice-card:has(input:checked) { border: 2px solid var(--guide-accent); background: var(--guide-accent-soft); color: var(--guide-text); }
  .choice-card:has(input:focus-visible) { outline: 3px solid var(--guide-accent); outline-offset: 3px; }
  .choice-card input { position: absolute; width: 1px; height: 1px; opacity: 0; }
  .choice-card strong { font-size: 16px; line-height: 1.4; }
  .choice-card small { color: var(--guide-sub); font-size: 14px; line-height: 1.45; }
  .selection-check { position: absolute; top: 12px; right: 12px; display: grid; width: 22px; height: 22px; place-items: center; border-radius: 50%; background: var(--guide-accent); color: #fff; font-size: 14px; font-weight: 900; }
  .selection-check[hidden] { display: none; }
  .choice-card--condition { min-height: 76px; }
  .additional-adjustments { margin-top: 14px; color: var(--guide-sub); }
  .additional-adjustments > summary { width: fit-content; color: var(--guide-secondary); font-size: 14px; font-weight: 800; cursor: pointer; }
  .entry-section--secondary { margin-top: 10px; padding: 0; border: 0; }
  .selection-actions { display: flex; align-items: center; justify-content: space-between; gap: 12px 20px; margin-top: 18px; padding-top: 16px; border-top: 1px solid var(--guide-border); }
  .selection-actions p { margin: 0; color: var(--guide-sub); font-size: 14px; font-weight: 700; }
  .selection-actions > div { display: flex; flex-wrap: wrap; align-items: center; gap: 10px; }
  .selection-actions button, .selection-actions a { display: inline-flex; min-height: 44px; align-items: center; justify-content: center; padding: 8px 16px; border-radius: 8px; font: inherit; font-size: 16px; font-weight: 800; cursor: pointer; }
  .selection-actions button { border: 1px solid var(--guide-accent); background: var(--guide-accent); color: #fff; }
  .selection-actions button:hover:not(:disabled) { background: var(--primary-hover); }
  .selection-actions button:disabled { border-color: var(--guide-border); background: var(--guide-border); color: var(--guide-sub); cursor: not-allowed; }
  .selection-actions a { border: 1px solid var(--guide-secondary); color: var(--guide-secondary); }
  .selection-actions button:focus-visible, .selection-actions a:focus-visible { outline: 3px solid var(--guide-accent); outline-offset: 3px; }
  .criteria-list { display: grid; gap: 9px; margin-top: 12px; }
  .criteria-list article { min-width: 0; padding: 13px; border: 1px solid var(--guide-border); border-radius: 8px; background: var(--card-subtle); overflow-wrap: anywhere; }
  .criteria-list dl { display: grid; gap: 6px; margin: 0; }
  .criteria-list dl div { display: grid; grid-template-columns: 140px minmax(0, 1fr); gap: 8px; }
  .criteria-list dt { font-weight: 800; }
  .criteria-list dd { min-width: 0; margin: 0; }
  .visually-hidden { position: absolute; width: 1px; height: 1px; padding: 0; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0; }
  @media (max-width: 960px) {
    .entry-sections { grid-template-columns: 1fr; }
    .situation-options { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .condition-options { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 720px) {
    .situation-adjuster { scroll-margin-top: 112px; }
  }
  @media (max-width: 600px) {
    .situation-adjuster { padding: 20px 14px; }
    .choice-card { min-height: 78px; }
    .situation-options { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .selection-actions { align-items: stretch; flex-direction: column; }
    .selection-actions > div { display: grid; grid-template-columns: 1fr; }
    .selection-actions button, .selection-actions a { width: 100%; }
    .criteria-list dl div { grid-template-columns: 1fr; gap: 1px; }
  }
  @media (max-width: 410px) {
    .situation-options, .condition-options { grid-template-columns: 1fr; }
  }
</style>

<script>
  import { setupRouteSituationAdjusters } from "../../scripts/routeSituationAdjuster.js";
  setupRouteSituationAdjusters();
</script>
