---
import GuideRouteMap from "./GuideRouteMap.astro";
import RouteSituationAdjuster from "./RouteSituationAdjuster.astro";

const {
  route,
  routeSpots,
  optionSpot,
  routeVariants,
  content,
} = Astro.props;

const mapLocations = routeSpots.map(({ order, name, slug, lat, lng, detailUrl }) => ({
  order,
  name,
  slug,
  lat,
  lng,
  detailUrl,
}));
const exitOptions = route.exitOptions ?? [];
const exitOptionsBySlug = new Map(exitOptions.map((option) => [option.atSlug, option]));
const mapExitPoints = exitOptions.map((option) => {
  const spot = routeSpots.find((item) => item.slug === option.atSlug);
  if (!spot) throw new Error(`Exit option spot not found: ${option.atSlug}`);
  return { ...option, name: spot.name, lat: spot.lat, lng: spot.lng };
});
const initialRecommendation = content.situationAdjuster.recommendations.standard;
const initialVariant = routeVariants[initialRecommendation.routeVariant];
const timelineVariantsJson = JSON.stringify(Object.fromEntries(Object.entries(routeVariants).map(([id, variant]) => [id, {
  visibleSpotSlugs: variant.visibleSpotSlugs,
  hasArrivalSchedule: variant.hasArrivalSchedule,
  timelineTransfers: variant.timelineTransfers ?? {},
}]))).replace(/</g, "\\u003c");
---

<main class="route-page">
  <div class="route-container">
    <nav class="breadcrumb" aria-label="パンくずリスト">
      {content.breadcrumbs.map((item, index) => (
        <>
          {item.href ? <a href={item.href}>{item.label}</a> : <span>{item.label}</span>}
          {index < content.breadcrumbs.length - 1 && <span aria-hidden="true">/</span>}
        </>
      ))}
    </nav>

    <header class="route-hero">
      <h1>
        <span>{content.hero.workTitle}</span>
        {content.hero.courseTitle}
      </h1>
      <section class="hero-route-result" aria-label="現在選択中のルート">
        <div class="hero-route-heading">
          <h2 data-overview-route>{initialRecommendation.label}</h2>
          <span class="route-status" data-overview-status>{initialVariant.fieldVerified ? "確認済み" : "現地未確認"}</span>
        </div>
        <dl class="hero-route-meta" aria-label="主要なコース概要">
          <div><dt>所要時間</dt><dd data-overview-timing>{initialRecommendation.timing}</dd></div>
          <div><dt>地点数</dt><dd data-overview-spots>{initialVariant.visibleSpotSlugs.length}地点</dd></div>
          <div><dt>START</dt><dd>{route.start}</dd></div>
          <div><dt>GOAL</dt><dd>{route.end}</dd></div>
        </dl>
      </section>
    </header>

    <GuideRouteMap
      locations={mapLocations}
      supportFacilities={route.supportFacilities ?? []}
      exitPoints={mapExitPoints}
      routeVariants={routeVariants}
      recommendations={content.situationAdjuster.recommendations}
      quickChoices={content.situationAdjuster.quickChoices}
      sectionTitle={content.map.title}
      description={content.map.description}
      mapAriaLabel={content.map.ariaLabel}
      editMapUrl={content.map.editUrl}
      initialCenter={content.map.initialCenter}
    />

    {content.situationAdjuster && <RouteSituationAdjuster config={content.situationAdjuster} routeVariants={routeVariants} />}

    <details class="verification-notice">
      <summary>{content.verification.title}</summary>
      <p>{content.verification.description}</p>
    </details>

    <section
      class="route-section timeline-section"
      aria-labelledby="route-order-heading"
      data-route-timeline
      data-initial-route-variant={initialRecommendation.routeVariant}
      data-initial-timing={initialRecommendation.timing}
    >
      <div class="timeline-heading">
        <div>
          <h2 id="route-order-heading">{content.timeline.title}</h2>
          <p>時刻・徒歩時間は目安</p>
        </div>
        <dl class="timeline-summary" aria-label="行程概要">
          <div><dt>所要時間</dt><dd data-timeline-timing>{initialRecommendation.timing}</dd></div>
          <div><dt>地点数</dt><dd data-timeline-count>{initialVariant.visibleSpotSlugs.length}地点</dd></div>
          <div class="timeline-summary-route"><dt>区間</dt><dd><span data-timeline-start>{routeSpots[0].name}</span><span aria-hidden="true"> → </span><span data-timeline-goal>{routeSpots.at(-1).name}</span></dd></div>
        </dl>
      </div>
      <p class="timeline-omitted" data-timeline-omitted hidden></p>
      <details class="timeline-note">
        <summary>時刻について</summary>
        <p>{content.timeline.description} 派生ルートの到着時刻は未設定です。</p>
      </details>
      <p class="timeline-scroll-hint" aria-hidden="true">横にスクロールして続きを表示 →</p>

      <ol class="route-timeline" tabindex="0" aria-label="巡回順序。PCでは左右にスクロールできます">
        {routeSpots.map((spot) => (
          <li class:list={["timeline-item", { "is-last": spot.order === routeSpots.length, "is-goal": spot.order === routeSpots.length }]} data-timeline-spot={spot.slug} data-standard-arrival={spot.arrival} data-standard-next-walk={spot.nextWalk}>
            <article class="timeline-card">
              <div class="timeline-head">
                <span class="timeline-marker" aria-hidden="true" data-timeline-order>{String(spot.order).padStart(2, "0")}</span>
                <div class="timeline-place">
                  <p class="arrival"><span>到着目安</span> <time data-timeline-arrival>{spot.arrival}</time></p>
                  <h3>{spot.name}</h3>
                </div>
                <span class="endpoint-badge" data-timeline-endpoint hidden={spot.order !== 1 && spot.order !== routeSpots.length}>{spot.order === 1 ? "START" : spot.order === routeSpots.length ? "GOAL" : ""}</span>
              </div>
              <p class="stay-badge">滞在 {spot.stay}</p>

              <details class="timeline-details">
                <summary>詳細</summary>
                <p class="step-note">{spot.note}</p>
                <div class="step-actions">
                  <a href={spot.detailUrl} data-route-action="open-spot" data-route-target={spot.slug}>スポット詳細</a>
                  <a
                    href={spot.googleMapsUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    data-route-action="open-google-maps"
                    data-route-target={spot.googleMapsUrl}
                  >Google Maps</a>
                </div>

                {spot.breakAfter && (
                  <div class="break-card">
                    <p>{spot.breakAfter.time}</p>
                    <h4>{spot.breakAfter.title}</h4>
                    <span>{spot.breakAfter.description}</span>
                  </div>
                )}

                {exitOptionsBySlug.has(spot.slug) && (() => {
                  const exitOption = exitOptionsBySlug.get(spot.slug);
                  const panelId = `exit-option-${exitOption.id}`;
                  return (
                    <div class="exit-option" data-exit-option={exitOption.id}>
                      <button type="button" aria-expanded="false" aria-controls={panelId} data-exit-toggle><span>ルート調整</span><span>大吉山を省略</span></button>
                      <div id={panelId} class="exit-option-panel" hidden data-exit-panel>
                        <h4>{exitOption.title}</h4>
                        <p>{exitOption.guidance}</p>
                        <dl>
                          <div><dt>切替地点</dt><dd>{exitOption.endPoint}</dd></div>
                          <div><dt>{exitOption.destinationLabel}</dt><dd>{exitOption.destination}</dd></div>
                          <div><dt>省略区間</dt><dd>{exitOption.omittedSection}</dd></div>
                          {exitOption.timeSaved && <div><dt>短縮目安</dt><dd>{exitOption.timeSaved}</dd></div>}
                        </dl>
                        <a href="#route-map" data-show-exit-map>地図で確認</a>
                      </div>
                    </div>
                  );
                })()}
              </details>
            </article>
            <p class="timeline-transfer" data-timeline-transfer hidden={spot.order === routeSpots.length}><span aria-hidden="true">→</span><span>{spot.nextWalk}</span></p>
          </li>
        ))}
      </ol>
      <script type="application/json" data-timeline-variants set:html={timelineVariantsJson}></script>
    </section>

    {content.practicalInfo && (
      <section class="route-section practical-section" aria-labelledby="practical-heading">
        <div class="section-heading">
          <p class="section-label">現地での調整</p>
          <h2 id="practical-heading">{content.practicalInfo.title}</h2>
          <p>{content.practicalInfo.description}</p>
        </div>
        <div class="practical-list">
          {content.practicalInfo.items.map((item) => (
            <article id={item.id} tabindex={item.id ? "-1" : undefined}>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))}
        </div>
      </section>
    )}

    <section class="route-section option-section" aria-labelledby="option-heading">
      <div class="option-badge">追加オプション</div>
      <h2 id="option-heading">{route.option.title}</h2>
      <p>{route.option.description}</p>
      <p>{route.option.plan}</p>
      <div class="step-actions">
        <a href={`/spots/${optionSpot.slug}/`} data-route-action="open-spot" data-route-target={optionSpot.slug}>{route.option.linkLabel}</a>
        <a
          href={`https://www.google.com/maps/search/?api=1&query=${optionSpot.lat},${optionSpot.lng}`}
          target="_blank"
          rel="noopener noreferrer"
          data-route-action="open-google-maps"
          data-route-target={`https://www.google.com/maps/search/?api=1&query=${optionSpot.lat},${optionSpot.lng}`}
        >Google Mapsで検索</a>
      </div>
    </section>

    <section class="route-section check-section" aria-labelledby="check-heading">
      <div class="section-heading">
        <p class="section-label">出発前の確認</p>
        <h2 id="check-heading">出発前に確認すること</h2>
      </div>
      <ul>
        {content.checkItems.map((item) => <li>{item}</li>)}
      </ul>
    </section>
  </div>
</main>

<script>
  import { setupRouteAnalytics } from "../../scripts/routeAnalytics.js";
  import { setupRouteExitOptions } from "../../scripts/routeExitOptions.js";
  import { setupRouteTimelines } from "../../scripts/routeTimeline.js";

  setupRouteAnalytics();
  setupRouteExitOptions();
  setupRouteTimelines();
</script>

<style>
  .route-page {
    --guide-bg: var(--bg);
    --guide-card: var(--card);
    --guide-text: var(--text);
    --guide-sub: var(--sub);
    --guide-border: var(--border);
    --guide-accent: var(--primary);
    --guide-accent-soft: var(--primary-soft);
    --guide-secondary: var(--secondary);
    --guide-notice-bg: var(--secondary-soft);
    --guide-notice-text: var(--text);
    padding: 16px clamp(16px, 2vw, 32px) 80px;
    background: var(--guide-bg);
    color: var(--guide-text);
  }
  .route-container { width: 100%; max-width: 1680px; margin: 0 auto; }
  .breadcrumb { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 12px; color: var(--guide-sub); font-size: 13px; }
  .breadcrumb a { color: var(--guide-accent); font-weight: 700; }
  .route-hero { padding: clamp(16px, 2.4vw, 28px); background: var(--guide-card); border-top: 4px solid var(--guide-accent); }
  .route-hero h1 { max-width: 820px; font-size: clamp(29px, 5vw, 44px); line-height: 1.2; }
  .route-hero h1 span { display: block; margin-bottom: 5px; color: var(--guide-sub); font-size: .48em; font-weight: 700; letter-spacing: .02em; }
  .hero-route-result { display: grid; grid-template-columns: minmax(220px, .75fr) minmax(0, 1.7fr); gap: 10px 24px; margin-top: 12px; padding: 12px 16px; border: 1px solid var(--guide-border); border-radius: 12px; background: var(--guide-accent-soft); }
  .hero-route-heading { display: flex; flex-wrap: wrap; align-items: center; gap: 7px 10px; }
  .hero-route-result h2 { margin: 0; padding: 0; border: 0; font-size: clamp(22px, 3vw, 26px); }
  .route-status { display: inline-flex; min-height: 25px; align-items: center; padding: 2px 8px; border: 1px solid var(--guide-accent); border-radius: 999px; color: var(--guide-accent); font-size: 14px; font-weight: 800; }
  .hero-route-meta { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 8px 14px; margin: 0; align-content: center; }
  .hero-route-meta div { min-width: 0; }
  .hero-route-meta dt { color: var(--guide-sub); font-size: 14px; font-weight: 700; }
  .hero-route-meta dd { margin: 2px 0 0; font-size: 16px; font-weight: 800; line-height: 1.4; }
  .verification-notice { margin-top: 18px; padding: 18px 20px; border-left: 3px solid #9a8053; background: var(--guide-notice-bg); }
  .verification-notice summary, .verification-notice p { color: var(--guide-notice-text); }
  .verification-notice summary { font-weight: 800; cursor: pointer; }
  .verification-notice p { margin: 4px 0 0; }
  .route-section { max-width: 1120px; margin: 30px auto 0; padding: clamp(24px, 4vw, 36px); border-top: 1px solid var(--guide-border); background: var(--guide-card); }
  .section-label { margin: 0 0 6px; color: var(--guide-accent); font-size: 14px; font-weight: 700; }
  .section-heading h2, .option-section h2 { margin: 0; padding: 0; border: 0; font-size: clamp(24px, 4vw, 32px); }
  .section-heading > p:last-child { margin: 8px 0 0; color: var(--guide-sub); }
  .timeline-section { max-width: none; overflow: hidden; }
  .timeline-heading { display: flex; align-items: end; justify-content: space-between; gap: 18px 30px; }
  .timeline-heading h2 { margin: 0; padding: 0; border: 0; font-size: clamp(24px, 4vw, 32px); }
  .timeline-heading p { margin: 4px 0 0; color: var(--guide-sub); font-size: 14px; }
  .timeline-summary { display: grid; grid-template-columns: auto auto minmax(260px, auto); gap: 12px 24px; margin: 0; }
  .timeline-summary div { min-width: 0; }
  .timeline-summary dt { color: var(--guide-sub); font-size: 14px; font-weight: 700; }
  .timeline-summary dd { margin: 2px 0 0; font-size: 16px; font-weight: 800; line-height: 1.4; }
  .timeline-summary-route dd { overflow-wrap: anywhere; }
  .timeline-omitted { width: fit-content; margin: 12px 0 0; padding: 3px 9px; border-radius: 999px; background: var(--guide-accent-soft); color: var(--guide-accent); font-size: 14px; font-weight: 800; }
  .timeline-note { margin-top: 8px; color: var(--guide-sub); font-size: 14px; }
  .timeline-note summary, .timeline-details summary { width: fit-content; color: var(--guide-secondary); font-weight: 800; cursor: pointer; }
  .timeline-note summary:focus-visible, .timeline-details summary:focus-visible { outline: 3px solid var(--guide-accent); outline-offset: 3px; }
  .timeline-note p { max-width: 820px; margin: 6px 0 0; }
  .timeline-scroll-hint { margin: 16px 0 6px; color: var(--guide-sub); font-size: 14px; text-align: right; }
  .route-timeline { display: flex; width: 100%; gap: 0; margin: 0; padding: 4px 0 14px; overflow-x: auto; overscroll-behavior-inline: contain; scroll-snap-type: inline proximity; scrollbar-color: var(--guide-accent) var(--guide-border); list-style: none; }
  .route-timeline:focus-visible { outline: 3px solid var(--guide-accent); outline-offset: 3px; }
  .timeline-item { display: grid; flex: 0 0 clamp(290px, 22vw, 340px); grid-template-columns: minmax(220px, 1fr) 74px; align-items: center; scroll-snap-align: start; }
  .timeline-item[hidden] { display: none; }
  .timeline-item.is-last { grid-template-columns: minmax(220px, 1fr); padding-right: 10px; }
  .timeline-card { min-width: 0; min-height: 210px; padding: 16px; border: 1px solid var(--guide-border); border-radius: 10px; background: var(--guide-card); }
  .timeline-head { display: grid; grid-template-columns: 42px minmax(0, 1fr); gap: 10px; align-items: start; }
  .timeline-marker { display: grid; place-items: center; width: 40px; height: 40px; border-radius: 50%; background: var(--guide-accent); color: #fff; font-size: 14px; font-weight: 900; }
  .timeline-item.is-goal .timeline-marker { background: var(--guide-secondary); }
  .timeline-place { min-width: 0; }
  .arrival { display: flex; flex-wrap: wrap; gap: 4px 7px; margin: 0 0 3px; color: var(--guide-sub); font-size: 14px; font-weight: 700; }
  .arrival time { color: var(--guide-accent); font-size: 16px; font-weight: 900; }
  .timeline-head h3 { margin: 0; font-size: 18px; line-height: 1.4; }
  .endpoint-badge { grid-column: 1 / -1; width: fit-content; padding: 2px 8px; border: 1px solid var(--guide-accent); border-radius: 999px; color: var(--guide-accent); font-size: 14px; font-weight: 900; }
  .timeline-item.is-goal .endpoint-badge { border-color: var(--guide-secondary); color: var(--guide-secondary); }
  .stay-badge { margin: 12px 0 0; color: var(--guide-text); font-size: 14px; font-weight: 800; }
  .timeline-details { margin-top: 12px; border-top: 1px solid var(--guide-border); padding-top: 8px; color: var(--guide-sub); font-size: 14px; }
  .timeline-transfer { display: grid; justify-items: center; gap: 5px; margin: 0; color: var(--guide-sub); font-size: 14px; font-weight: 800; line-height: 1.35; text-align: center; }
  .timeline-transfer > span:first-child { width: 100%; color: var(--guide-accent); font-size: 28px; line-height: 1; }
  .timeline-transfer[hidden] { display: none; }
  .option-badge { display: inline-block; margin-bottom: 10px; color: var(--guide-accent); font-size: 12px; font-weight: 800; }
  .step-note { margin: 8px 0 0; color: var(--guide-sub); font-size: 14px; }
  .step-actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 16px; }
  .step-actions a { padding: 8px 11px; border: 1px solid var(--guide-border); border-radius: 3px; background: #fff; color: var(--guide-accent); font-size: 13px; font-weight: 800; }
  .exit-option { margin-top: 16px; padding-top: 14px; border-top: 1px solid var(--guide-border); }
  .exit-option > button { display: inline-flex; min-height: 44px; align-items: center; gap: 8px; padding: 9px 14px; border: 1px solid var(--guide-secondary); border-radius: 4px; background: #fff; color: var(--guide-secondary); font: inherit; font-size: 14px; font-weight: 800; cursor: pointer; }
  .exit-option > button span:first-child { padding-right: 8px; border-right: 1px solid var(--guide-border); font-size: 14px; }
  .exit-option > button:focus-visible, .exit-option-panel a:focus-visible { outline: 3px solid var(--guide-accent); outline-offset: 3px; }
  .exit-option-panel { margin-top: 10px; padding: 15px; border-left: 3px solid var(--guide-secondary); background: var(--guide-secondary-soft, var(--secondary-soft)); }
  .exit-option-panel h4 { margin: 0; font-size: 16px; }
  .exit-option-panel > p { margin: 6px 0 0; color: var(--guide-sub); font-size: 13px; }
  .exit-option-panel dl { display: grid; gap: 7px; margin: 10px 0 0; }
  .exit-option-panel dl div { display: grid; grid-template-columns: 130px minmax(0, 1fr); gap: 8px; }
  .exit-option-panel dt { color: var(--guide-sub); font-size: 12px; font-weight: 800; }
  .exit-option-panel dd { margin: 0; font-size: 13px; }
  .exit-option-panel a { display: inline-flex; min-height: 44px; align-items: center; margin-top: 12px; padding: 9px 12px; border-radius: 4px; background: var(--guide-secondary); color: #fff; font-size: 14px; font-weight: 800; }
  .break-card { margin-top: 12px; padding: 10px 12px; border-left: 3px solid var(--guide-accent); background: var(--guide-accent-soft); }
  .break-card p { margin: 0; color: var(--guide-accent); font-size: 12px; font-weight: 800; }
  .break-card h4 { margin: 2px 0; font-size: 16px; }
  .break-card span { color: var(--guide-sub); font-size: 13px; }
  .practical-list { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; margin-top: 24px; }
  .practical-list article { padding: 18px; border: 1px solid var(--guide-border); background: var(--guide-card); }
  .practical-list article:last-child { grid-column: 1 / -1; }
  .practical-list h3 { margin: 0; font-size: 17px; }
  .practical-list p { margin: 7px 0 0; color: var(--guide-sub); font-size: 14px; }
  .option-section { background: var(--guide-accent-soft); }
  .option-section p { color: var(--guide-sub); }
  .check-section ul { margin: 20px 0 0; padding-left: 20px; }
  .check-section li + li { margin-top: 8px; }
  @media (max-width: 720px) {
    .route-page { padding: 12px 12px 56px; }
    .route-hero { padding: 16px 14px 18px; }
    .hero-route-result { grid-template-columns: 1fr; }
    .hero-route-meta { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .route-section { padding: 20px 14px; }
    .timeline-heading { display: block; }
    .timeline-summary { grid-template-columns: repeat(2, minmax(0, 1fr)); margin-top: 12px; }
    .timeline-summary-route { grid-column: 1 / -1; }
    .timeline-scroll-hint { display: none; }
    .route-timeline { display: block; padding-bottom: 0; overflow: visible; scroll-snap-type: none; }
    .timeline-item, .timeline-item.is-last { position: relative; display: block; padding: 0 0 12px 50px; }
    .timeline-item[hidden] { display: none; }
    .timeline-item:not(.is-last)::before { content: ""; position: absolute; top: 40px; bottom: -2px; left: 19px; width: 2px; background: var(--guide-accent); }
    .timeline-card { min-height: 0; padding: 13px 14px; }
    .timeline-head { display: block; }
    .timeline-marker { position: absolute; z-index: 1; top: 0; left: 0; width: 40px; height: 40px; }
    .endpoint-badge { margin-top: 7px; }
    .timeline-transfer { justify-items: start; gap: 3px; padding: 9px 0 3px; text-align: left; }
    .timeline-transfer > span:first-child { width: auto; transform: rotate(90deg); font-size: 23px; }
    .exit-option > button, .exit-option-panel a { width: 100%; justify-content: center; }
    .exit-option-panel dl div { grid-template-columns: 1fr; gap: 1px; }
    .practical-list { grid-template-columns: 1fr; }
    .practical-list article:last-child { grid-column: auto; }
  }
</style>
