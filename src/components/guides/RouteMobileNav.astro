---
const { routeVariants, initialRouteVariant } = Astro.props;
const variantsJson = JSON.stringify(Object.fromEntries(
  Object.entries(routeVariants).map(([id, variant]) => [id, {
    compactLabel: variant.compactLabel ?? variant.label,
    spotCount: variant.visibleSpotSlugs.length,
  }]),
)).replace(/</g, "\\u003c");
const initialVariant = routeVariants[initialRouteVariant];
---

<nav class="route-mobile-nav" aria-label="ルートガイド内の移動" data-route-mobile-nav>
  <p class="route-mobile-status" aria-live="polite" data-mobile-route-status>
    {initialVariant.compactLabel ?? initialVariant.label}<span aria-hidden="true">｜</span>{initialVariant.visibleSpotSlugs.length}地点
  </p>
  <div class="route-mobile-links">
    <a href="#route-map" data-mobile-nav-destination="map">地図</a>
    <a href="#situation-adjuster" data-mobile-nav-destination="conditions">条件</a>
    <a href="#route-order-heading" data-mobile-nav-destination="timeline">順番</a>
  </div>
  <script type="application/json" data-mobile-route-variants set:html={variantsJson}></script>
</nav>

<style>
  .route-mobile-nav { display: none; }
  @media (max-width: 720px) {
    .route-mobile-nav { position: fixed; z-index: 19; right: 0; bottom: 0; left: 0; display: block; padding: 5px max(12px, env(safe-area-inset-right)) calc(6px + env(safe-area-inset-bottom)) max(12px, env(safe-area-inset-left)); border-top: 1px solid var(--guide-border); background: rgba(255, 255, 255, .97); color: var(--guide-text); box-shadow: 0 -2px 7px rgba(23, 48, 66, .08); backdrop-filter: blur(10px); }
    .route-mobile-status { margin: 0 0 3px; overflow: hidden; color: var(--guide-sub); font-size: 13px; font-weight: 800; line-height: 1.3; text-align: center; text-overflow: ellipsis; white-space: nowrap; }
    .route-mobile-links { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 5px; }
    .route-mobile-links a { display: grid; min-width: 0; min-height: 44px; place-items: center; border: 1px solid transparent; border-radius: 7px; color: var(--guide-text); font-size: 14px; font-weight: 800; text-decoration: none; }
    .route-mobile-links a[aria-current="location"] { border-color: var(--guide-accent); background: var(--guide-accent-soft); color: var(--guide-accent); }
    .route-mobile-links a[aria-current="location"]::before { content: "現在地"; display: block; height: 12px; font-size: 10px; line-height: 1; }
    .route-mobile-links a:focus-visible { outline: 3px solid var(--guide-accent); outline-offset: 1px; }
  }
</style>
