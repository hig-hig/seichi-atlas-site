---
const {
  locations,
  supportFacilities = [],
  exitPoints = [],
  routeVariants = {},
  recommendations = {},
  quickChoices = [],
  sectionTitle,
  description,
  mapAriaLabel,
  editMapUrl,
  initialCenter,
} = Astro.props;

const locationsJson = JSON.stringify(locations).replace(/</g, "\\u003c");
const categoryLabels = {
  toilet: "トイレ",
  rest: "休憩",
  "tourist-information": "観光案内",
};
const formatJapaneseDate = (date) => {
  const [year, month, day] = date.split("-");
  return `${year}年${Number(month)}月${Number(day)}日`;
};
const supportFacilitiesJson = JSON.stringify(supportFacilities.map((facility) => ({
  ...facility,
  categoriesLabel: facility.categories.map((category) => categoryLabels[category] ?? category).join("・"),
  markerLabel: facility.categories.includes("rest")
    ? "休憩・トイレ"
    : facility.categories.includes("toilet") ? "案内・トイレ" : "観光案内",
  markerVariant: facility.categories.includes("rest")
    ? "rest"
    : facility.categories.includes("toilet") ? "information-toilet" : "information",
  markerLayer: facility.categories.includes("rest") ? "rest" : "tourist-information",
  verificationSummary: `${formatJapaneseDate(facility.sourceUpdatedAt)}更新の公式情報を、${formatJapaneseDate(facility.verifiedAt)}に確認`,
  fieldCheckLabel: facility.fieldChecked ? "現地確認済み" : "現地未確認",
}))).replace(/</g, "\\u003c");
const exitPointsJson = JSON.stringify(exitPoints).replace(/</g, "\\u003c");
const routeVariantsJson = JSON.stringify(routeVariants).replace(/</g, "\\u003c");
const initialRecommendation = recommendations.standard;
const initialSpotCount = routeVariants[initialRecommendation.routeVariant].visibleSpotSlugs.length;
---

<section class="route-section map-section" id="route-map" aria-labelledby="route-map-heading" tabindex="-1">
  <div class="section-heading">
    <h2 id="route-map-heading">{sectionTitle}</h2>
    <p>{description}</p>
  </div>
  <p class="map-result-summary" data-map-result-summary aria-live="polite">
    <strong>現在の表示：</strong><span>{initialRecommendation.mapAction.summary}｜{initialSpotCount}地点｜{initialRecommendation.timing}</span>
  </p>
  <ul class="map-legend" aria-label="地図の凡例">
    <li><span class="legend-symbol legend-route" aria-hidden="true"></span>現在のルート</li>
    <li data-legend-layer="spots"><span class="legend-symbol legend-spot" aria-hidden="true">1</span>聖地点</li>
    <li data-legend-layer="rest"><span class="legend-symbol legend-rest" aria-hidden="true">休</span>休憩</li>
    <li data-legend-layer="tourist-information" hidden><span class="legend-symbol legend-information" aria-hidden="true">i</span>観光案内</li>
    <li data-legend-layer="exit" hidden><span class="legend-symbol legend-exit" aria-hidden="true">→</span>省略地点</li>
  </ul>
  <p class="route-variant-notice" data-route-variant-notice hidden></p>
  <details class="map-tools">
    <summary>表示項目</summary>
    <div class="map-layer-controls" aria-label="地図の表示切替">
    <button type="button" aria-pressed="true" data-map-layer="spots" data-route-action="toggle-map-layer" data-route-target="spots:visible">
      <span class="map-layer-check" aria-hidden="true">✓</span>
      <span>聖地スポット</span>
      <small>表示中</small>
    </button>
    <button type="button" aria-pressed="true" data-map-layer="rest" data-route-action="toggle-map-layer" data-route-target="rest:visible">
      <span class="map-layer-check" aria-hidden="true">✓</span>
      <span>トイレ・休憩</span>
      <small>表示中</small>
    </button>
    <button type="button" aria-pressed="true" data-map-layer="tourist-information" data-route-action="toggle-map-layer" data-route-target="tourist-information:visible">
      <span class="map-layer-check" aria-hidden="true">✓</span>
      <span>観光案内</span>
      <small>表示中</small>
    </button>
    <button type="button" aria-pressed="true" data-map-layer="exit" data-route-action="toggle-map-layer" data-route-target="exit:visible" data-route-exit-option={exitPoints.map((point) => point.id).join(",")}>
      <span class="map-layer-check" aria-hidden="true">✓</span>
      <span>大吉山を省略</span>
      <small>表示中</small>
    </button>
    </div>
  </details>
  <div class="route-map-shell">
    <div class="map-route-switcher" data-map-route-switcher>
      <button type="button" class="map-route-toggle" aria-expanded="false" aria-controls="map-route-panel" data-map-route-toggle>
        <span>ルート変更</span><span data-map-route-toggle-status>{quickChoices.find((choice) => choice.recommendation === "standard")?.label ?? initialRecommendation.label}・{initialSpotCount}地点</span>
      </button>
      <div class="map-route-panel" id="map-route-panel" hidden data-map-route-panel>
        <p>現在：<strong data-map-current-route>{initialRecommendation.label}</strong></p>
        <div class="map-route-choices" aria-label="ルートの簡易選択">
          {quickChoices.map((choice) => (
            <button type="button" aria-pressed={choice.recommendation === "standard" ? "true" : "false"} data-map-recommendation={choice.recommendation}>
              {choice.label}
            </button>
          ))}
        </div>
        <a href="#situation-adjuster" data-map-all-conditions>すべての条件を見る</a>
      </div>
    </div>
    <div id="guide-route-map" aria-label={mapAriaLabel} data-initial-center={JSON.stringify(initialCenter)}></div>
  </div>
  <p class="map-adjuster-link"><a href="#situation-adjuster">時間・天候・歩く量から詳しく調整する</a></p>
  <p class="map-attribution-note">
    地図：<a href="https://openfreemap.org/" target="_blank" rel="noopener noreferrer">OpenFreeMap</a>・
    <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener noreferrer">OpenStreetMap contributors</a>／
    経路：<a href="https://routing.openstreetmap.de/about.html" target="_blank" rel="noopener noreferrer">FOSSGIS OSRM</a>・
    <a href={editMapUrl} target="_blank" rel="noopener noreferrer">地図を修正</a>
  </p>
  <script type="application/json" id="guide-route-map-data" set:html={locationsJson}></script>
  <script type="application/json" id="guide-route-support-data" set:html={supportFacilitiesJson}></script>
  <script type="application/json" id="guide-route-exit-data" set:html={exitPointsJson}></script>
  <script type="application/json" id="guide-route-variants-data" set:html={routeVariantsJson}></script>
</section>

<style>
  .route-section { margin-top: clamp(28px, 4vw, 44px); padding: clamp(18px, 2.4vw, 30px); border: 1px solid var(--guide-border); border-radius: 24px; background: var(--guide-card); box-shadow: 0 10px 28px rgba(18, 54, 68, .05); }
  .section-label { margin: 0 0 6px; color: var(--guide-accent); font-size: 14px; font-weight: 700; }
  .section-heading h2 { margin: 0; padding: 0; border: 0; font-size: clamp(24px, 3vw, 32px); letter-spacing: -.01em; }
  .section-heading > p:last-child { margin: 5px 0 0; color: var(--guide-sub); font-size: 14px; }
  .map-section { width: 100%; max-width: none; margin-top: 10px; scroll-margin-top: 88px; }
  .map-section:focus { outline: none; }
  .map-result-summary { margin: 16px 0 0; padding: 12px 15px; border-left: 4px solid var(--guide-accent); border-radius: 12px; background: var(--guide-accent-soft); font-size: 15px; line-height: 1.55; overflow-wrap: anywhere; }
  .map-legend { display: flex; flex-wrap: wrap; gap: 7px 16px; margin: 11px 2px 0; padding: 0; color: var(--guide-sub); font-size: 14px; line-height: 1.5; list-style: none; }
  .map-legend li { display: inline-flex; align-items: center; gap: 7px; min-width: 0; }
  .map-legend li[hidden] { display: none; }
  .legend-symbol { display: inline-grid; flex: 0 0 auto; place-items: center; color: #fff; font: 800 14px/1 "Noto Sans JP", sans-serif; }
  .legend-route { width: 30px; height: 5px; border: 3px solid rgba(255,255,255,.96); border-radius: 8px; background: var(--guide-accent); box-shadow: 0 0 0 1px rgba(23,48,66,.16); }
  .legend-spot { width: 20px; height: 20px; border: 2px solid #fff; border-radius: 50%; background: var(--guide-accent); box-shadow: 0 0 0 1px rgba(23,48,66,.18); }
  .legend-rest { min-width: 24px; height: 20px; padding: 0 4px; border-radius: 4px; background: #5d6f2f; }
  .legend-information { width: 22px; height: 20px; border-radius: 12px; background: #3157a4; }
  .legend-exit { width: 25px; height: 20px; padding-right: 3px; clip-path: polygon(0 0, calc(100% - 7px) 0, 100% 50%, calc(100% - 7px) 100%, 0 100%); background: #b5424a; }
  .route-variant-notice { margin: 8px 2px 0; color: var(--guide-sub); font-size: 14px; line-height: 1.6; }
  .map-tools { margin-top: 12px; color: var(--guide-sub); font-size: 14px; }
  .map-tools summary { width: fit-content; color: var(--guide-secondary); font-weight: 700; cursor: pointer; }
  .map-tools summary:focus-visible { outline: 3px solid var(--guide-accent); outline-offset: 3px; }
  .map-layer-controls { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
  .map-layer-controls button { display: inline-flex; min-height: 42px; align-items: center; gap: 7px; padding: 8px 12px; border: 1px solid var(--guide-accent); border-radius: 10px; background: var(--guide-accent-soft); color: var(--guide-text); font: inherit; font-size: 14px; font-weight: 700; cursor: pointer; }
  .map-layer-controls button[aria-pressed="false"] { border-color: var(--guide-border); background: #fff; color: var(--guide-sub); }
  .map-layer-controls button:focus-visible { outline: 3px solid var(--guide-accent); outline-offset: 2px; }
  .map-layer-controls small { font-size: 14px; font-weight: 700; }
  .route-map-shell { position: relative; height: min(68vh, 680px); min-height: 430px; margin-top: 16px; overflow: hidden; border: 1px solid var(--guide-border); border-radius: 18px; background: #e8eef1; box-shadow: 0 8px 24px rgba(18, 54, 68, .08); }
  .map-route-switcher { position: absolute; z-index: 3; top: 12px; left: 12px; width: min(320px, calc(100% - 24px)); font-size: 14px; }
  .map-route-toggle { display: flex; max-width: 100%; min-height: 44px; align-items: center; gap: 6px; padding: 9px 14px; border: 1px solid rgba(0, 140, 149, .65); border-radius: 12px; background: rgba(255,255,255,.96); color: var(--guide-text); font: inherit; font-weight: 700; line-height: 1.35; text-align: left; box-shadow: 0 4px 14px rgba(18, 54, 68, .12); cursor: pointer; backdrop-filter: blur(8px); }
  .map-route-toggle span + span::before { content: "｜"; color: var(--guide-accent); }
  .map-route-toggle[aria-expanded="true"] { background: var(--guide-accent-soft); }
  .map-route-panel { margin-top: 8px; padding: 15px; border: 1px solid var(--guide-border); border-radius: 16px; background: rgba(255,255,255,.97); box-shadow: 0 8px 22px rgba(18,54,68,.13); backdrop-filter: blur(10px); }
  .map-route-panel[hidden] { display: none; }
  .map-route-panel p { margin: 0; line-height: 1.5; }
  .map-route-choices { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 6px; margin-top: 9px; }
  .map-route-choices button { min-height: 40px; padding: 7px 9px; border: 1px solid var(--guide-border); border-radius: 10px; background: #fff; color: var(--guide-text); font: inherit; font-weight: 700; cursor: pointer; }
  .map-route-choices button:hover { background: var(--guide-accent-soft); }
  .map-route-choices button[aria-pressed="true"] { border-color: var(--guide-accent); background: var(--guide-accent-soft); color: var(--guide-text); }
  .map-route-panel a { display: inline-block; margin-top: 10px; color: var(--guide-secondary); font-weight: 800; text-decoration: underline; }
  .map-route-toggle:focus-visible, .map-route-choices button:focus-visible, .map-route-panel a:focus-visible { outline: 3px solid var(--guide-accent); outline-offset: 2px; }
  #guide-route-map { width: 100%; height: 100%; }
  .map-attribution-note { margin: 8px 2px 0; color: var(--guide-sub); font-size: 14px; line-height: 1.6; }
  .map-attribution-note a { text-decoration: underline; }
  .map-adjuster-link { margin: 12px 0 0; font-size: 14px; font-weight: 800; text-align: center; }
  .map-adjuster-link a { color: var(--guide-secondary); text-decoration: underline; text-underline-offset: 3px; }
  :global(.route-map-marker) { display: grid; place-items: center; width: 34px; height: 34px; border: 2px solid #fff; border-radius: 50%; background: #008c95; color: #fff; font: 900 14px/1 "Noto Sans JP", sans-serif; box-shadow: 0 2px 5px rgba(23,48,66,.20); cursor: pointer; }
  :global(.route-map-marker.is-selected) { background: #3157a4; }
  :global(.route-map-marker[hidden]), :global(.route-support-marker[hidden]), :global(.route-exit-marker[hidden]) { display: none; }
  :global(.route-support-marker) { display: grid; place-items: center; min-width: 76px; min-height: 32px; padding: 4px 7px; border: 2px solid #fff; border-radius: 4px; background: #5d6f2f; color: #fff; font: 800 14px/1.2 "Noto Sans JP", sans-serif; box-shadow: 0 2px 5px rgba(23,48,66,.22); cursor: pointer; }
  :global(.route-support-marker--information) { border-radius: 18px; background: #3157a4; }
  :global(.route-support-marker--information-toilet) { min-width: 96px; border-radius: 0; clip-path: polygon(8px 0, calc(100% - 8px) 0, 100% 50%, calc(100% - 8px) 100%, 8px 100%, 0 50%); background: #5a4e91; }
  :global(.route-exit-marker) { display: grid; place-items: center; min-width: 82px; min-height: 34px; padding: 4px 12px 4px 9px; border: 2px solid #fff; clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 50%, calc(100% - 12px) 100%, 0 100%); background: #b5424a; color: #fff; font: 800 14px/1.2 "Noto Sans JP", sans-serif; box-shadow: 0 2px 5px rgba(23,48,66,.22); cursor: pointer; }
  :global(.maplibregl-popup-content) { padding: 13px 15px; border-radius: 12px; box-shadow: 0 8px 24px rgba(18, 54, 68, .14); font-family: "Noto Sans JP", sans-serif; }
  :global(.maplibregl-popup-content strong) { display: block; max-width: 220px; font-size: 14px; }
  :global(.route-support-popup) { max-width: 280px; }
  :global(.route-support-popup dl) { margin: 8px 0 0; font-size: 14px; }
  :global(.route-support-popup dl div) { display: grid; grid-template-columns: 76px minmax(0, 1fr); gap: 6px; }
  :global(.route-support-popup dt) { font-weight: 800; }
  :global(.route-support-popup dd) { margin: 0; }
  :global(.route-support-popup p), :global(.maplibregl-popup-content p) { margin: 8px 0 0; font-size: 14px; line-height: 1.6; }
  :global(.maplibregl-popup-content a) { display: inline-block; margin-top: 5px; color: #3157a4; font-size: 14px; font-weight: 800; }
  @media (max-width: 720px) {
    .route-section { padding: 20px 14px; }
    .map-section { scroll-margin-top: 112px; }
    .map-layer-controls { display: grid; grid-template-columns: 1fr; }
    .map-layer-controls button { width: 100%; justify-content: flex-start; }
    .map-layer-controls small { margin-left: auto; }
    .map-legend { gap: 7px 13px; }
    .route-map-shell { height: min(62vh, 560px); min-height: 420px; }
    .map-route-toggle { flex-wrap: wrap; }
    .map-route-toggle span + span::before { content: ""; }
  }
</style>

<script>
  import maplibregl from "maplibre-gl";
  import "maplibre-gl/dist/maplibre-gl.css";
  import { setRouteSpotSelection } from "../../scripts/routeSpotSelection.js";

  const dataElement = document.getElementById("guide-route-map-data");
  const routeLocations = JSON.parse(dataElement?.textContent || "[]");
  const supportDataElement = document.getElementById("guide-route-support-data");
  const supportFacilities = JSON.parse(supportDataElement?.textContent || "[]");
  const exitDataElement = document.getElementById("guide-route-exit-data");
  const exitPoints = JSON.parse(exitDataElement?.textContent || "[]");
  const variantsElement = document.getElementById("guide-route-variants-data");
  const routeVariants = JSON.parse(variantsElement?.textContent || "{}");
  const savedRouteGeometry = routeVariants.standard?.geometry || { type: "FeatureCollection", features: [] };
  const mapContainer = document.getElementById("guide-route-map");
  const initialCenter = JSON.parse(mapContainer?.dataset.initialCenter || "[0,0]");
  const layerMarkers = {
    spots: [],
    rest: [],
    "tourist-information": [],
    exit: [],
  };
  const routeMarkers = new Map();
  const exitMarkers = new Map();
  const summaryElement = document.querySelector("[data-map-result-summary] span");
  const variantNotice = document.querySelector("[data-route-variant-notice]");
  const routeToggle = document.querySelector("[data-map-route-toggle]");
  const routeToggleStatus = document.querySelector("[data-map-route-toggle-status]");
  const routePanel = document.querySelector("[data-map-route-panel]");
  const mapCurrentRoute = document.querySelector("[data-map-current-route]");
  const mapRecommendationButtons = [...document.querySelectorAll("[data-map-recommendation]")];
  const legendItems = new Map([...document.querySelectorAll("[data-legend-layer]")]
    .map((item) => [item.dataset.legendLayer, item]));

  if (mapContainer && routeLocations.length && mapContainer.dataset.ready !== "true") {
    mapContainer.dataset.ready = "true";
    let mapLoaded = false;
    let pendingMapState = window.routeSituationPendingMapAction || null;
    let activeSpotSlugs = new Set(routeLocations.map((location) => location.slug));
    let currentRouteCoordinates = savedRouteGeometry?.features?.[0]?.geometry?.coordinates || [];
    let pendingSpotSelection = null;
    const narrowMapMedia = window.matchMedia("(max-width: 720px)");
    const reducedMotionMedia = window.matchMedia("(prefers-reduced-motion: reduce)");
    const markerFocusStates = new WeakMap();
    const registerMarkerFocus = (marker) => {
      const element = marker.getElement();
      markerFocusStates.set(marker, {
        hadTabindex: element.hasAttribute("tabindex"),
        tabindex: element.getAttribute("tabindex"),
      });
    };
    const setMarkerVisibility = (marker, visible) => {
      const element = marker.getElement();
      const focusState = markerFocusStates.get(marker);
      element.hidden = !visible;
      if (visible) {
        element.removeAttribute("aria-hidden");
        if (focusState?.hadTabindex) element.setAttribute("tabindex", focusState.tabindex);
        else element.removeAttribute("tabindex");
      } else {
        element.setAttribute("aria-hidden", "true");
        element.setAttribute("tabindex", "-1");
        marker.getPopup()?.remove();
      }
    };
    const map = new maplibregl.Map({
      container: mapContainer,
      style: "https://tiles.openfreemap.org/styles/positron",
      center: initialCenter,
      zoom: 14,
      attributionControl: true,
    });

    map.addControl(new maplibregl.NavigationControl({ showCompass: false }), "bottom-right");

    const setRoutePanelOpen = (open) => {
      routeToggle?.setAttribute("aria-expanded", String(open));
      if (routePanel) routePanel.hidden = !open;
    };
    const syncMapRecommendation = (detail) => {
      if (mapCurrentRoute) mapCurrentRoute.textContent = detail.label;
      const activeChoice = mapRecommendationButtons.find((button) => button.dataset.mapRecommendation === detail.recommendation);
      if (routeToggleStatus) routeToggleStatus.textContent = `${activeChoice?.textContent.trim() || detail.label}・${detail.spotCount}地点`;
      mapRecommendationButtons.forEach((button) => {
        button.setAttribute("aria-pressed", String(button.dataset.mapRecommendation === detail.recommendation));
      });
    };
    routeToggle?.addEventListener("click", () => {
      setRoutePanelOpen(routeToggle.getAttribute("aria-expanded") !== "true");
    });
    mapRecommendationButtons.forEach((button) => {
      button.addEventListener("click", () => {
        window.routeSituationPendingRecommendation = {
          recommendation: button.dataset.mapRecommendation,
          interactionLocation: "map",
        };
        window.dispatchEvent(new CustomEvent("route:request-recommendation", {
          detail: window.routeSituationPendingRecommendation,
        }));
        setRoutePanelOpen(false);
        routeToggle?.focus();
      });
    });
    document.querySelectorAll("[data-map-all-conditions], .map-adjuster-link a").forEach((link) => {
      link.addEventListener("click", (event) => {
        event.preventDefault();
        setRoutePanelOpen(false);
        window.dispatchEvent(new CustomEvent("route:guide-view-request", {
          detail: { view: "selection", source: "map" },
        }));
      });
    });
    document.addEventListener("keydown", (event) => {
      if (event.key !== "Escape" || routePanel?.hidden) return;
      setRoutePanelOpen(false);
      routeToggle?.focus();
    });
    window.addEventListener("route:recommendation-change", (event) => syncMapRecommendation(event.detail));
    if (window.routeSituationState) syncMapRecommendation(window.routeSituationState);

    routeLocations.forEach((location) => {
      const markerElement = document.createElement("button");
      markerElement.className = "route-map-marker";
      markerElement.type = "button";
      markerElement.textContent = String(location.order).padStart(2, "0");
      markerElement.setAttribute("aria-label", `${location.order}. ${location.name}`);

      const popupContent = document.createElement("div");
      const popupName = document.createElement("strong");
      const popupLink = document.createElement("a");
      popupName.textContent = `${location.order}. ${location.name}`;
      popupLink.href = location.detailUrl;
      popupLink.textContent = "スポット詳細";
      popupLink.dataset.routeAction = "open-spot";
      popupContent.append(popupName, popupLink);

      const popup = new maplibregl.Popup({ offset: 24 }).setDOMContent(popupContent);
      const marker = new maplibregl.Marker({ element: markerElement, anchor: "bottom" })
        .setLngLat([location.lng, location.lat])
        .setPopup(popup)
        .addTo(map);
      marker.routeLocation = location;
      marker.popupNameElement = popupName;
      popup.on("open", () => {
        const source = marker.popupSelectionSource || "map";
        marker.popupSelectionSource = null;
        setRouteSpotSelection(location.slug, source);
      });
      popup.on("close", () => {
        if (window.routeSelectedSpotSlug === location.slug) setRouteSpotSelection(null, "map");
      });
      registerMarkerFocus(marker);
      layerMarkers.spots.push(marker);
      routeMarkers.set(location.slug, marker);
    });

    supportFacilities.forEach((facility) => {
      const markerElement = document.createElement("button");
      markerElement.className = `route-support-marker route-support-marker--${facility.markerVariant}`;
      markerElement.type = "button";
      markerElement.textContent = facility.markerLabel;
      markerElement.setAttribute("aria-label", `ルート支援設備：${facility.name}（${facility.markerLabel}）`);

      const popupContent = document.createElement("div");
      popupContent.className = "route-support-popup";
      const popupName = document.createElement("strong");
      popupName.textContent = facility.name;
      const details = document.createElement("dl");
      const appendDetail = (label, value) => {
        const row = document.createElement("div");
        const term = document.createElement("dt");
        const description = document.createElement("dd");
        term.textContent = label;
        description.textContent = value;
        row.append(term, description);
        details.append(row);
      };
      appendDetail("設備", facility.categoriesLabel);
      appendDetail("住所", facility.address);
      appendDetail("案内時間", facility.openingHours);
      appendDetail("施設情報", facility.verificationLabel);
      if (facility.locationVerificationLabel) {
        appendDetail("位置情報", facility.locationVerificationLabel);
      }
      appendDetail("確認日", facility.verificationSummary);
      appendDetail("現地確認", facility.fieldCheckLabel);
      const note = document.createElement("p");
      note.textContent = facility.note;
      const sourceLink = document.createElement("a");
      sourceLink.href = facility.sourceUrl;
      sourceLink.target = "_blank";
      sourceLink.rel = "noopener noreferrer";
      sourceLink.textContent = `施設情報：${facility.sourceName}`;
      popupContent.append(popupName, details, note, sourceLink);
      if (facility.secondarySourceUrl) {
        const secondarySourceLink = document.createElement("a");
        secondarySourceLink.href = facility.secondarySourceUrl;
        secondarySourceLink.target = "_blank";
        secondarySourceLink.rel = "noopener noreferrer";
        secondarySourceLink.textContent = `設備補足：${facility.secondarySourceName}`;
        popupContent.append(secondarySourceLink);
      }
      if (facility.locationSourceUrl) {
        const locationSourceLink = document.createElement("a");
        locationSourceLink.href = facility.locationSourceUrl;
        locationSourceLink.target = "_blank";
        locationSourceLink.rel = "noopener noreferrer";
        locationSourceLink.textContent = `位置情報：${facility.locationSourceName}`;
        popupContent.append(locationSourceLink);
      }

      const popup = new maplibregl.Popup({ offset: 24 }).setDOMContent(popupContent);
      const marker = new maplibregl.Marker({ element: markerElement, anchor: "bottom", offset: [54, 0] })
        .setLngLat([facility.lng, facility.lat])
        .setPopup(popup)
        .addTo(map);
      registerMarkerFocus(marker);
      marker.facility = facility;
      layerMarkers[facility.markerLayer].push(marker);
    });

    exitPoints.forEach((exitPoint) => {
      const markerElement = document.createElement("button");
      markerElement.className = "route-exit-marker";
      markerElement.type = "button";
      markerElement.textContent = exitPoint.mapLabel;
      markerElement.setAttribute("aria-label", `大吉山省略地点：${exitPoint.name}`);

      const popupContent = document.createElement("div");
      const popupName = document.createElement("strong");
      const popupDescription = document.createElement("p");
      popupName.textContent = `大吉山を省略：${exitPoint.name}`;
      popupDescription.textContent = `${exitPoint.title}。${exitPoint.destinationLabel}は${exitPoint.destination}です。`;
      popupContent.append(popupName, popupDescription);

      const popup = new maplibregl.Popup({ offset: 24 }).setDOMContent(popupContent);
      const marker = new maplibregl.Marker({ element: markerElement, anchor: "bottom", offset: [-54, 0] })
        .setLngLat([exitPoint.lng, exitPoint.lat])
        .setPopup(popup)
        .addTo(map);
      registerMarkerFocus(marker);
      layerMarkers.exit.push(marker);
      exitMarkers.set(exitPoint.id, marker);
    });

    const syncSpotMarkerVisibility = () => {
      const layerVisible = document.querySelector('[data-map-layer="spots"]')?.getAttribute("aria-pressed") === "true";
      const visibleLocations = routeLocations.filter((location) => activeSpotSlugs.has(location.slug));
      const displayOrder = new Map(visibleLocations.map((location, index) => [location.slug, index + 1]));
      routeMarkers.forEach((marker, slug) => {
        const location = marker.routeLocation;
        const order = displayOrder.get(slug);
        if (order) {
          marker.getElement().textContent = String(order).padStart(2, "0");
          marker.getElement().setAttribute("aria-label", `${order}. ${location.name}`);
          marker.popupNameElement.textContent = `${order}. ${location.name}`;
        }
        const visible = layerVisible && activeSpotSlugs.has(slug);
        setMarkerVisibility(marker, visible);
      });
    };

    const syncLegendLayer = (layer, visible) => {
      const item = legendItems.get(layer);
      if (!item) return;
      const hasMarkers = layer === "spots" ? activeSpotSlugs.size > 0 : layerMarkers[layer].length > 0;
      item.hidden = !visible || !hasMarkers;
    };

    const setLayerVisibility = (layer, visible) => {
      const button = document.querySelector(`[data-map-layer="${layer}"]`);
      button.setAttribute("aria-pressed", String(visible));
      button.querySelector(".map-layer-check").textContent = visible ? "✓" : "—";
      button.querySelector("small").textContent = visible ? "表示中" : "非表示";
      syncLegendLayer(layer, visible);
      if (layer === "spots") {
        syncSpotMarkerVisibility();
        return;
      }
      layerMarkers[layer].forEach((marker) => {
        setMarkerVisibility(marker, visible);
      });
    };

    document.querySelectorAll("[data-map-layer]").forEach((button) => {
      button.addEventListener("click", () => {
        const layer = button.dataset.mapLayer;
        const visible = button.getAttribute("aria-pressed") !== "true";
        setLayerVisibility(layer, visible);
        button.dataset.routeTarget = `${layer}:${visible ? "visible" : "hidden"}`;
        button.dataset.routeLayer = layer;
        button.dataset.routeVisible = String(visible);
      });
    });

    const applyLayerState = (layers) => {
      Object.entries(layers).forEach(([layer, visible]) => {
        if (!(layer in layerMarkers)) return;
        setLayerVisibility(layer, visible);
        const button = document.querySelector(`[data-map-layer="${layer}"]`);
        button.dataset.routeTarget = `${layer}:${visible ? "visible" : "hidden"}`;
        button.dataset.routeLayer = layer;
        button.dataset.routeVisible = String(visible);
      });
    };

    const fitPoints = (points) => {
      if (!points.length) return;
      const bounds = new maplibregl.LngLatBounds(points[0], points[0]);
      points.slice(1).forEach((point) => bounds.extend(point));
      map.fitBounds(bounds, { padding: 54, maxZoom: 15, duration: 300 });
    };
    const visibleMarkerPoints = () => Object.values(layerMarkers).flat()
      .filter((marker) => !marker.getElement().hidden)
      .map((marker) => marker.getLngLat().toArray());
    const closeAllPopups = () => Object.values(layerMarkers).flat()
      .forEach((marker) => marker.getPopup()?.remove());
    const focusTimelineSpot = (slug) => {
      if (!mapLoaded) {
        pendingSpotSelection = slug;
        return;
      }
      const marker = routeMarkers.get(slug);
      if (!marker || marker.getElement().hidden || !activeSpotSlugs.has(slug)) return;
      map.easeTo({
        center: marker.getLngLat(),
        duration: reducedMotionMedia.matches ? 0 : 180,
      });
      marker.popupSelectionSource = "timeline";
      if (!marker.getPopup().isOpen()) marker.togglePopup();
    };
    const applyMapState = (state) => {
      if (!state) return;
      pendingMapState = state;
      if (summaryElement) {
        summaryElement.textContent = window.routeSituationMapSummary || state.action.summary;
      }
      if (!mapLoaded) return;
      const routeVariant = routeVariants[state.routeVariantId];
      if (!routeVariant) return;
      setRouteSpotSelection(null, "route");
      const routeSource = map.getSource("guide-route");
      const geometry = routeVariant.geometry || { type: "FeatureCollection", features: [] };
      routeSource.setData(geometry);
      currentRouteCoordinates = geometry.features?.[0]?.geometry?.coordinates || [];
      activeSpotSlugs = new Set(routeVariant.visibleSpotSlugs || routeLocations.map((location) => location.slug));
      syncSpotMarkerVisibility();
      if (variantNotice) {
        variantNotice.textContent = routeVariant.note || "";
        variantNotice.hidden = !routeVariant.note;
      }
      applyLayerState(state.layers);
      closeAllPopups();
      const { action } = state;
      if (action.type === "show-spot") {
        setLayerVisibility("spots", true);
        const marker = routeMarkers.get(action.spotSlug);
        if (!marker || marker.getElement().hidden) return;
        map.easeTo({ center: marker.getLngLat(), duration: 300 });
        marker.popupSelectionSource = "route";
        if (!marker.getPopup().isOpen()) marker.togglePopup();
      } else if (action.type === "show-exit") {
        setLayerVisibility("exit", true);
        const marker = exitMarkers.get(action.exitOption);
        if (!marker || marker.getElement().hidden) return;
        map.easeTo({ center: marker.getLngLat(), duration: 300 });
        if (!marker.getPopup().isOpen()) marker.togglePopup();
      } else if (action.type === "fit-facilities") {
        const categories = action.facilityCategories || [];
        categories.forEach((category) => setLayerVisibility(category, true));
        const markers = [...layerMarkers.rest, ...layerMarkers["tourist-information"]]
          .filter((marker) => marker.facility.categories.some((category) => categories.includes(category)));
        fitPoints(markers.map((marker) => marker.getLngLat().toArray()));
      } else if (action.type === "fit-current") {
        fitPoints([...currentRouteCoordinates, ...visibleMarkerPoints()]);
      } else if (action.type === "fit-route") {
        fitPoints([...currentRouteCoordinates, ...visibleMarkerPoints()]);
      }
    };

    window.addEventListener("route:update-summary", (event) => {
      if (summaryElement) summaryElement.textContent = event.detail.summary;
    });
    window.addEventListener("route:apply-map-action", (event) => applyMapState(event.detail));
    window.addEventListener("route:guide-view-change", (event) => {
      if (event.detail.view !== "result") return;
      window.requestAnimationFrame(() => {
        map.resize();
        if (pendingMapState) applyMapState(pendingMapState);
      });
    });
    window.addEventListener("route:spot-select", (event) => {
      routeMarkers.forEach((marker, slug) => {
        marker.getElement().classList.toggle("is-selected", Boolean(event.detail.slug) && slug === event.detail.slug);
      });
      if (event.detail.source === "timeline" && event.detail.slug) focusTimelineSpot(event.detail.slug);
    });
    window.addEventListener("route:show-exit", (event) => {
      const marker = exitMarkers.get(event.detail.exitOption);
      if (!marker || !mapLoaded) return;
      setLayerVisibility("exit", true);
      map.easeTo({ center: marker.getLngLat(), duration: 300 });
      if (!marker.getPopup().isOpen()) marker.togglePopup();
    });
    if (window.routeSituationMapSummary && summaryElement) {
      summaryElement.textContent = window.routeSituationMapSummary;
    }

    map.on("load", () => {
      map.addSource("guide-route", {
        type: "geojson",
        data: savedRouteGeometry,
      });
      map.addLayer({
        id: "guide-route-casing",
        type: "line",
        source: "guide-route",
        layout: { "line-cap": "round", "line-join": "round" },
        paint: {
          "line-color": "rgba(255,255,255,0.96)",
          "line-width": narrowMapMedia.matches ? 9 : 8,
          "line-opacity": 1,
        },
      });
      map.addLayer({
        id: "guide-route-line",
        type: "line",
        source: "guide-route",
        layout: { "line-cap": "round", "line-join": "round" },
        paint: {
          "line-color": "#008c95",
          "line-width": narrowMapMedia.matches ? 5.5 : 5,
          "line-opacity": 1,
        },
      });

      narrowMapMedia.addEventListener("change", (event) => {
        map.setPaintProperty("guide-route-casing", "line-width", event.matches ? 9 : 8);
        map.setPaintProperty("guide-route-line", "line-width", event.matches ? 5.5 : 5);
      });

      mapLoaded = true;
      if (pendingMapState) applyMapState(pendingMapState);
      else fitPoints([...currentRouteCoordinates, ...visibleMarkerPoints()]);
      if (pendingSpotSelection) {
        const slug = pendingSpotSelection;
        pendingSpotSelection = null;
        setRouteSpotSelection(slug, "route");
        focusTimelineSpot(slug);
      }
    });
  }
</script>
