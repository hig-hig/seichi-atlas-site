---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const {
  title = "アニメ聖地巡礼を地図から探す | Seichi Atlas",
  description = "Seichi Atlasは、アニメや漫画の聖地巡礼スポットを作品・地域・地図から探せる非公式ポータルです。",
  canonical = "",
} = Astro.props;

const siteUrl = "https://seichi-atlas-site.vercel.app";
const pageUrl = canonical ? `${siteUrl}${canonical}` : siteUrl;
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="google-site-verification" content="1gzTK7CCqdVLe4eIRKoRZQW_aYKlb6kv5sZTsaL4yak" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;800;900&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0ea5e9" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={pageUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="Seichi Atlas" />

    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Seichi Atlas",
      "alternateName": "アニメ聖地巡礼ポータル",
      "url": siteUrl,
      "description": "アニメ・漫画等の聖地巡礼スポットを作品・地図・地域から探せる非公式ポータル"
    })} />
  </head>

  <body>
    <Header />

    <slot />

    <Footer />

    <style is:global>
      :root {
        --bg: #f6f8fb;
        --bg-soft: #eef4f8;

        --card: #ffffff;
        --card-subtle: #f8fafc;

        --text: #162033;
        --sub: #64748b;
        --muted: #94a3b8;

        --border: #e2e8f0;
        --border-soft: #edf2f7;

        --accent: #0ea5e9;
        --accent-dark: #0369a1;
        --accent-soft: #e0f2fe;

        --visited: #16a34a;
        --visited-dark: #166534;
        --visited-soft: #dcfce7;

        --danger: #be123c;
        --danger-soft: #fff1f2;

        --shadow: 0 14px 34px rgba(15, 23, 42, 0.06);
        --shadow-strong: 0 18px 42px rgba(15, 23, 42, 0.10);

        --radius-card: 24px;
        --radius-large: 28px;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Noto Sans JP", system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
        -webkit-text-size-adjust: 100%;
        text-size-adjust: 100%;
        font-feature-settings: "palt";
        background:
          radial-gradient(circle at top left, rgba(14, 165, 233, 0.08), transparent 34%),
          linear-gradient(180deg, var(--bg) 0%, #ffffff 100%);
        color: var(--text);
        line-height: 1.8;
      }

      button,
      input,
      select,
      textarea {
        font: inherit;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
        height: auto;
      }


      .page {
        max-width: 1120px;
        margin: 0 auto;
        padding: 56px 20px 80px;
      }

      .legal-page {
        max-width: 880px;
        margin: 0 auto;
        padding: 56px 20px 80px;
      }

      .legal-header {
        margin-bottom: 40px;
        padding: 32px;
        background: var(--card);
        border-radius: 24px;
        box-shadow: var(--shadow);
      }

      .kicker {
        margin: 0 0 8px;
        color: var(--accent-dark);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0 0 12px;
        font-size: clamp(32px, 5vw, 52px);
        line-height: 1.25;
        letter-spacing: -0.03em;
      }

      h2 {
        margin-top: 40px;
        padding-bottom: 8px;
        border-bottom: 1px solid var(--border);
        font-size: 22px;
      }

      h3 {
        line-height: 1.45;
      }

      .legal-page section {
        background: var(--card);
        border-radius: 20px;
        padding: 24px;
        margin-top: 20px;
        box-shadow: 0 8px 24px rgba(120, 90, 60, 0.06);
      }

      p,
      li {
        font-size: 15px;
      }

      .legal-page a {
        color: #9f6f63;
        font-weight: 700;
        text-decoration: underline;
        text-underline-offset: 3px;
      }

      .date {
        color: var(--sub);
        font-size: 14px;
      }

      .button-primary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 13px 20px;
        border-radius: 999px;
        background: var(--text);
        color: #ffffff;
        font-weight: 800;
        box-shadow: 0 12px 24px rgba(63, 53, 45, 0.18);
      }

      .button-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 13px 20px;
        border-radius: 999px;
        background: #ffffff;
        color: var(--text);
        font-weight: 800;
        border: 1px solid var(--border);
      }


      /* ============================
        App-like Header
      ============================ */

      .site-header {
        position: sticky;
        top: 0;
        z-index: 20;
        background: rgba(246, 248, 251, 0.9);
        backdrop-filter: blur(16px);
        border-bottom: 1px solid rgba(226, 232, 240, 0.88);
      }

      .site-header-inner {
        width: calc(100% - 32px);
        max-width: 1680px;
        margin: 0 auto;
        padding: 14px 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
      }

      .site-logo {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-weight: 900;
        color: var(--text);
      }

      .site-logo-mark {
        width: 36px;
        height: 36px;
        border-radius: 13px;
        display: grid;
        place-items: center;
        background: var(--accent);
        color: #ffffff;
        font-weight: 950;
        box-shadow: 0 10px 22px rgba(14, 165, 233, 0.22);
      }

      .site-logo-text {
        letter-spacing: 0.01em;
      }

      .site-nav {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px;
        border-radius: 999px;
        background: #ffffff;
        border: 1px solid var(--border-soft);
        box-shadow: var(--shadow);
      }

      .site-nav a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 38px;
        padding: 8px 14px;
        border-radius: 999px;
        color: var(--sub);
        font-size: 13px;
        font-weight: 900;
        transition:
          background 0.18s ease,
          color 0.18s ease,
          transform 0.18s ease,
          box-shadow 0.18s ease;
      }

      .site-nav a:hover {
        background: var(--card-subtle);
        color: var(--text);
        transform: translateY(-1px);
      }

      .site-nav a.active {
        background: var(--accent);
        color: #ffffff;
        box-shadow: 0 10px 22px rgba(14, 165, 233, 0.22);
      }

      /* ============================
        App-like Footer
      ============================ */

      .site-footer {
        margin-top: 80px;
        padding: 48px 20px 32px;
        background: #ffffff;
        border-top: 1px solid var(--border-soft);
      }

      .site-footer-inner {
        max-width: 1180px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: minmax(260px, 0.9fr) minmax(0, 1.6fr);
        gap: 42px;
        align-items: start;
      }

      .footer-logo {
        color: var(--text);
        font-size: 22px;
        font-weight: 950;
        letter-spacing: -0.03em;
      }

      .footer-brand p,
      .site-footer-note {
        color: var(--sub);
        font-size: 13px;
        line-height: 1.8;
      }

      .footer-small {
        margin-top: 12px;
      }

      .footer-links {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 24px;
      }

      .footer-link-group {
        display: grid;
        gap: 8px;
      }

      .footer-link-title {
        margin-bottom: 4px;
        color: var(--muted);
        font-size: 12px;
        font-weight: 950;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .footer-links a {
        color: var(--sub);
        font-size: 13px;
        font-weight: 800;
        line-height: 1.6;
      }

      .footer-links a:hover {
        color: var(--accent-dark);
      }

      .site-footer-note {
        max-width: 1180px;
        margin: 32px auto 0;
        padding-top: 18px;
        border-top: 1px solid var(--border-soft);
      }

      /* ============================
        Responsive Header / Footer
      ============================ */

      @media (max-width: 820px) {
        .site-header-inner {
          display: grid;
          gap: 12px;
        }

        .site-logo {
          justify-content: center;
        }

        .site-nav {
          width: 100%;
          display: grid;
          grid-template-columns: repeat(4, 1fr);
          border-radius: 22px;
        }

        .site-nav a {
          min-height: 40px;
          padding: 8px 6px;
          font-size: 12px;
          white-space: nowrap;
        }

        .site-footer-inner {
          grid-template-columns: 1fr;
          gap: 28px;
        }

        .footer-links {
          grid-template-columns: 1fr;
          gap: 22px;
        }
      }

      @media (max-width: 480px) {
        .site-header-inner {
          width: calc(100% - 24px);
          padding: 12px 0;
        }
        @media (max-width: 820px) {
          .site-header-inner {
            width: calc(100% - 24px);
          }
        }

        .site-logo-text {
          font-size: 16px;
        }

        .site-nav {
          gap: 6px;
          padding: 6px;
        }

        .site-nav a {
          font-size: 11px;
        }
      }
    </style>
  </body>
</html>
