---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "記録アプリ準備中 | Seichi Atlas";
const description = "Seichi Atlasの記録アプリ機能は現在準備中です。現在は作品・スポット・マップから探す公開版ポータルをご利用ください。";
---

<BaseLayout title={title} description={description} canonical="/app/">
  <main class="app-coming-soon-page">

    <section class="coming-soon-card reveal-item">
      <div class="status-badge">準備中</div>

      <h1>記録アプリは現在準備中です</h1>

      <p>
        訪問記録やユーザー別保存機能は、まだ正式公開していません。
        現在は、作品・スポット・マップから聖地巡礼スポットを探す公開版ポータルをご利用ください。
      </p>

      <div class="action-row">
        <a class="button-primary" href="/map/">
          マップから探す
        </a>

        <a class="button-secondary" href="/">
          HOMEへ戻る
        </a>
      </div>
    </section>

  </main>

  <style>
    .app-coming-soon-page {
      width: calc(100% - 32px);
      max-width: 880px;
      min-height: 62vh;
      margin: 0 auto;
      padding: 72px 0 88px;
      display: grid;
      place-items: center;
    }

    .coming-soon-card {
      width: 100%;
      padding: 42px;
      border-radius: var(--radius-large);
      background: linear-gradient(135deg, #ffffff 0%, var(--card-subtle) 100%);
      border: 1px solid var(--border-soft);
      box-shadow: var(--shadow);
      text-align: center;
    }

    .status-badge {
      width: fit-content;
      margin: 0 auto 18px;
      padding: 8px 14px;
      border-radius: 999px;
      background: var(--accent-soft);
      color: var(--accent-dark);
      font-size: 13px;
      font-weight: 950;
      letter-spacing: 0.08em;
    }

    .coming-soon-card h1 {
      margin: 0 0 14px;
      color: var(--text);
      font-size: clamp(32px, 5vw, 48px);
      line-height: 1.16;
      letter-spacing: -0.05em;
    }

    .coming-soon-card p {
      max-width: 640px;
      margin: 0 auto;
      color: var(--sub);
      font-size: 15px;
      font-weight: 750;
      line-height: 1.9;
    }

    .action-row {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 28px;
    }

    .reveal-item {
      opacity: 0;
      animation: contentFadeUp 0.42s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes contentFadeUp {
      from {
        opacity: 0;
        transform: translateY(14px) scale(0.99);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @media (max-width: 760px) {
      .app-coming-soon-page {
        width: calc(100% - 24px);
        padding: 48px 0 64px;
      }

      .coming-soon-card {
        padding: 28px 20px;
      }

      .action-row {
        display: grid;
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>