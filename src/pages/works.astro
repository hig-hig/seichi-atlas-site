---
import BaseLayout from "../layouts/BaseLayout.astro";
import { works, spots } from "../data/portalData.js";

const title = "作品から探す | Seichi Atlas";
const description = "Seichi Atlasの作品一覧ページです。アニメや漫画の作品ごとに、関連する聖地巡礼スポットを探せます。";

function normalizeTags(tags) {
  if (Array.isArray(tags)) {
    return tags;
  }

  if (typeof tags === "string") {
    return tags
      .split(",")
      .map((tag) => tag.trim())
      .filter(Boolean);
  }

  return [];
}

const normalizedWorks = works.map((work) => {
  const workSpots = spots.filter((spot) => spot.workSlug === work.slug);

  const prefectures = [
    ...new Set(
      workSpots
        .map((spot) => spot.prefecture)
        .filter(Boolean)
    ),
  ];

  const tags = [
    ...new Set(
      [
        ...normalizeTags(work.tags),
        ...workSpots.flatMap((spot) => normalizeTags(spot.tags)),
      ].filter(Boolean)
    ),
  ];

  return {
    ...work,
    spotCount: workSpots.length,
    prefectures,
    tags,
    descriptionText: work.summary || work.description || "",
  };
});

const prefectures = [
  ...new Set(
    normalizedWorks
      .flatMap((work) => work.prefectures)
      .filter(Boolean)
  ),
];

const tagOptions = [
  ...new Set(
    normalizedWorks
      .flatMap((work) => work.tags)
      .filter(Boolean)
  ),
];

const totalWorks = normalizedWorks.length;
const totalSpots = spots.length;
---

<BaseLayout title={title} description={description} canonical="/works/">
  <main class="works-page">

    <section class="works-hero reveal-item">
      <div>
        <div class="section-kicker">WORKS</div>

        <h1>作品から探す</h1>

        <p>
          アニメ・漫画等の作品ごとに、関連する聖地巡礼スポットを探せます。
          作品詳細ページでは、登録スポットや関連エリアを確認できます。
        </p>
      </div>

      <div class="works-hero-stats">
        <div class="stat-card">
          <span>作品</span>
          <strong class="count-up" data-count={totalWorks}>0</strong>
        </div>

        <div class="stat-card">
          <span>関連スポット</span>
          <strong class="count-up" data-count={totalSpots}>0</strong>
        </div>
      </div>
    </section>

    <section class="works-filter-card reveal-item">
      <div class="filter-head">
        <div>
          <div class="section-kicker">FILTER</div>
          <h2>条件で絞り込む</h2>
        </div>

        <button class="filter-reset-button" type="button" id="filter-reset">
          条件をリセット
        </button>
      </div>

      <div class="filter-grid">
        <label class="filter-field search-field">
          <span>キーワード</span>
          <input
            id="work-search"
            class="filter-input"
            type="search"
            placeholder="作品名・年・地域・タグで検索"
            autocomplete="off"
          />
        </label>

        <label class="filter-field">
          <span>地域</span>
          <select id="prefecture-filter" class="filter-select">
            <option value="all">すべて</option>
            {prefectures.map((prefecture) => (
              <option value={prefecture}>{prefecture}</option>
            ))}
          </select>
        </label>

        <label class="filter-field">
          <span>スポット数</span>
          <select id="spot-count-filter" class="filter-select">
            <option value="all">すべて</option>
            <option value="has-spots">登録あり</option>
            <option value="no-spots">未登録</option>
          </select>
        </label>
      </div>

      {tagOptions.length > 0 && (
        <div class="tag-filter-section">
          <div class="tag-filter-head">
            <span>タグ</span>
            <small>作品・スポットに登録されたタグで絞り込みます</small>
          </div>

          <div class="tag-filter-list">
            <button class="tag-filter-chip active" type="button" data-tag="all">
              #すべて
            </button>

            {tagOptions.map((tag) => (
              <button class="tag-filter-chip" type="button" data-tag={tag}>
                #{tag}
              </button>
            ))}
          </div>
        </div>
      )}
    </section>

    <section class="works-main reveal-item">
      <div class="section-header">
        <div>
          <div class="section-kicker">LIST</div>
          <h2>作品一覧</h2>
          <p id="result-count">{normalizedWorks.length}件の作品を表示中</p>
        </div>

        <a class="section-link" href="/map/">地図から探す</a>
      </div>

      <div id="filter-summary" class="filter-summary muted">
        すべての作品を表示中
      </div>

      <div class="works-grid" id="works-grid">
        {normalizedWorks.map((work, index) => (
          <a
            class="work-card"
            href={work.slug ? `/works/${work.slug}/` : "/works/"}
            style={`--card-delay:${index * 42}ms;`}
            data-title={work.title}
            data-year={work.year}
            data-prefectures={work.prefectures.join(",")}
            data-tags={work.tags.join(",")}
            data-count={work.spotCount}
            data-description={work.descriptionText}
          >
            <div class="work-card-top">
              <div>
                <h3>{work.title}</h3>

                <div class="work-meta">
                  {work.year && <span>{work.year}</span>}
                  <span>{work.spotCount}スポット</span>
                  {work.prefectures.slice(0, 3).map((prefecture) => (
                    <span>{prefecture}</span>
                  ))}
                </div>
              </div>

              <div class={`status-pill ${work.spotCount > 0 ? "active" : "empty"}`}>
                {work.spotCount > 0 ? "公開中" : "未登録"}
              </div>
            </div>

            {work.descriptionText && (
              <p class="work-description">
                {work.descriptionText}
              </p>
            )}

            <div class="work-card-bottom">
              <div class="progress-head">
                <span>登録スポット</span>
                <strong>{work.spotCount}件</strong>
              </div>

              <div class="progress-bar">
                <div
                  class="progress-fill"
                  style={`width:${Math.min(100, work.spotCount * 12)}%;`}
                >
                </div>
              </div>

              <div class="work-card-foot">
                <span>
                  {work.prefectures.length > 0 ? work.prefectures.join(" / ") : "エリア未登録"}
                </span>

                <span class="card-link">
                  作品詳細へ
                  <span class="arrow">→</span>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="empty-result-card" id="empty-result" hidden>
        <div class="empty-icon">🎬</div>
        <h3>表示できる作品がありません</h3>
        <p>検索条件を変更するか、条件をリセットしてください。</p>
      </div>
    </section>

  </main>

  <style>
    .works-page {
      width: calc(100% - 32px);
      max-width: 1180px;
      margin: 0 auto;
      padding: 44px 0 72px;
    }

    .section-kicker {
      color: var(--accent-dark);
      font-size: 12px;
      font-weight: 950;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .works-hero {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
      gap: 24px;
      align-items: stretch;
      margin-bottom: 22px;
      padding: 30px;
      border-radius: var(--radius-large);
      background: linear-gradient(135deg, #ffffff 0%, var(--card-subtle) 100%);
      border: 1px solid var(--border-soft);
      box-shadow: var(--shadow);
    }

    .works-hero h1 {
      margin: 8px 0 12px;
      color: var(--text);
      font-size: clamp(34px, 5vw, 54px);
      line-height: 1.12;
      letter-spacing: -0.05em;
    }

    .works-hero p {
      max-width: 720px;
      margin: 0;
      color: var(--sub);
      font-size: 15px;
      font-weight: 750;
      line-height: 1.8;
    }

    .works-hero-stats {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .stat-card {
      padding: 20px;
      border-radius: 22px;
      background: #ffffff;
      border: 1px solid var(--border-soft);
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.04);
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

    .stat-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-strong);
    }

    .stat-card span {
      display: block;
      margin-bottom: 8px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 900;
    }

    .stat-card strong {
      display: block;
      color: var(--text);
      font-size: 36px;
      font-weight: 950;
      line-height: 1;
      letter-spacing: -0.04em;
    }

    .works-filter-card,
    .works-main {
      border-radius: var(--radius-card);
      background: #ffffff;
      border: 1px solid var(--border-soft);
      box-shadow: var(--shadow);
    }

    .works-filter-card {
      margin-bottom: 18px;
      padding: 22px;
    }

    .filter-head,
    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
      margin-bottom: 18px;
    }

    .filter-head h2,
    .section-header h2 {
      margin: 4px 0 0;
      padding: 0;
      border: none;
      color: var(--text);
      font-size: 24px;
      letter-spacing: -0.03em;
    }

    .section-header p {
      margin: 6px 0 0;
      color: var(--sub);
      font-size: 13px;
      font-weight: 750;
    }

    .filter-reset-button,
    .section-link {
      min-height: 40px;
      border-radius: 999px;
      padding: 8px 14px;
      font-size: 13px;
      font-weight: 900;
      cursor: pointer;
      transition: transform 0.18s ease, background 0.18s ease, color 0.18s ease;
    }

    .filter-reset-button {
      border: 1px solid var(--border);
      background: #ffffff;
      color: var(--sub);
    }

    .section-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: var(--accent-soft);
      color: var(--accent-dark);
    }

    .filter-reset-button:hover,
    .section-link:hover {
      transform: translateY(-1px);
      background: var(--card-subtle);
      color: var(--text);
    }

    .filter-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.5fr) repeat(2, minmax(180px, 0.75fr));
      gap: 12px;
      align-items: end;
    }

    .filter-field {
      display: grid;
      gap: 7px;
    }

    .filter-field span {
      color: var(--muted);
      font-size: 12px;
      font-weight: 950;
      letter-spacing: 0.04em;
    }

    .filter-input,
    .filter-select {
      width: 100%;
      min-height: 42px;
      padding: 10px 12px;
      border-radius: 14px;
      border: 1px solid var(--border);
      background: #ffffff;
      color: var(--text);
      font-size: 14px;
      font-weight: 750;
      outline: none;
      transition: border-color 0.18s ease, box-shadow 0.18s ease;
    }

    .filter-input:focus,
    .filter-select:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.14);
    }

    .tag-filter-section {
      margin-top: 18px;
      padding-top: 16px;
      border-top: 1px solid var(--border-soft);
    }

    .tag-filter-head {
      display: flex;
      align-items: baseline;
      gap: 10px;
      margin-bottom: 10px;
    }

    .tag-filter-head span {
      color: var(--muted);
      font-size: 12px;
      font-weight: 950;
    }

    .tag-filter-head small {
      color: var(--muted);
      font-size: 12px;
      font-weight: 750;
    }

    .tag-filter-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .tag-filter-chip {
      border: none;
      border-radius: 999px;
      padding: 8px 12px;
      background: var(--card-subtle);
      color: var(--sub);
      font-size: 13px;
      font-weight: 850;
      cursor: pointer;
      transition: transform 0.18s ease, background 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;
    }

    .tag-filter-chip:hover {
      transform: translateY(-1px);
      background: #e8eef6;
      color: var(--text);
    }

    .tag-filter-chip.active {
      background: var(--accent);
      color: #ffffff;
      box-shadow: 0 10px 22px rgba(14, 165, 233, 0.22);
      animation: chipPop 0.24s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .works-main {
      padding: 22px;
    }

    .filter-summary {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 8px;
      margin: 0 0 14px;
      padding: 12px 14px;
      border-radius: 18px;
      background: var(--card-subtle);
      border: 1px solid var(--border-soft);
      color: var(--sub);
      font-size: 13px;
      font-weight: 850;
    }

    .filter-summary.muted {
      color: var(--muted);
    }

    .summary-label {
      color: var(--accent-dark);
      font-weight: 950;
    }

    .summary-pill {
      display: inline-flex;
      padding: 5px 9px;
      border-radius: 999px;
      background: #ffffff;
      border: 1px solid var(--border-soft);
      color: var(--sub);
      font-size: 12px;
      font-weight: 850;
    }

    .works-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(255px, 1fr));
      gap: 16px;
    }

    .works-grid.filter-refreshing .work-card:not([hidden]) {
      animation: filterResultFadeIn 0.28s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .work-card {
      min-height: 292px;
      display: flex;
      flex-direction: column;
      padding: 22px;
      border-radius: var(--radius-card);
      background: #ffffff;
      border: 1px solid var(--border-soft);
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.05);
      opacity: 0;
      animation: cardIn 0.42s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      animation-delay: var(--card-delay);
      transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }

    .work-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-strong);
      border-color: var(--accent-soft);
    }

    .work-card:active {
      transform: translateY(-1px) scale(0.985);
    }

    .work-card-top {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 14px;
      align-items: start;
    }

    .work-card h3 {
      min-height: 56px;
      margin: 0;
      color: var(--text);
      font-size: 20px;
      font-weight: 950;
      line-height: 1.35;
      letter-spacing: -0.02em;
      word-break: keep-all;
      overflow-wrap: anywhere;
    }

    .work-meta {
      min-height: 76px;
      display: flex;
      flex-wrap: wrap;
      align-content: flex-start;
      gap: 8px;
      margin-top: 10px;
    }

    .work-meta span {
      display: inline-flex;
      padding: 6px 10px;
      border-radius: 999px;
      background: var(--card-subtle);
      color: var(--sub);
      font-size: 13px;
      font-weight: 750;
    }

    .status-pill {
      flex-shrink: 0;
      white-space: nowrap;
      padding: 7px 11px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 950;
      letter-spacing: 0.03em;
    }

    .status-pill.active {
      background: var(--accent-soft);
      color: var(--accent-dark);
    }

    .status-pill.empty {
      background: #eef2f7;
      color: var(--sub);
    }

    .work-description {
      display: -webkit-box;
      margin: 4px 0 16px;
      color: var(--sub);
      font-size: 13px;
      font-weight: 750;
      line-height: 1.7;
      overflow: hidden;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
    }

    .work-card-bottom {
      margin-top: auto;
    }

    .progress-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      margin-bottom: 8px;
      color: var(--sub);
      font-size: 13px;
      font-weight: 850;
    }

    .progress-head strong {
      color: var(--accent-dark);
      font-size: 15px;
      font-weight: 950;
    }

    .progress-bar {
      width: 100%;
      height: 10px;
      border-radius: 999px;
      background: #e8edf3;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--accent), #38bdf8);
      transition: width 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .work-card-foot {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      margin-top: 10px;
      color: var(--sub);
      font-size: 13px;
      font-weight: 800;
    }

    .card-link {
      color: var(--accent);
      font-weight: 950;
      white-space: nowrap;
    }

    .arrow {
      display: inline-flex;
      transition: transform 0.18s ease;
    }

    .work-card:hover .arrow {
      transform: translateX(4px);
    }

    .empty-result-card {
      margin-top: 18px;
      padding: 42px 28px;
      border-radius: var(--radius-large);
      background: #ffffff;
      border: 1px solid var(--border-soft);
      box-shadow: var(--shadow);
      text-align: center;
      animation: emptyStateIn 0.28s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .empty-icon {
      margin-bottom: 12px;
      font-size: 34px;
      animation: emptyIconFloat 1.8s ease-in-out infinite;
    }

    .empty-result-card h3 {
      margin: 0 0 8px;
      color: var(--text);
      font-size: 22px;
    }

    .empty-result-card p {
      margin: 0;
      color: var(--sub);
      font-size: 14px;
      font-weight: 750;
    }

    .reveal-item {
      opacity: 0;
      animation: contentFadeUp 0.42s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes contentFadeUp {
      from {
        opacity: 0;
        transform: translateY(14px) scale(0.99);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @keyframes cardIn {
      from {
        opacity: 0;
        transform: translateY(14px) scale(0.985);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @keyframes filterResultFadeIn {
      from {
        opacity: 0.42;
        transform: translateY(8px) scale(0.99);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @keyframes chipPop {
      from {
        transform: scale(0.94);
      }

      65% {
        transform: scale(1.05);
      }

      to {
        transform: scale(1);
      }
    }

    @keyframes emptyStateIn {
      from {
        opacity: 0;
        transform: translateY(10px) scale(0.98);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @keyframes emptyIconFloat {
      0% {
        transform: translateY(0) rotate(0deg);
      }

      35% {
        transform: translateY(-3px) rotate(-2deg);
      }

      70% {
        transform: translateY(1px) rotate(2deg);
      }

      100% {
        transform: translateY(0) rotate(0deg);
      }
    }

    @media (max-width: 900px) {
      .works-hero {
        grid-template-columns: 1fr;
      }

      .works-hero-stats {
        grid-template-columns: repeat(2, 1fr);
      }

      .filter-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 760px) {
      .works-page {
        width: calc(100% - 24px);
        padding: 26px 0 52px;
      }

      .works-hero {
        padding: 22px;
        border-radius: 24px;
      }

      .works-hero h1 {
        font-size: 34px;
      }

      .filter-head,
      .section-header {
        display: block;
      }

      .filter-reset-button,
      .section-link {
        width: 100%;
        margin-top: 12px;
      }

      .tag-filter-list {
        flex-wrap: nowrap;
        overflow-x: auto;
        padding-bottom: 4px;
        -webkit-overflow-scrolling: touch;
      }

      .tag-filter-chip {
        flex: 0 0 auto;
      }

      .works-main {
        padding: 18px;
      }

      .works-grid {
        grid-template-columns: 1fr;
      }

      .work-card {
        min-height: auto;
      }

      .work-card-top {
        display: block;
      }

      .work-card h3 {
        min-height: auto;
        font-size: 19px;
      }

      .work-meta {
        min-height: auto;
      }

      .status-pill {
        display: inline-flex;
        margin-top: 14px;
      }

      .work-card-foot {
        display: block;
      }

      .card-link {
        display: inline-flex;
        margin-top: 8px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      *,
      *::before,
      *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
        scroll-behavior: auto !important;
      }
    }
  </style>

  <script>
    const searchInput = document.getElementById("work-search");
    const prefectureFilter = document.getElementById("prefecture-filter");
    const countFilter = document.getElementById("spot-count-filter");
    const resetButton = document.getElementById("filter-reset");
    const tagButtons = Array.from(document.querySelectorAll("[data-tag]"));
    const cards = Array.from(document.querySelectorAll(".work-card"));
    const resultCount = document.getElementById("result-count");
    const summary = document.getElementById("filter-summary");
    const emptyResult = document.getElementById("empty-result");
    const grid = document.getElementById("works-grid");

    let activeTag = "all";

    function normalizeText(value) {
      return String(value || "").toLowerCase();
    }

    function animateCountUp(element, target, duration) {
      const endValue = Number(target || 0);
      const startTime = performance.now();

      function update(now) {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const value = Math.round(endValue * eased);

        element.textContent = String(value);

        if (progress < 1) {
          requestAnimationFrame(update);
        } else {
          element.textContent = String(endValue);
        }
      }

      requestAnimationFrame(update);
    }

    function triggerFilterMotion() {
      if (!grid) {
        return;
      }

      grid.classList.remove("filter-refreshing");

      void grid.offsetWidth;

      grid.classList.add("filter-refreshing");

      setTimeout(() => {
        grid.classList.remove("filter-refreshing");
      }, 300);
    }

    function renderSummary(count) {
      if (!summary) {
        return;
      }

      const labels = [];
      const keyword = searchInput ? searchInput.value.trim() : "";
      const prefecture = prefectureFilter?.value || "all";
      const countValue = countFilter?.value || "all";

      if (keyword) {
        labels.push("検索: " + keyword);
      }

      if (prefecture !== "all") {
        labels.push(prefecture);
      }

      if (countValue === "has-spots") {
        labels.push("登録あり");
      }

      if (countValue === "no-spots") {
        labels.push("未登録");
      }

      if (activeTag !== "all") {
        labels.push("#" + activeTag);
      }

      if (!labels.length) {
        summary.className = "filter-summary muted";
        summary.textContent = "すべての作品を表示中";
        return;
      }

      summary.className = "filter-summary";
      summary.innerHTML =
        '<span class="summary-label">絞り込み中</span>' +
        labels.map((label) => '<span class="summary-pill">' + label + '</span>').join("") +
        '<span class="summary-pill">' + count + '件表示</span>';
    }

    function applyFilters() {
      const keyword = normalizeText(searchInput?.value);
      const prefecture = prefectureFilter?.value || "all";
      const countValue = countFilter?.value || "all";

      let visibleCount = 0;

      cards.forEach((card) => {
        const title = normalizeText(card.dataset.title);
        const year = normalizeText(card.dataset.year);
        const prefectures = String(card.dataset.prefectures || "");
        const tags = String(card.dataset.tags || "");
        const description = normalizeText(card.dataset.description);
        const spotCount = Number(card.dataset.count || 0);

        const keywordTarget = normalizeText([
          title,
          year,
          prefectures,
          tags,
          description,
        ].join(" "));

        const keywordMatch = !keyword || keywordTarget.includes(keyword);
        const prefectureMatch = prefecture === "all" || prefectures.split(",").includes(prefecture);
        const tagMatch = activeTag === "all" || tags.split(",").includes(activeTag);

        let countMatch = true;

        if (countValue === "has-spots") {
          countMatch = spotCount > 0;
        }

        if (countValue === "no-spots") {
          countMatch = spotCount === 0;
        }

        const isVisible = keywordMatch && prefectureMatch && tagMatch && countMatch;

        card.hidden = !isVisible;

        if (isVisible) {
          visibleCount += 1;
        }
      });

      if (resultCount) {
        resultCount.textContent = visibleCount + "件の作品を表示中";
      }

      if (emptyResult) {
        emptyResult.hidden = visibleCount !== 0;
      }

      renderSummary(visibleCount);
      triggerFilterMotion();
    }

    function resetFilters() {
      if (searchInput) {
        searchInput.value = "";
      }

      if (prefectureFilter) {
        prefectureFilter.value = "all";
      }

      if (countFilter) {
        countFilter.value = "all";
      }

      activeTag = "all";

      tagButtons.forEach((button) => {
        if (button.dataset.tag === "all") {
          button.classList.add("active");
        } else {
          button.classList.remove("active");
        }
      });

      applyFilters();
    }

    document.querySelectorAll(".count-up").forEach((element) => {
      animateCountUp(element, Number(element.dataset.count || 0), 720);
    });

    searchInput?.addEventListener("input", applyFilters);
    prefectureFilter?.addEventListener("change", applyFilters);
    countFilter?.addEventListener("change", applyFilters);
    resetButton?.addEventListener("click", resetFilters);

    tagButtons.forEach((button) => {
      button.addEventListener("click", () => {
        activeTag = button.dataset.tag || "all";

        tagButtons.forEach((item) => {
          if (item.dataset.tag === activeTag) {
            item.classList.add("active");
          } else {
            item.classList.remove("active");
          }
        });

        applyFilters();
      });
    });
  </script>
</BaseLayout>