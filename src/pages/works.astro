---
import BaseLayout from "../layouts/BaseLayout.astro";
import { works } from "../data/portalData.js";

const title = "作品から探す | Seichi Atlas";
const description = "Seichi Atlasの作品一覧ページです。アニメや漫画の作品ごとに、関連する聖地巡礼スポットを探せます。";
---

<BaseLayout title={title} description={description} canonical="/works">
  <main class="page">
    <section class="content-hero">
      <p class="kicker">Works</p>

      <h1>作品から聖地を探す</h1>

      <p class="lead">
        好きな作品を起点に、関連する聖地巡礼スポットを探せます。
        作品ごとの登録スポット数、主な地域、タグを確認しながら巡礼先を見つけましょう。
      </p>
    </section>

    <section class="works-intro">
      <div>
        <h2>作品別に巡礼スポットを整理</h2>
        <p>
          Seichi Atlasでは、作品ごとに聖地スポットを整理できます。
          作品ページでは、主な地域、登録スポット、巡礼時の注意などを確認できます。
        </p>
      </div>

      <a class="button-primary" href="/app">記録アプリを開く</a>
    </section>

    <section class="section">
      <p class="kicker">List</p>
      <h2>作品一覧</h2>

      <div class="works-grid">
        {works.map((work) => (
          <article class="work-card">
            <div class="work-card-head">
              <div>
                <h3>{work.title}</h3>
                <p class="work-meta">
                  {work.year} / {work.area}
                </p>
              </div>

              <div class="spot-count">
                <span>{work.spots}</span>
                <small>spots</small>
              </div>
            </div>

            <p class="work-description">
              {work.description}
            </p>

            <div class="tag-list">
              {work.tags.map((tag) => (
                <span>{tag}</span>
              ))}
            </div>

            <div class="work-actions">
              <a class="text-link" href={`/works/${work.slug}`}>
                作品ページを見る
              </a>
              <a class="text-link muted" href="/app">
                アプリで記録する
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="notice-section">
      <div>
        <p class="kicker">Data</p>
        <h2>公開ポータル用データを読み込んでいます</h2>
        <p>
          この作品一覧は、共通データファイルから表示しています。
          今後はSpreadsheetのAnime・Locationデータから公開用データを生成し、
          作品ページを自動で増やしていく予定です。
        </p>
      </div>

      <a class="button-secondary" href="/areas">地域から探す</a>
    </section>
  </main>

  <style>
    .content-hero {
      max-width: 840px;
      padding: 40px 0 16px;
    }

    .lead {
      color: var(--sub);
      font-size: 17px;
      max-width: 760px;
    }

    .works-intro {
      margin-top: 36px;
      padding: 32px;
      border-radius: 28px;
      background: #ffffff;
      box-shadow: var(--shadow);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 28px;
    }

    .works-intro h2 {
      border: none;
      margin-top: 0;
      padding-bottom: 0;
    }

    .works-intro p {
      color: var(--sub);
      max-width: 680px;
    }

    .section {
      margin-top: 72px;
    }

    .section > h2,
    .notice-section h2 {
      border: none;
      margin-top: 0;
      padding-bottom: 0;
      font-size: clamp(28px, 4vw, 40px);
    }

    .works-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
      margin-top: 28px;
    }

    .work-card {
      background: #ffffff;
      border-radius: 24px;
      padding: 24px;
      box-shadow: 0 8px 24px rgba(120, 90, 60, 0.06);
      display: flex;
      flex-direction: column;
      gap: 18px;
    }

    .work-card-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
    }

    .work-card h3 {
      margin: 0;
      font-size: 22px;
    }

    .work-meta {
      margin: 4px 0 0;
      color: var(--sub);
      font-size: 13px;
    }

    .spot-count {
      min-width: 64px;
      padding: 10px;
      border-radius: 18px;
      background: #f7f3ee;
      text-align: center;
    }

    .spot-count span {
      display: block;
      font-weight: 900;
      font-size: 24px;
      line-height: 1.1;
    }

    .spot-count small {
      color: var(--sub);
      font-size: 11px;
    }

    .work-description {
      color: var(--sub);
      margin: 0;
    }

    .tag-list {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: auto;
    }

    .tag-list span {
      padding: 6px 10px;
      border-radius: 999px;
      background: #f7f3ee;
      color: var(--sub);
      font-size: 12px;
      font-weight: 700;
    }

    .work-actions {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      padding-top: 4px;
    }

    .text-link {
      color: var(--accent-dark);
      font-weight: 800;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .text-link.muted {
      color: var(--sub);
    }

    .notice-section {
      margin-top: 72px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 28px;
      padding: 32px;
      border-radius: 28px;
      background: #fffaf7;
      border: 1px solid var(--accent);
    }

    .notice-section p {
      color: var(--sub);
    }

    @media (max-width: 900px) {
      .works-grid {
        grid-template-columns: 1fr;
      }

      .works-intro,
      .notice-section {
        align-items: flex-start;
        flex-direction: column;
      }
    }
  </style>
</BaseLayout>
