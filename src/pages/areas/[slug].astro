---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { areas, spots, works } from "../../data/portalData.js";

export function getStaticPaths() {
  return areas
    .filter((area) => area.slug)
    .map((area) => ({
      params: {
        slug: area.slug,
      },
      props: {
        area,
      },
    }));
}

const { area } = Astro.props;

function normalizeTags(tags) {
  if (Array.isArray(tags)) return tags;

  if (typeof tags === "string") {
    return tags
      .split(",")
      .map((tag) => tag.trim())
      .filter(Boolean);
  }

  return [];
}

function getAreaName(areaItem) {
  return areaItem.name || areaItem.prefecture || areaItem.title || "地域未登録";
}

function normalizeOfficialLevel(level) {
  if (level === "official") return "official";
  if (level === "tourism") return "tourism";
  return "fan";
}

function officialLabel(level) {
  if (level === "official") return "公式";
  if (level === "tourism") return "観光協会・自治体";
  return "ファン考察";
}

const areaName = getAreaName(area);

const areaSpots = spots
  .filter((spot) => spot.areaSlug === area.slug || spot.prefecture === areaName)
  .map((spot, index) => {
    const work = works.find((item) => item.slug === spot.workSlug);
    const officialLevel = normalizeOfficialLevel(spot.officialLevel);

    return {
      ...spot,
      id: spot.id || index + 1,
      name: spot.name || "名称未登録",
      slug: spot.slug || "",
      work: spot.work || spot.workTitle || work?.title || "",
      workSlug: spot.workSlug || work?.slug || "",
      prefecture: spot.prefecture || areaName,
      station: spot.station || "",
      officialLevel,
      officialLabel: officialLabel(officialLevel),
      descriptionText: spot.description || "",
      tags: normalizeTags(spot.tags),
    };
  });

const featuredSpots = areaSpots.slice(0, 6);

const relatedWorks = [
  ...new Map(
    areaSpots
      .map((spot) => {
        const work = works.find((item) => item.slug === spot.workSlug);
        const title = spot.work || spot.workTitle || work?.title || "";
        const slug = spot.workSlug || work?.slug || "";

        if (!title) return null;

        return [slug || title, { title, slug }];
      })
      .filter(Boolean)
  ).values(),
];

const areaTags = [
  ...new Set(
    areaSpots
      .flatMap((spot) => spot.tags)
      .filter(Boolean)
  ),
];

const title = `${areaName}のアニメ聖地巡礼スポット | Seichi Atlas`;
const description =
  `${areaName}に関連するアニメ・漫画等の聖地巡礼スポット、関連作品、巡礼エリアをまとめた地域ページです。`;


  const canonicalPath = `/areas/${area.slug}/`;

const areaJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: title,
  description,
  url: `https://seichi-atlas-site.vercel.app${canonicalPath}`,
  isPartOf: {
    "@type": "WebSite",
    name: "Seichi Atlas",
    url: "https://seichi-atlas-site.vercel.app/",
  },
  about: {
    "@type": "Place",
    name: areaName,
    address: {
      "@type": "PostalAddress",
      addressCountry: "JP",
      addressRegion: areaName,
    },
  },
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: areaSpots.length,
    itemListElement: areaSpots.slice(0, 20).map((spot, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: spot.name,
      url: spot.slug
        ? `https://seichi-atlas-site.vercel.app/spots/${spot.slug}/`
        : "https://seichi-atlas-site.vercel.app/spots/",
    })),
  },
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "HOME",
      item: "https://seichi-atlas-site.vercel.app/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "地域一覧",
      item: "https://seichi-atlas-site.vercel.app/areas/",
    },
    {
      "@type": "ListItem",
      position: 3,
      name: areaName,
      item: `https://seichi-atlas-site.vercel.app${canonicalPath}`,
    },
  ],
};
---

<BaseLayout title={title} description={description} canonical={canonicalPath}>
  <script type="application/ld+json" set:html={JSON.stringify(areaJsonLd)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)}></script>

  <main class="area-detail-page">

    <section class="area-hero reveal-item">
      <div>
        <div class="section-kicker">AREA GUIDE</div>

        <h1>{areaName}の聖地巡礼ガイド</h1>

        <p>
          {area.description || `${areaName}に関連する作品・スポットをまとめた地域別の聖地巡礼ガイドです。`}
        </p>

        <div class="hero-actions">
          <a class="button-primary" href={`/map/?area=${area.slug}`}>地図で探す</a>
          <a class="button-secondary" href={`/spots/?area=${area.slug}`}>スポット一覧で探す</a>
        </div>
      </div>

      <div class="area-stats">
        <div class="stat-card">
          <span>関連スポット</span>
          <strong class="count-up" data-count={areaSpots.length}>0</strong>
        </div>

        <div class="stat-card">
          <span>関連作品</span>
          <strong class="count-up" data-count={relatedWorks.length}>0</strong>
        </div>

        <div class="stat-card">
          <span>関連タグ</span>
          <strong class="count-up" data-count={areaTags.length}>0</strong>
        </div>
      </div>
    </section>

    <section class="area-layout">

      <div class="main-column">

        <section class="content-card reveal-item">
          <div class="section-header">
            <div>
              <div class="section-kicker">SUMMARY</div>
              <h2>{areaName}で探せる聖地</h2>
            </div>
          </div>

          <p class="lead-text">
            このページでは、{areaName}に関連する聖地巡礼スポットの概要、関連作品、
            代表的なスポットをまとめています。全スポットを細かく探す場合は、
            スポット一覧またはマップから探してください。
          </p>

          <div class="summary-grid">
            <a href="/map/" class="summary-link-card">
              <span>MAP</span>
              <strong>地図で探す</strong>
              <small>{areaName}周辺のスポットを地図で確認する</small>
            </a>

            <a href="/spots/" class="summary-link-card">
              <span>SPOTS</span>
              <strong>スポット一覧で探す</strong>
              <small>作品・地域・タグで絞り込んで探す</small>
            </a>

            <a href="/works/" class="summary-link-card">
              <span>WORKS</span>
              <strong>作品から探す</strong>
              <small>関連作品の一覧から探す</small>
            </a>
          </div>
        </section>

        <section class="content-card reveal-item">
          <div class="section-header">
            <div>
              <div class="section-kicker">FEATURED SPOTS</div>
              <h2>代表スポット</h2>
              <p>{areaSpots.length}件中、代表的なスポットを最大6件表示しています。</p>
            </div>

            <a class="section-link" href="/spots/">全スポットを見る</a>
          </div>

          {featuredSpots.length > 0 ? (
            <div class="featured-spot-grid">
              {featuredSpots.map((spot, index) => (
                <article
                  class={`featured-spot-card level-${spot.officialLevel}`}
                  style={`--card-delay:${index * 40}ms;`}
                >
                  <div class="spot-card-main">
                    <div class="spot-card-top">
                      <div>
                        <h3>{spot.name}</h3>

                        <div class="spot-meta-row">
                          {spot.work && <span>{spot.work}</span>}
                          {spot.prefecture && <span>{spot.prefecture}</span>}
                          {spot.station && <span>{spot.station}</span>}
                        </div>
                      </div>

                      <div class={`level-pill level-${spot.officialLevel}`}>
                        {spot.officialLabel}
                      </div>
                    </div>

                    {spot.descriptionText && (
                      <p class="spot-description">
                        {spot.descriptionText}
                      </p>
                    )}

                    {spot.tags.length > 0 && (
                      <div class="spot-tags">
                        {spot.tags.slice(0, 4).map((tag) => (
                          <span>#{tag}</span>
                        ))}
                      </div>
                    )}

                    <div class="spot-actions">
                      <a
                        class="spot-button primary"
                        href={spot.slug ? `/spots/${spot.slug}/` : "/spots/"}
                      >
                        スポット詳細
                      </a>

                      {spot.workSlug && (
                        <a class="spot-button" href={`/works/${spot.workSlug}/`}>
                          作品ページ
                        </a>
                      )}
                    </div>
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <div class="empty-card">
              <h3>この地域のスポットはまだ登録されていません</h3>
              <p>今後データを追加すると、このページに代表スポットが表示されます。</p>
            </div>
          )}
        </section>

      </div>

      <aside class="side-column">

        <section class="side-card reveal-item">
          <div class="section-kicker">WORKS</div>
          <h2>関連作品</h2>

          {relatedWorks.length > 0 ? (
            <div class="side-link-list">
              {relatedWorks.map((work) => (
                <a href={work.slug ? `/works/${work.slug}/` : "/works/"}>
                  <span>{work.title}</span>
                  <small>作品ページへ →</small>
                </a>
              ))}
            </div>
          ) : (
            <p class="side-muted">関連作品はまだ登録されていません。</p>
          )}
        </section>

        <section class="side-card reveal-item">
          <div class="section-kicker">TAGS</div>
          <h2>関連タグ</h2>

          {areaTags.length > 0 ? (
            <div class="tag-list">
              {areaTags.map((tag) => (
                <span>#{tag}</span>
              ))}
            </div>
          ) : (
            <p class="side-muted">タグはまだ登録されていません。</p>
          )}
        </section>

        <section class="side-card reveal-item">
          <div class="section-kicker">NAVIGATION</div>
          <h2>探し方</h2>

          <div class="side-link-list">
            <a href="/map/">
              <span>マップから探す</span>
              <small>地図上でスポットを探す →</small>
            </a>

            <a href="/spots/">
              <span>スポットから探す</span>
              <small>一覧検索で探す →</small>
            </a>

            <a href="/areas/">
              <span>地域一覧へ戻る</span>
              <small>他の地域を見る →</small>
            </a>
          </div>
        </section>

      </aside>

    </section>

  </main>

  <style>
    .area-detail-page {
      width: calc(100% - 32px);
      max-width: 1180px;
      margin: 0 auto;
      padding: 44px 0 72px;
    }

    .section-kicker {
      color: var(--accent-dark);
      font-size: 12px;
      font-weight: 950;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .area-hero {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
      gap: 24px;
      align-items: stretch;
      margin-bottom: 22px;
      padding: 30px;
      border-radius: var(--radius-large);
      background: linear-gradient(135deg, #ffffff 0%, var(--card-subtle) 100%);
      border: 1px solid var(--border-soft);
      box-shadow: var(--shadow);
    }

    .area-hero h1 {
      margin: 8px 0 12px;
      color: var(--text);
      font-size: clamp(34px, 5vw, 54px);
      line-height: 1.12;
      letter-spacing: -0.05em;
    }

    .area-hero p,
    .lead-text {
      max-width: 760px;
      margin: 0;
      color: var(--sub);
      font-size: 15px;
      font-weight: 750;
      line-height: 1.8;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 22px;
    }

    .area-stats {
      display: grid;
      gap: 12px;
    }

    .stat-card {
      padding: 20px;
      border-radius: 22px;
      background: #ffffff;
      border: 1px solid var(--border-soft);
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.04);
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

    .stat-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-strong);
    }

    .stat-card span {
      display: block;
      margin-bottom: 8px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 900;
    }

    .stat-card strong {
      display: block;
      color: var(--text);
      font-size: 36px;
      font-weight: 950;
      line-height: 1;
      letter-spacing: -0.04em;
    }

    .area-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 320px;
      gap: 18px;
      align-items: start;
    }

    .main-column {
      display: grid;
      gap: 18px;
    }

    .content-card,
    .side-card {
      border-radius: var(--radius-card);
      background: #ffffff;
      border: 1px solid var(--border-soft);
      box-shadow: var(--shadow);
    }

    .content-card {
      padding: 22px;
    }

    .side-card {
      padding: 20px;
      margin-bottom: 16px;
    }

    .side-column {
      position: sticky;
      top: 90px;
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
      margin-bottom: 18px;
    }

    .section-header h2,
    .side-card h2 {
      margin: 4px 0 0;
      padding: 0;
      border: none;
      color: var(--text);
      font-size: 24px;
      letter-spacing: -0.03em;
    }

    .section-header p,
    .side-muted {
      margin: 6px 0 0;
      color: var(--sub);
      font-size: 13px;
      font-weight: 750;
      line-height: 1.7;
    }

    .side-card h2 {
      margin-bottom: 14px;
      font-size: 20px;
    }

    .section-link {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      border-radius: 999px;
      padding: 8px 14px;
      background: var(--accent-soft);
      color: var(--accent-dark);
      font-size: 13px;
      font-weight: 900;
      transition: transform 0.18s ease, background 0.18s ease, color 0.18s ease;
    }

    .section-link:hover {
      transform: translateY(-1px);
      background: var(--card-subtle);
      color: var(--text);
    }

    .summary-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
      margin-top: 20px;
    }

    .summary-link-card {
      display: grid;
      gap: 6px;
      padding: 18px;
      border-radius: 20px;
      background: var(--card-subtle);
      border: 1px solid var(--border-soft);
      transition: transform 0.18s ease, background 0.18s ease, box-shadow 0.18s ease;
    }

    .summary-link-card:hover {
      transform: translateY(-2px);
      background: var(--accent-soft);
      box-shadow: var(--shadow);
    }

    .summary-link-card span {
      color: var(--accent-dark);
      font-size: 11px;
      font-weight: 950;
      letter-spacing: 0.08em;
    }

    .summary-link-card strong {
      color: var(--text);
      font-size: 18px;
      font-weight: 950;
    }

    .summary-link-card small {
      color: var(--sub);
      font-size: 12px;
      font-weight: 750;
      line-height: 1.6;
    }

    .featured-spot-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 14px;
    }

    .featured-spot-card {
      display: flex;
      border-left: 5px solid var(--sub);
      border-radius: var(--radius-card);
      background: #ffffff;
      border-top: 1px solid var(--border-soft);
      border-right: 1px solid var(--border-soft);
      border-bottom: 1px solid var(--border-soft);
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.05);
      animation: cardIn 0.42s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      animation-delay: var(--card-delay);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .featured-spot-card.level-official {
      border-left-color: var(--accent);
    }

    .featured-spot-card.level-tourism {
      border-left-color: var(--visited);
    }

    .featured-spot-card.level-fan {
      border-left-color: var(--sub);
    }

    .featured-spot-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-strong);
    }

    .spot-card-main {
      width: 100%;
      display: flex;
      flex-direction: column;
      padding: 20px;
    }

    .spot-card-top {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 14px;
      align-items: start;
    }

    .featured-spot-card h3 {
      margin: 0;
      color: var(--text);
      font-size: 19px;
      font-weight: 950;
      line-height: 1.35;
      letter-spacing: -0.02em;
    }

    .spot-meta-row,
    .spot-tags,
    .spot-actions,
    .tag-list {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
    }

    .spot-meta-row {
      margin-top: 10px;
    }

    .spot-meta-row span {
      display: inline-flex;
      padding: 6px 10px;
      border-radius: 999px;
      background: var(--card-subtle);
      color: var(--sub);
      font-size: 13px;
      font-weight: 750;
    }

    .level-pill {
      flex-shrink: 0;
      display: inline-flex;
      width: fit-content;
      padding: 7px 11px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 950;
      letter-spacing: 0.03em;
    }

    .level-pill.level-official {
      background: var(--accent-soft);
      color: var(--accent-dark);
    }

    .level-pill.level-tourism {
      background: var(--visited-soft);
      color: var(--visited-dark);
    }

    .level-pill.level-fan {
      background: var(--card-subtle);
      color: var(--sub);
    }

    .spot-description {
      display: -webkit-box;
      margin: 16px 0 0;
      color: var(--sub);
      font-size: 13px;
      font-weight: 750;
      line-height: 1.7;
      overflow: hidden;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
    }

    .spot-tags {
      margin-top: 14px;
    }

    .spot-tags span,
    .tag-list span {
      display: inline-flex;
      padding: 5px 9px;
      border-radius: 999px;
      background: var(--accent-soft);
      color: var(--accent-dark);
      font-size: 12px;
      font-weight: 850;
    }

    .spot-actions {
      margin-top: auto;
      padding-top: 16px;
    }

    .spot-button {
      min-height: 38px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 8px 12px;
      background: var(--card-subtle);
      color: var(--text);
      font-size: 12px;
      font-weight: 900;
      cursor: pointer;
      transition: transform 0.16s ease, background 0.16s ease, color 0.16s ease;
    }

    .spot-button.primary {
      background: var(--accent);
      border-color: var(--accent);
      color: #ffffff;
      box-shadow: 0 10px 22px rgba(14, 165, 233, 0.18);
    }

    .spot-button:hover {
      transform: translateY(-1px);
      background: var(--accent-soft);
      color: var(--accent-dark);
    }

    .spot-button.primary:hover {
      background: var(--accent-dark);
      color: #ffffff;
    }

    .side-link-list {
      display: grid;
      gap: 10px;
    }

    .side-link-list a {
      display: grid;
      gap: 2px;
      padding: 12px;
      border-radius: 14px;
      background: var(--card-subtle);
      border: 1px solid var(--border-soft);
      transition: transform 0.18s ease, background 0.18s ease;
    }

    .side-link-list a:hover {
      transform: translateY(-1px);
      background: var(--accent-soft);
    }

    .side-link-list span {
      color: var(--text);
      font-size: 14px;
      font-weight: 900;
    }

    .side-link-list small {
      color: var(--sub);
      font-size: 12px;
      font-weight: 750;
    }

    .empty-card {
      padding: 34px 22px;
      border-radius: var(--radius-card);
      background: var(--card-subtle);
      border: 1px solid var(--border-soft);
      text-align: center;
    }

    .empty-card h3 {
      margin: 0 0 8px;
      color: var(--text);
      font-size: 20px;
    }

    .empty-card p {
      margin: 0;
      color: var(--sub);
      font-size: 14px;
      font-weight: 750;
    }

    .reveal-item {
      opacity: 0;
      animation: contentFadeUp 0.42s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes contentFadeUp {
      from {
        opacity: 0;
        transform: translateY(14px) scale(0.99);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @keyframes cardIn {
      from {
        opacity: 0;
        transform: translateY(14px) scale(0.985);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @media (max-width: 980px) {
      .area-hero,
      .area-layout {
        grid-template-columns: 1fr;
      }

      .area-stats,
      .summary-grid {
        grid-template-columns: repeat(3, 1fr);
      }

      .side-column {
        position: static;
      }
    }

    @media (max-width: 760px) {
      .area-detail-page {
        width: calc(100% - 24px);
        padding: 26px 0 52px;
      }

      .area-hero {
        padding: 22px;
        border-radius: 24px;
      }

      .area-hero h1 {
        font-size: 34px;
      }

      .area-stats,
      .summary-grid {
        grid-template-columns: 1fr;
      }

      .stat-card {
        padding: 14px 10px;
      }

      .stat-card strong {
        font-size: 26px;
      }

      .section-header {
        display: block;
      }

      .section-link {
        width: 100%;
        margin-top: 12px;
      }

      .spot-card-top {
        display: block;
      }

      .level-pill {
        margin-top: 12px;
      }

      .spot-actions,
      .hero-actions {
        display: grid;
        grid-template-columns: 1fr;
      }

      .spot-button {
        width: 100%;
      }
    }
  </style>

  <script>
    function animateCountUp(element, target, duration) {
      const endValue = Number(target || 0);
      const startTime = performance.now();

      function update(now) {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const value = Math.round(endValue * eased);

        element.textContent = String(value);

        if (progress < 1) {
          requestAnimationFrame(update);
        } else {
          element.textContent = String(endValue);
        }
      }

      requestAnimationFrame(update);
    }

    document.querySelectorAll(".count-up").forEach((element) => {
      animateCountUp(element, Number(element.dataset.count || 0), 720);
    });
  </script>
</BaseLayout>