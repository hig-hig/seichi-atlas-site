---
import BaseLayout from "../layouts/BaseLayout.astro";
import { works, spots, areas } from "../data/portalData.js";

const title = "アニメ聖地巡礼を地図から探す | Seichi Atlas";
const description = "Seichi Atlasは、アニメや漫画の聖地巡礼スポットを作品・地域・地図から探せる非公式ポータルです。";

const normalizedWorks = works.map((work) => {
  const workSpots = spots.filter((spot) => spot.workSlug === work.slug);
  const prefectures = [
    ...new Set(workSpots.map((spot) => spot.prefecture).filter(Boolean)),
  ];
  const tags = [
    ...new Set(
      workSpots
        .flatMap((spot) => Array.isArray(spot.tags) ? spot.tags : [])
        .filter(Boolean)
    ),
  ];

  return {
    ...work,
    spotCount: workSpots.length,
    prefectures,
    tags,
    mainArea: prefectures.slice(0, 2).join(" / ") || "地域未登録",
  };
});

const prefectures = [
  ...new Set(spots.map((spot) => spot.prefecture).filter(Boolean)),
];

const visibleAreas = areas.slice(0, 8);
const totalWorks = works.length;
const totalSpots = spots.length;

const heroMapSpots = spots
  .map((spot, index) => {
    const work = works.find((item) => item.slug === spot.workSlug);
    const lat = Number(spot.lat);
    const lng = Number(spot.lng);

    return {
      id: String(spot.id || spot.slug || index + 1),
      name: spot.name || "聖地スポット",
      work: spot.work || spot.workTitle || work?.title || "",
      lat,
      lng,
    };
  })
  .filter((spot) => Number.isFinite(spot.lat) && Number.isFinite(spot.lng))
  .slice(0, 10);

const heroMapSpotsJson = JSON.stringify(heroMapSpots).replace(/</g, "\\u003c");
---

<BaseLayout title={title} description={description} canonical="/">
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  />

  <main class="home-page">
    <section class="home-hero">
      <div class="home-hero-main">
        <p class="section-kicker">SEICHI ATLAS</p>
        <h1>アニメの舞台を、地図で探す。</h1>
        <p class="hero-copy">作品や地域を手がかりに、気になる舞台を地図から見つけられます。</p>

        <div class="hero-actions" aria-label="主要ナビゲーション">
          <a class="button-primary" href="/map/">地図を開く</a>
          <a class="button-secondary" href="/works/">作品を見る</a>
        </div>
      </div>

      <div class="home-hero-visual" aria-label="地図プレビュー">
        <div class="map-visual">
          <div id="home-hero-map" class="home-hero-map" aria-label="聖地スポットの地図プレビュー"></div>
          <div class="map-count map-count-spots">
            <strong>{totalSpots}</strong>
            <span>spots</span>
          </div>
          <div class="map-count map-count-works">
            <strong>{totalWorks}</strong>
            <span>works</span>
          </div>
        </div>
      </div>
    </section>

    <section class="works-section" aria-labelledby="works-heading">
      <div class="section-head">
        <div>
          <p class="section-kicker">WORKS</p>
          <h2 id="works-heading">作品から探す</h2>
        </div>
        <a class="section-link" href="/works/">作品一覧へ</a>
      </div>

      <div class="filter-bar" aria-label="作品の絞り込み">
        <label class="search-field">
          <span>検索</span>
          <input
            id="work-search"
            type="search"
            placeholder="作品名・地域で検索"
            autocomplete="off"
          />
        </label>

        <div class="region-filter" aria-label="地域">
          <button class="filter-chip active" type="button" data-region="all">すべて</button>
          {prefectures.map((prefecture) => (
            <button class="filter-chip" type="button" data-region={prefecture}>
              {prefecture}
            </button>
          ))}
        </div>
      </div>

      <p id="work-result-count" class="result-count">
        {normalizedWorks.length}件
      </p>

      <div class="work-grid" id="work-grid">
        {normalizedWorks.map((work, index) => (
          <a
            class="work-card"
            href={work.slug ? `/works/${work.slug}/` : "/works/"}
            style={`--card-delay:${index * 28}ms;`}
            data-title={work.title}
            data-year={work.year}
            data-prefectures={work.prefectures.join(",")}
            data-tags={work.tags.join(",")}
          >
            <h3>{work.title}</h3>
            <dl>
              <div>
                <dt>スポット数</dt>
                <dd>{work.spotCount}件</dd>
              </div>
              <div>
                <dt>主な地域</dt>
                <dd>{work.mainArea}</dd>
              </div>
            </dl>
            <span class="card-link">見る <span aria-hidden="true">→</span></span>
          </a>
        ))}
      </div>

      <div class="empty-result-card" id="empty-result" hidden>
        <h3>該当する作品がありません</h3>
        <p>検索語句や地域を変えてください。</p>
      </div>
    </section>

    <section class="area-section" aria-labelledby="areas-heading">
      <div class="section-head">
        <div>
          <p class="section-kicker">AREA</p>
          <h2 id="areas-heading">地域</h2>
        </div>
        <a class="section-link" href="/areas/">地域一覧へ</a>
      </div>

      <div class="area-grid">
        {visibleAreas.map((area) => (
          <a class="area-card" href={area.slug ? `/areas/${area.slug}/` : "/areas/"}>
            <strong>{area.name}</strong>
            <span>見る →</span>
          </a>
        ))}
      </div>
    </section>
  </main>

  <style>
    .home-page {
      width: calc(100% - 32px);
      max-width: 1680px;
      margin: 0 auto;
      padding: 44px 0 72px;
    }

    .section-kicker {
      margin: 0;
      color: var(--accent-dark);
      font-size: 12px;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .home-hero {
      display: grid;
      grid-template-columns: minmax(0, 0.86fr) minmax(520px, 1.14fr);
      gap: 28px;
      align-items: stretch;
      min-height: 470px;
      margin-bottom: 42px;
      padding: 36px;
      border: 1px solid var(--border-soft);
      border-radius: var(--radius-large);
      background:
        radial-gradient(circle at 18% 18%, rgba(14, 165, 233, 0.12), transparent 28%),
        linear-gradient(135deg, #ffffff 0%, var(--card-subtle) 100%);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .home-hero-main {
      display: flex;
      min-width: 0;
      flex-direction: column;
      justify-content: center;
    }

    .home-hero h1 {
      max-width: 760px;
      margin: 10px 0 14px;
      color: var(--text);
      font-size: clamp(40px, 5vw, 68px);
      line-height: 1.12;
      letter-spacing: -0.04em;
    }

    .hero-copy {
      max-width: 680px;
      margin: 0;
      color: var(--sub);
      font-size: 16px;
      font-weight: 700;
      line-height: 1.8;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 26px;
    }

    .home-hero-visual {
      min-width: 0;
    }

    .map-visual {
      position: relative;
      width: 100%;
      height: 100%;
      min-height: 390px;
      overflow: hidden;
      border: 1px solid var(--border-soft);
      border-radius: 26px;
      background: var(--card-subtle);
      box-shadow: var(--shadow);
    }

    .map-visual::after {
      content: "";
      position: absolute;
      z-index: 2;
      inset: 0;
      pointer-events: none;
      background:
        linear-gradient(90deg, rgba(255, 255, 255, 0.58) 0%, transparent 36%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.18) 0%, transparent 42%);
    }

    .home-hero-map {
      position: absolute;
      z-index: 1;
      inset: 0;
      height: 100%;
    }

    .map-visual .leaflet-container {
      background: var(--card-subtle);
      cursor: pointer;
      font-family: inherit;
    }

    .map-visual .leaflet-control-attribution {
      font-size: 10px;
    }

    .hero-map-popup {
      display: grid;
      gap: 2px;
      min-width: 150px;
    }

    .hero-map-popup strong {
      color: var(--text);
      font-size: 13px;
      font-weight: 900;
    }

    .hero-map-popup span {
      color: var(--sub);
      font-size: 12px;
      font-weight: 700;
    }

    .hero-map-popup a {
      margin-top: 4px;
      color: var(--accent-dark);
      font-size: 12px;
      font-weight: 900;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .hero-map-marker {
      display: block;
      width: 18px;
      height: 18px;
      border: 3px solid #ffffff;
      border-radius: 50% 50% 50% 0;
      background: var(--accent);
      box-shadow: 0 10px 22px rgba(14, 165, 233, 0.34);
      transform: rotate(-45deg);
    }

    .map-count {
      position: absolute;
      z-index: 5;
      display: inline-flex;
      align-items: baseline;
      gap: 6px;
      padding: 10px 14px;
      border: 1px solid var(--border-soft);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.92);
      color: var(--accent-dark);
      box-shadow: var(--shadow);
    }

    .map-count strong {
      font-size: 24px;
      font-weight: 950;
      line-height: 1;
    }

    .map-count span {
      color: var(--sub);
      font-size: 12px;
      font-weight: 900;
    }

    .map-count-spots {
      top: 22px;
      left: 22px;
    }

    .map-count-works {
      right: 22px;
      bottom: 22px;
    }

    .works-section,
    .area-section {
      margin-top: 34px;
    }

    .section-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 18px;
      margin-bottom: 18px;
    }

    .section-head h2 {
      margin: 4px 0 0;
      border: 0;
      padding: 0;
      color: var(--text);
      font-size: 30px;
      line-height: 1.2;
      letter-spacing: -0.03em;
    }

    .section-link {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      padding: 9px 15px;
      border-radius: 999px;
      background: var(--accent-soft);
      color: var(--accent-dark);
      font-size: 13px;
      font-weight: 900;
      transition: background 0.18s ease, transform 0.18s ease;
    }

    .section-link:hover {
      transform: translateY(-1px);
      background: #bae6fd;
    }

    .filter-bar {
      display: grid;
      grid-template-columns: minmax(220px, 320px) minmax(0, 1fr);
      gap: 14px;
      align-items: start;
      margin-bottom: 14px;
      padding: 16px;
      border: 1px solid var(--border-soft);
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.78);
      box-shadow: 0 12px 28px rgba(15, 23, 42, 0.04);
    }

    .search-field {
      display: grid;
      gap: 8px;
    }

    .search-field span {
      color: var(--muted);
      font-size: 12px;
      font-weight: 900;
    }

    .search-field input {
      width: 100%;
      min-height: 42px;
      padding: 10px 13px;
      border: 1px solid var(--border);
      border-radius: 14px;
      outline: none;
      background: #ffffff;
      color: var(--text);
      font-size: 14px;
      font-weight: 700;
      transition: border-color 0.18s ease, box-shadow 0.18s ease;
    }

    .search-field input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.14);
    }

    .region-filter {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .filter-chip {
      min-height: 34px;
      border: 0;
      border-radius: 999px;
      padding: 8px 12px;
      background: var(--card-subtle);
      color: var(--sub);
      cursor: pointer;
      font-size: 13px;
      font-weight: 850;
      transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease;
    }

    .filter-chip:hover {
      transform: translateY(-1px);
      background: #e8eef6;
      color: var(--text);
    }

    .filter-chip.active {
      background: var(--accent);
      color: #ffffff;
    }

    .result-count {
      margin: 0 0 14px;
      color: var(--sub);
      font-size: 13px;
      font-weight: 800;
    }

    .work-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 16px;
    }

    .work-grid.filter-refreshing .work-card:not([hidden]) {
      animation: filterResultFadeIn 0.24s ease-out;
    }

    .work-card {
      display: flex;
      min-height: 210px;
      flex-direction: column;
      padding: 24px;
      border: 1px solid var(--border-soft);
      border-radius: var(--radius-card);
      background: #ffffff;
      box-shadow: 0 12px 28px rgba(15, 23, 42, 0.055);
      opacity: 0;
      animation: cardIn 0.36s ease-out forwards;
      animation-delay: var(--card-delay);
      transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
    }

    .work-card[hidden] {
      display: none !important;
    }

    .work-card:hover {
      transform: translateY(-2px);
      border-color: var(--accent-soft);
      box-shadow: var(--shadow-strong);
    }

    .work-card h3 {
      margin: 0;
      color: var(--text);
      font-size: 20px;
      font-weight: 950;
      line-height: 1.4;
      letter-spacing: -0.02em;
      overflow-wrap: anywhere;
    }

    .work-card dl {
      display: grid;
      gap: 10px;
      margin: 22px 0 0;
    }

    .work-card dl div {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 14px;
      padding-top: 10px;
      border-top: 1px solid var(--border-soft);
    }

    .work-card dt {
      color: var(--muted);
      font-size: 12px;
      font-weight: 900;
    }

    .work-card dd {
      margin: 0;
      color: var(--sub);
      font-size: 14px;
      font-weight: 800;
      text-align: right;
    }

    .card-link {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      margin-top: auto;
      padding-top: 22px;
      color: var(--accent-dark);
      font-size: 14px;
      font-weight: 950;
    }

    .card-link span {
      transition: transform 0.18s ease;
    }

    .work-card:hover .card-link span {
      transform: translateX(3px);
    }

    .empty-result-card {
      margin-top: 18px;
      padding: 32px 24px;
      border: 1px solid var(--border-soft);
      border-radius: var(--radius-large);
      background: #ffffff;
      text-align: center;
      box-shadow: var(--shadow);
    }

    .empty-result-card h3 {
      margin: 0 0 8px;
      font-size: 20px;
    }

    .empty-result-card p {
      margin: 0;
      color: var(--sub);
      font-size: 14px;
      font-weight: 700;
    }

    .area-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
      gap: 12px;
    }

    .area-card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      min-height: 82px;
      padding: 20px;
      border: 1px solid var(--border-soft);
      border-radius: 20px;
      background: #ffffff;
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.045);
      transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
    }

    .area-card:hover {
      transform: translateY(-2px);
      border-color: var(--accent-soft);
      box-shadow: var(--shadow);
    }

    .area-card strong {
      color: var(--text);
      font-size: 18px;
      font-weight: 950;
    }

    .area-card span {
      flex-shrink: 0;
      color: var(--accent-dark);
      font-size: 13px;
      font-weight: 900;
    }

    @keyframes cardIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes filterResultFadeIn {
      from {
        opacity: 0.5;
        transform: translateY(6px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 980px) {
      .home-hero {
        grid-template-columns: 1fr;
      }

      .home-hero-visual {
        min-height: 330px;
      }

      .filter-bar {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 760px) {
      .home-page {
        width: calc(100% - 24px);
        padding: 28px 0 52px;
      }

      .home-hero {
        gap: 24px;
        min-height: auto;
        padding: 22px;
        border-radius: 24px;
      }

      .home-hero h1 {
        font-size: 36px;
      }

      .hero-copy {
        font-size: 15px;
      }

      .hero-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
      }

      .home-hero-visual,
      .map-visual {
        min-height: 280px;
      }

      .map-visual {
        border-radius: 22px;
      }

      .map-count {
        padding: 8px 11px;
      }

      .map-count strong {
        font-size: 20px;
      }

      .section-head {
        align-items: start;
      }

      .section-head h2 {
        font-size: 26px;
      }

      .filter-bar {
        padding: 14px;
      }

      .region-filter {
        flex-wrap: nowrap;
        margin-inline: -14px;
        padding: 0 14px 2px;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }

      .filter-chip {
        flex: 0 0 auto;
      }

      .work-grid,
      .area-grid {
        grid-template-columns: 1fr;
      }

      .work-card {
        min-height: 188px;
      }
    }

    @media (max-width: 420px) {
      .hero-actions {
        grid-template-columns: 1fr;
      }

      .section-head {
        display: grid;
      }

      .section-link {
        width: 100%;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      *,
      *::before,
      *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
        scroll-behavior: auto !important;
      }
    }
  </style>

  <script type="application/json" id="hero-map-spots" set:html={heroMapSpotsJson}></script>
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  <script>
    const heroMapElement = document.getElementById("home-hero-map");
    const heroMapDataElement = document.getElementById("hero-map-spots");
    const searchInput = document.getElementById("work-search");
    const regionButtons = Array.from(document.querySelectorAll("[data-region]"));
    const cards = Array.from(document.querySelectorAll(".work-card"));
    const countText = document.getElementById("work-result-count");
    const emptyResult = document.getElementById("empty-result");
    const grid = document.getElementById("work-grid");

    let activeRegion = "all";

    function escapeHtml(value) {
      return String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    function initHeroMap() {
      if (!heroMapElement || !heroMapDataElement || typeof L === "undefined") {
        return;
      }

      const previewSpots = JSON.parse(heroMapDataElement.textContent || "[]");

      if (!previewSpots.length) {
        return;
      }

      const map = L.map(heroMapElement, {
        zoomControl: false,
        scrollWheelZoom: false,
        dragging: false,
        touchZoom: false,
        doubleClickZoom: false,
        boxZoom: false,
        keyboard: false,
        tap: false,
      });

      L.tileLayer("https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png", {
        attribution: "&copy; OpenStreetMap &copy; CARTO",
        subdomains: "abcd",
        maxZoom: 20,
      }).addTo(map);

      const markerIcon = L.divIcon({
        className: "",
        html: '<span class="hero-map-marker"></span>',
        iconSize: [24, 24],
        iconAnchor: [12, 22],
        popupAnchor: [0, -18],
      });

      const bounds = [];

      previewSpots.forEach((spot) => {
        const latLng = [spot.lat, spot.lng];
        const popupHtml = `
          <div class="hero-map-popup">
            <strong>${escapeHtml(spot.name)}</strong>
            ${spot.work ? `<span>${escapeHtml(spot.work)}</span>` : ""}
            <a href="/map/">地図を開く</a>
          </div>
        `;

        L.marker(latLng, { icon: markerIcon })
          .addTo(map)
          .bindPopup(popupHtml);

        bounds.push(latLng);
      });

      map.fitBounds(bounds, {
        padding: [42, 42],
        maxZoom: 11,
      });

      map.on("click", () => {
        window.location.href = "/map/";
      });
    }

    function normalizeText(value) {
      return String(value || "").toLowerCase();
    }

    function setActiveRegion(value) {
      regionButtons.forEach((button) => {
        button.classList.toggle("active", button.dataset.region === value);
      });
    }

    function refreshGridMotion() {
      if (!grid) {
        return;
      }

      grid.classList.remove("filter-refreshing");
      void grid.offsetWidth;
      grid.classList.add("filter-refreshing");

      setTimeout(() => {
        grid.classList.remove("filter-refreshing");
      }, 260);
    }

    function applyFilters() {
      const keyword = normalizeText(searchInput?.value);
      let visibleCount = 0;

      cards.forEach((card) => {
        const prefectures = String(card.dataset.prefectures || "");
        const keywordTarget = normalizeText([
          card.dataset.title,
          card.dataset.year,
          prefectures,
          card.dataset.tags,
        ].join(" "));

        const keywordMatch = !keyword || keywordTarget.includes(keyword);
        const regionMatch =
          activeRegion === "all" ||
          prefectures.split(",").includes(activeRegion);
        const isVisible = keywordMatch && regionMatch;

        card.hidden = !isVisible;

        if (isVisible) {
          visibleCount += 1;
        }
      });

      if (countText) {
        countText.textContent = `${visibleCount}件`;
      }

      if (emptyResult) {
        emptyResult.hidden = visibleCount !== 0;
      }

      refreshGridMotion();
    }

    initHeroMap();

    searchInput?.addEventListener("input", applyFilters);

    regionButtons.forEach((button) => {
      button.addEventListener("click", () => {
        activeRegion = button.dataset.region || "all";
        setActiveRegion(activeRegion);
        applyFilters();
      });
    });
  </script>
</BaseLayout>
