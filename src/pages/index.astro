---
import BaseLayout from "../layouts/BaseLayout.astro";
import { works, spots, areas } from "../data/portalData.js";

const title = "アニメ聖地巡礼を地図から探す | Seichi Atlas";
const description = "Seichi Atlasは、アニメや漫画の聖地巡礼スポットを作品・地域・地図から探せる非公式ポータルです。";

const normalizedWorks = works.map((work) => {
  const workSpots = spots.filter((spot) => spot.workSlug === work.slug);

  const prefectures = [
    ...new Set(
      workSpots
        .map((spot) => spot.prefecture)
        .filter(Boolean)
    ),
  ];

  const tags = [
    ...new Set(
      workSpots
        .flatMap((spot) => Array.isArray(spot.tags) ? spot.tags : [])
        .filter(Boolean)
    ),
  ];

  return {
    ...work,
    spotCount: workSpots.length,
    prefectures,
    tags,
  };
});

const prefectures = [
  ...new Set(
    spots
      .map((spot) => spot.prefecture)
      .filter(Boolean)
  ),
];

const visibleAreas = areas.slice(0, 8);

const totalWorks = works.length;
const totalSpots = spots.length;
const totalAreas = areas.length;

const heroMapSpots = spots
  .map((spot, index) => {
    const work = works.find((item) => item.slug === spot.workSlug);
    const lat = Number(spot.lat);
    const lng = Number(spot.lng);

    return {
      id: String(spot.id || spot.slug || index + 1),
      name: spot.name || "聖地スポット",
      work: spot.work || spot.workTitle || work?.title || "",
      slug: spot.slug || "",
      lat,
      lng,
    };
  })
  .filter((spot) => Number.isFinite(spot.lat) && Number.isFinite(spot.lng))
  .slice(0, 8);

const heroMapSpotsJson = JSON.stringify(heroMapSpots).replace(/</g, "\\u003c");
---

<BaseLayout title={title} description={description} canonical="/">
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  />

  <main class="home-page">

    <section class="home-hero reveal-item">
      <div class="home-hero-main">
        <div class="section-kicker">SEICHI ATLAS</div>

        <h1>アニメの舞台を、地図から探す。</h1>

        <p>
          作品・地域・スポットを横断して、聖地巡礼の行き先を見つけよう。
        </p>

        <div class="hero-actions">
          <a class="button-primary" href="/map/">マップから探す</a>
          <a class="button-secondary" href="/works/">作品から探す</a>
        </div>
      </div>

      <div class="home-hero-visual">
        <div class="map-visual">
          <div id="home-hero-map" class="home-hero-map" aria-label="聖地スポットの地図プレビュー"></div>

          <div class="map-badge badge-spots">
            <strong>{totalSpots}</strong>
            <span>spots</span>
          </div>

          <div class="map-badge badge-works">
            <strong>{totalWorks}</strong>
            <span>works</span>
          </div>

          <div class="map-badge badge-areas">
            <strong>{totalAreas}</strong>
            <span>areas</span>
          </div>
        </div>
      </div>
    </section>

    <section class="home-app-layout">

      <aside class="filter-panel reveal-item">
        <button class="mobile-filter-toggle" type="button" id="mobile-filter-toggle">
          <span>絞り込みを開く</span>
        </button>

        <div class="filter-card">
          <div class="filter-title">探す</div>

          <input
            id="work-search"
            class="filter-input"
            type="search"
            placeholder="作品名・年・地域で検索"
            autocomplete="off"
          />

          <div class="filter-section">
            <div class="filter-subtitle">地域</div>

            <div class="filter-chip-list">
              <button class="filter-chip active" type="button" data-region="all">
                すべて
              </button>

              {prefectures.map((prefecture) => (
                <button class="filter-chip" type="button" data-region={prefecture}>
                  {prefecture}
                </button>
              ))}
            </div>
          </div>

          <div class="filter-section">
            <div class="filter-subtitle">スポット数</div>

            <div class="filter-chip-list">
              <button class="filter-chip active" type="button" data-count-filter="all">
                すべて
              </button>

              <button class="filter-chip" type="button" data-count-filter="has-spots">
                登録あり
              </button>

              <button class="filter-chip" type="button" data-count-filter="no-spots">
                未登録
              </button>
            </div>
          </div>

          <button class="filter-reset-button" type="button" id="filter-reset">
            条件をリセット
          </button>
        </div>
      </aside>

      <section class="main-panel">
        <div class="home-section-header reveal-item">
          <div>
            <div class="section-kicker">HOME</div>
            <h2>作品コレクション</h2>
            <p>
              作品を選んで、関連する聖地スポットやエリアを確認できます。
            </p>
          </div>

          <a class="section-link" href="/map/">地図で見る</a>
        </div>

        <div id="active-filter-summary" class="active-filter-summary muted reveal-item">
          すべての作品を表示中
        </div>

        <p id="work-result-count" class="result-count reveal-item">
          {normalizedWorks.length}件の作品を表示中
        </p>

        <div class="work-grid" id="work-grid">
          {normalizedWorks.map((work, index) => (
            <a
              class="work-card"
              href={work.slug ? `/works/${work.slug}/` : "/works/"}
              style={`--card-delay:${index * 42}ms;`}
              data-title={work.title}
              data-year={work.year}
              data-prefectures={work.prefectures.join(",")}
              data-tags={work.tags.join(",")}
              data-count={work.spotCount}
            >
              <div class="work-card-top">
                <div>
                  <h3>{work.title}</h3>

                  <div class="work-meta">
                    {work.year && <span>{work.year}</span>}
                    <span>{work.spotCount}スポット</span>
                    {work.prefectures.slice(0, 3).map((prefecture) => (
                      <span>{prefecture}</span>
                    ))}
                  </div>
                </div>

                <div class={`status-pill ${work.spotCount > 0 ? "active" : "empty"}`}>
                  {work.spotCount > 0 ? "公開中" : "未登録"}
                </div>
              </div>

              <div class="work-card-bottom">
                <div class="progress-head">
                  <span>登録スポット</span>
                  <strong>{work.spotCount}件</strong>
                </div>

                <div class="progress-bar">
                  <div
                    class="progress-fill"
                    style={`width:${Math.min(100, work.spotCount * 12)}%;`}
                  >
                  </div>
                </div>

                <div class="work-card-foot">
                  <span>
                    {work.prefectures.length > 0 ? work.prefectures.join(" / ") : "エリア未登録"}
                  </span>

                  <span class="card-link">
                    詳細を見る
                    <span class="arrow">→</span>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>

        <div class="empty-result-card" id="empty-result" hidden>
          <div class="empty-icon">🗺️</div>
          <h3>表示できる作品がありません</h3>
          <p>検索条件を変更するか、条件をリセットしてください。</p>
        </div>
      </section>

    </section>

    <section class="area-section reveal-item">
      <div class="home-section-header">
        <div>
          <div class="section-kicker">AREA</div>
          <h2>地域別に見る</h2>
          <p>
            地域ページはSEO・回遊用として残し、都道府県やエリアから関連スポットを確認できます。
          </p>
        </div>

        <a class="section-link" href="/areas/">地域一覧へ</a>
      </div>

      <div class="area-grid">
        {visibleAreas.map((area) => (
          <a class="area-card" href={area.slug ? `/areas/${area.slug}/` : "/areas/"}>
            <span>AREA</span>
            <strong>{area.name}</strong>
            <small>関連スポットを見る →</small>
          </a>
        ))}
      </div>
    </section>

  </main>

  <style>
    .home-page {
      width: calc(100% - 32px);
      max-width: 1680px;
      margin: 0 auto;
      padding: 44px 0 72px;
    }

    .home-hero {
      display: grid;
      grid-template-columns: minmax(0, 0.92fr) minmax(420px, 1.08fr);
      gap: 30px;
      align-items: stretch;
      min-height: 460px;
      margin-bottom: 30px;
      padding: 34px;
      border-radius: var(--radius-large);
      background:
        radial-gradient(circle at 18% 18%, rgba(14, 165, 233, 0.14), transparent 30%),
        linear-gradient(135deg, var(--card) 0%, var(--card-subtle) 100%);
      border: 1px solid var(--border-soft);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .home-hero-main {
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-width: 0;
    }

    .section-kicker {
      color: var(--accent-dark);
      font-size: 12px;
      font-weight: 950;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .home-hero h1 {
      max-width: 760px;
      margin: 8px 0 12px;
      font-size: clamp(38px, 5vw, 66px);
      line-height: 1.12;
      letter-spacing: -0.05em;
      color: var(--text);
    }

    .home-hero p {
      max-width: 720px;
      margin: 0;
      color: var(--sub);
      font-size: 15px;
      font-weight: 750;
      line-height: 1.8;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 22px;
    }

    .home-hero-visual {
      min-width: 0;
      display: flex;
      align-items: center;
    }

    .map-visual {
      position: relative;
      width: 100%;
      min-height: 380px;
      border-radius: 28px;
      overflow: hidden;
      background: var(--card-subtle);
      border: 1px solid var(--border-soft);
      box-shadow: var(--shadow);
    }

    .map-visual::after {
      content: "";
      position: absolute;
      z-index: 2;
      inset: 0;
      pointer-events: none;
      background:
        linear-gradient(90deg, rgba(255, 255, 255, 0.56) 0%, transparent 34%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.2) 0%, transparent 42%);
    }

    .home-hero-map {
      position: absolute;
      inset: 0;
      z-index: 1;
      height: 100%;
    }

    .map-visual .leaflet-container {
      background: var(--card-subtle);
      cursor: pointer;
      font-family: inherit;
    }

    .map-visual .leaflet-control-attribution {
      font-size: 10px;
    }

    .hero-map-popup {
      display: grid;
      gap: 2px;
      min-width: 150px;
    }

    .hero-map-popup strong {
      color: var(--text);
      font-size: 13px;
      font-weight: 900;
    }

    .hero-map-popup span {
      color: var(--sub);
      font-size: 12px;
      font-weight: 700;
    }

    .hero-map-popup a {
      margin-top: 4px;
      color: var(--accent-dark);
      font-size: 12px;
      font-weight: 900;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .hero-map-marker {
      display: block;
      width: 18px;
      height: 18px;
      border: 3px solid #ffffff;
      border-radius: 50% 50% 50% 0;
      background: var(--accent);
      box-shadow: 0 10px 22px rgba(14, 165, 233, 0.34);
      transform: rotate(-45deg);
    }

    .map-badge {
      position: absolute;
      z-index: 5;
      display: inline-flex;
      align-items: baseline;
      gap: 6px;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.9);
      border: 1px solid var(--border-soft);
      box-shadow: var(--shadow);
      color: var(--accent-dark);
    }

    .map-badge strong {
      font-size: 24px;
      font-weight: 950;
      line-height: 1;
    }

    .map-badge span {
      color: var(--sub);
      font-size: 12px;
      font-weight: 900;
    }

    .badge-spots {
      left: 22px;
      top: 24px;
    }

    .badge-works {
      right: 28px;
      top: 42px;
    }

    .badge-areas {
      left: 42%;
      bottom: 24px;
    }

    .home-app-layout {
      display: grid;
      grid-template-columns: 260px minmax(0, 1fr);
      gap: 28px;
      align-items: start;
    }

    .filter-panel {
      position: sticky;
      top: 90px;
    }

    .mobile-filter-toggle {
      display: none;
    }

    .filter-card {
      background: var(--card);
      border: 1px solid var(--border-soft);
      border-radius: var(--radius-card);
      padding: 22px;
      box-shadow: var(--shadow);
    }

    .filter-title {
      font-size: 18px;
      font-weight: 950;
      margin-bottom: 18px;
      color: var(--text);
    }

    .filter-input {
      width: 100%;
      padding: 13px 14px;
      border-radius: 14px;
      border: 1px solid var(--border);
      background: var(--card-subtle);
      color: var(--text);
      font-size: 14px;
      font-weight: 750;
      outline: none;
      margin-bottom: 20px;
      transition: border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
    }

    .filter-input:focus {
      border-color: var(--accent);
      background: #ffffff;
      box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.14);
    }

    .filter-section {
      margin-top: 22px;
    }

    .filter-subtitle {
      margin-bottom: 12px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 950;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .filter-chip-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .filter-chip {
      min-height: 34px;
      border: none;
      border-radius: 999px;
      padding: 8px 12px;
      background: var(--card-subtle);
      color: var(--sub);
      font-size: 13px;
      font-weight: 850;
      cursor: pointer;
      transition: transform 0.18s ease, background 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;
    }

    .filter-chip:hover {
      transform: translateY(-1px);
      background: #e8eef6;
      color: var(--text);
    }

    .filter-chip.active {
      background: var(--accent);
      color: #ffffff;
      box-shadow: 0 10px 22px rgba(14, 165, 233, 0.22);
      animation: chipPop 0.24s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .filter-reset-button {
      width: 100%;
      min-height: 40px;
      margin-top: 22px;
      border: 1px solid var(--border);
      border-radius: 14px;
      background: #ffffff;
      color: var(--sub);
      font-size: 13px;
      font-weight: 850;
      cursor: pointer;
      transition: transform 0.18s ease, background 0.18s ease, color 0.18s ease;
    }

    .filter-reset-button:hover {
      transform: translateY(-1px);
      background: var(--card-subtle);
      color: var(--text);
    }

    .main-panel {
      min-width: 0;
    }

    .home-section-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 20px;
      margin-bottom: 18px;
      padding: 26px;
      border-radius: var(--radius-large);
      background: linear-gradient(135deg, #ffffff 0%, var(--card-subtle) 100%);
      border: 1px solid var(--border-soft);
      box-shadow: var(--shadow);
    }

    .home-section-header h2 {
      margin: 6px 0 8px;
      color: var(--text);
      font-size: 32px;
      line-height: 1.15;
      letter-spacing: -0.04em;
    }

    .home-section-header p {
      margin: 0;
      color: var(--sub);
      font-size: 14px;
      font-weight: 750;
      line-height: 1.7;
    }

    .section-link {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      padding: 9px 14px;
      border-radius: 999px;
      background: var(--accent-soft);
      color: var(--accent-dark);
      font-size: 13px;
      font-weight: 900;
      transition: transform 0.18s ease, background 0.18s ease;
    }

    .section-link:hover {
      transform: translateY(-1px);
      background: #bae6fd;
    }

    .active-filter-summary {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 8px;
      margin: 0 0 14px;
      padding: 12px 14px;
      border-radius: 18px;
      background: #ffffff;
      border: 1px solid var(--border-soft);
      color: var(--sub);
      font-size: 13px;
      font-weight: 850;
    }

    .active-filter-summary.muted {
      color: var(--muted);
    }

    .summary-label {
      color: var(--accent-dark);
      font-weight: 950;
    }

    .summary-pill {
      display: inline-flex;
      padding: 5px 9px;
      border-radius: 999px;
      background: var(--card-subtle);
      color: var(--sub);
      font-size: 12px;
      font-weight: 850;
    }

    .result-count {
      margin: 8px 0 14px;
      color: var(--sub);
      font-size: 14px;
      font-weight: 750;
    }

    .work-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 16px;
    }

    .work-grid.filter-refreshing .work-card:not([hidden]) {
      animation: filterResultFadeIn 0.28s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .work-card {
      min-height: 260px;
      display: flex;
      flex-direction: column;
      padding: 22px;
      border-radius: var(--radius-card);
      background: #ffffff;
      border: 1px solid var(--border-soft);
      box-shadow: var(--shadow);
      opacity: 0;
      animation: cardIn 0.42s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      animation-delay: var(--card-delay);
      transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }
    .work-card[hidden] {
      display: none !important;
    }

    .work-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-strong);
      border-color: var(--accent-soft);
    }

    .work-card:active {
      transform: translateY(-1px) scale(0.985);
    }

    .work-card-top {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 14px;
      align-items: start;
    }

    .work-card h3 {
      min-height: 56px;
      margin: 0;
      color: var(--text);
      font-size: 20px;
      font-weight: 950;
      line-height: 1.35;
      letter-spacing: -0.02em;
      word-break: keep-all;
      overflow-wrap: anywhere;
    }

    .work-meta {
      min-height: 82px;
      display: flex;
      flex-wrap: wrap;
      align-content: flex-start;
      gap: 8px;
      margin-top: 10px;
    }

    .work-meta span {
      display: inline-flex;
      padding: 6px 10px;
      border-radius: 999px;
      background: var(--card-subtle);
      color: var(--sub);
      font-size: 13px;
      font-weight: 750;
    }

    .status-pill {
      flex-shrink: 0;
      white-space: nowrap;
      padding: 7px 11px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 950;
      letter-spacing: 0.03em;
    }

    .status-pill.active {
      background: var(--accent-soft);
      color: var(--accent-dark);
    }

    .status-pill.empty {
      background: #eef2f7;
      color: var(--sub);
    }

    .work-card-bottom {
      margin-top: auto;
    }

    .progress-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      margin-bottom: 8px;
      color: var(--sub);
      font-size: 13px;
      font-weight: 850;
    }

    .progress-head strong {
      color: var(--accent-dark);
      font-size: 15px;
      font-weight: 950;
    }

    .progress-bar {
      width: 100%;
      height: 10px;
      border-radius: 999px;
      background: #e8edf3;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--accent), #38bdf8);
      transition: width 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .work-card-foot {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      margin-top: 10px;
      color: var(--sub);
      font-size: 13px;
      font-weight: 800;
    }

    .card-link {
      color: var(--accent);
      font-weight: 950;
      white-space: nowrap;
    }

    .arrow {
      display: inline-flex;
      transition: transform 0.18s ease;
    }

    .work-card:hover .arrow {
      transform: translateX(4px);
    }

    .empty-result-card {
      margin-top: 18px;
      padding: 42px 28px;
      border-radius: var(--radius-large);
      background: #ffffff;
      border: 1px solid var(--border-soft);
      box-shadow: var(--shadow);
      text-align: center;
      animation: emptyStateIn 0.28s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .empty-icon {
      margin-bottom: 12px;
      font-size: 34px;
      animation: emptyIconFloat 1.8s ease-in-out infinite;
    }

    .empty-result-card h3 {
      margin: 0 0 8px;
      font-size: 22px;
    }

    .empty-result-card p {
      margin: 0;
      color: var(--sub);
      font-size: 14px;
      font-weight: 750;
    }

    .area-section {
      margin-top: 34px;
    }

    .area-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 14px;
    }

    .area-card {
      display: grid;
      gap: 6px;
      padding: 20px;
      border-radius: var(--radius-card);
      background: #ffffff;
      border: 1px solid var(--border-soft);
      box-shadow: var(--shadow);
      transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
    }

    .area-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-strong);
      border-color: var(--accent-soft);
    }

    .area-card span {
      color: var(--accent-dark);
      font-size: 11px;
      font-weight: 950;
      letter-spacing: 0.08em;
    }

    .area-card strong {
      color: var(--text);
      font-size: 19px;
      font-weight: 950;
    }

    .area-card small {
      color: var(--sub);
      font-size: 13px;
      font-weight: 800;
    }

    .reveal-item {
      opacity: 0;
      animation: contentFadeUp 0.42s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    

    @keyframes contentFadeUp {
      from {
        opacity: 0;
        transform: translateY(14px) scale(0.99);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @keyframes cardIn {
      from {
        opacity: 0;
        transform: translateY(14px) scale(0.985);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @keyframes filterResultFadeIn {
      from {
        opacity: 0.42;
        transform: translateY(8px) scale(0.99);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @keyframes chipPop {
      from {
        transform: scale(0.94);
      }

      65% {
        transform: scale(1.05);
      }

      to {
        transform: scale(1);
      }
    }

    @keyframes emptyStateIn {
      from {
        opacity: 0;
        transform: translateY(10px) scale(0.98);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @keyframes emptyIconFloat {
      0% {
        transform: translateY(0) rotate(0deg);
      }

      35% {
        transform: translateY(-3px) rotate(-2deg);
      }

      70% {
        transform: translateY(1px) rotate(2deg);
      }

      100% {
        transform: translateY(0) rotate(0deg);
      }
    }

    @media (max-width: 980px) {
      .home-hero {
        grid-template-columns: 1fr;
      }

      .home-hero-visual {
        min-height: 320px;
      }

      .map-visual {
        min-height: 320px;
      }

      .home-app-layout {
        grid-template-columns: 1fr;
      }

      .filter-panel {
        position: static;
      }
    }

    @media (max-width: 760px) {
      .home-page {
        width: calc(100% - 24px);
        padding: 26px 0 52px;
      }

      .home-hero {
        padding: 22px;
        border-radius: 24px;
        min-height: auto;
      }

      .home-hero h1 {
        font-size: 34px;
      }

      .map-visual {
        min-height: 280px;
        border-radius: 22px;
        background-size: 28px 28px, 28px 28px, auto, auto;
      }

      .map-badge {
        padding: 8px 11px;
      }

      .map-badge strong {
        font-size: 20px;
      }

      .badge-spots {
        left: 14px;
        top: 16px;
      }

      .badge-works {
        right: 14px;
        top: 28px;
      }

      .badge-areas {
        left: 28%;
        bottom: 16px;
      }

      .mobile-filter-toggle {
        width: 100%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        margin-bottom: 10px;
        border: 1px solid var(--border);
        border-radius: 16px;
        background: #ffffff;
        color: var(--text);
        box-shadow: var(--shadow);
        font-weight: 900;
      }

      .filter-panel .filter-card {
        display: none;
      }

      .filter-panel.filter-open .filter-card {
        display: block;
        animation: contentFadeUp 0.26s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .filter-panel.filter-open .mobile-filter-toggle {
        background: var(--accent);
        color: #ffffff;
        border-color: var(--accent);
      }

      .home-section-header {
        display: block;
        padding: 20px;
        border-radius: 24px;
      }

      .home-section-header h2 {
        font-size: 26px;
      }

      .section-link {
        width: 100%;
        margin-top: 16px;
      }

      .work-grid {
        grid-template-columns: 1fr;
      }

      .work-card {
        min-height: auto;
      }

      .work-card-top {
        display: block;
      }

      .work-card h3 {
        min-height: auto;
        font-size: 19px;
      }

      .work-meta {
        min-height: auto;
      }

      .status-pill {
        display: inline-flex;
        margin-top: 14px;
      }

      .work-card-foot {
        display: block;
      }

      .card-link {
        display: inline-flex;
        margin-top: 8px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      *,
      *::before,
      *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
        scroll-behavior: auto !important;
      }
    }
  </style>

  <script type="application/json" id="hero-map-spots" set:html={heroMapSpotsJson}></script>
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  <script>
    const heroMapElement = document.getElementById("home-hero-map");
    const heroMapDataElement = document.getElementById("hero-map-spots");
    const searchInput = document.getElementById("work-search");
    const regionButtons = Array.from(document.querySelectorAll("[data-region]"));
    const countButtons = Array.from(document.querySelectorAll("[data-count-filter]"));
    const resetButton = document.getElementById("filter-reset");
    const cards = Array.from(document.querySelectorAll(".work-card"));
    const countText = document.getElementById("work-result-count");
    const summary = document.getElementById("active-filter-summary");
    const emptyResult = document.getElementById("empty-result");
    const grid = document.getElementById("work-grid");
    const mobileFilterToggle = document.getElementById("mobile-filter-toggle");
    const filterPanel = document.querySelector(".filter-panel");

    let activeRegion = "all";
    let activeCount = "all";

    function escapeHtml(value) {
      return String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    function initHeroMap() {
      if (!heroMapElement || !heroMapDataElement || typeof L === "undefined") {
        return;
      }

      const previewSpots = JSON.parse(heroMapDataElement.textContent || "[]");

      if (!previewSpots.length) {
        return;
      }

      const map = L.map(heroMapElement, {
        zoomControl: false,
        scrollWheelZoom: false,
        dragging: false,
        touchZoom: false,
        doubleClickZoom: false,
        boxZoom: false,
        keyboard: false,
        tap: false,
      });

      L.tileLayer("https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png", {
        attribution: "&copy; OpenStreetMap &copy; CARTO",
        subdomains: "abcd",
        maxZoom: 20,
      }).addTo(map);

      const markerIcon = L.divIcon({
        className: "",
        html: '<span class="hero-map-marker"></span>',
        iconSize: [24, 24],
        iconAnchor: [12, 22],
        popupAnchor: [0, -18],
      });

      const bounds = [];

      previewSpots.forEach((spot) => {
        const latLng = [spot.lat, spot.lng];
        const popupHtml = `
          <div class="hero-map-popup">
            <strong>${escapeHtml(spot.name)}</strong>
            ${spot.work ? `<span>${escapeHtml(spot.work)}</span>` : ""}
            <a href="/map/">マップで見る</a>
          </div>
        `;

        L.marker(latLng, { icon: markerIcon })
          .addTo(map)
          .bindPopup(popupHtml);

        bounds.push(latLng);
      });

      map.fitBounds(bounds, {
        padding: [42, 42],
        maxZoom: 11,
      });

      map.on("click", () => {
        window.location.href = "/map/";
      });
    }

    function normalizeText(value) {
      return String(value || "").toLowerCase();
    }

    function animateCountUp(element, target, duration) {
      const endValue = Number(target || 0);
      const startTime = performance.now();

      function update(now) {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const value = Math.round(endValue * eased);

        element.textContent = String(value);

        if (progress < 1) {
          requestAnimationFrame(update);
        } else {
          element.textContent = String(endValue);
        }
      }

      requestAnimationFrame(update);
    }

    function setActiveButton(buttons, key, value) {
      buttons.forEach((button) => {
        if (button.dataset[key] === value) {
          button.classList.add("active");
        } else {
          button.classList.remove("active");
        }
      });
    }

    function triggerFilterMotion() {
      if (!grid) {
        return;
      }

      grid.classList.remove("filter-refreshing");

      void grid.offsetWidth;

      grid.classList.add("filter-refreshing");

      setTimeout(() => {
        grid.classList.remove("filter-refreshing");
      }, 300);
    }

    function renderSummary(keyword, visibleCount) {
      if (!summary) {
        return;
      }

      const labels = [];

      if (keyword) {
        labels.push(`検索: ${searchInput.value.trim()}`);
      }

      if (activeRegion !== "all") {
        labels.push(activeRegion);
      }

      if (activeCount === "has-spots") {
        labels.push("登録あり");
      }

      if (activeCount === "no-spots") {
        labels.push("未登録");
      }

      if (labels.length === 0) {
        summary.className = "active-filter-summary muted";
        summary.textContent = "すべての作品を表示中";
        return;
      }

      summary.className = "active-filter-summary";
      summary.innerHTML =
        '<span class="summary-label">絞り込み中</span>' +
        labels.map((label) => `<span class="summary-pill">${label}</span>`).join("") +
        `<span class="summary-pill">${visibleCount}件表示</span>`;
    }

    function applyFilters() {
      const keyword = normalizeText(searchInput?.value);
      let visibleCount = 0;

      cards.forEach((card) => {
        const title = normalizeText(card.dataset.title);
        const year = normalizeText(card.dataset.year);
        const prefectures = String(card.dataset.prefectures || "");
        const tags = String(card.dataset.tags || "");
        const spotCount = Number(card.dataset.count || 0);

        const keywordTarget = normalizeText([
          title,
          year,
          prefectures,
          tags,
        ].join(" "));

        const keywordMatch = !keyword || keywordTarget.includes(keyword);

        const regionMatch =
          activeRegion === "all" ||
          prefectures.split(",").includes(activeRegion);

        let countMatch = true;

        if (activeCount === "has-spots") {
          countMatch = spotCount > 0;
        }

        if (activeCount === "no-spots") {
          countMatch = spotCount === 0;
        }

        const isVisible = keywordMatch && regionMatch && countMatch;

        card.hidden = !isVisible;

        if (isVisible) {
          visibleCount += 1;
        }
      });

      if (countText) {
        countText.textContent = `${visibleCount}件の作品を表示中`;
      }

      if (emptyResult) {
        emptyResult.hidden = visibleCount !== 0;
      }

      renderSummary(keyword, visibleCount);
      triggerFilterMotion();
    }

    initHeroMap();

    document.querySelectorAll(".count-up").forEach((element) => {
      animateCountUp(element, Number(element.dataset.count || 0), 720);
    });

    searchInput?.addEventListener("input", applyFilters);

    regionButtons.forEach((button) => {
      button.addEventListener("click", () => {
        activeRegion = button.dataset.region || "all";
        setActiveButton(regionButtons, "region", activeRegion);
        applyFilters();
      });
    });

    countButtons.forEach((button) => {
      button.addEventListener("click", () => {
        activeCount = button.dataset.countFilter || "all";
        setActiveButton(countButtons, "countFilter", activeCount);
        applyFilters();
      });
    });

    resetButton?.addEventListener("click", () => {
      if (searchInput) {
        searchInput.value = "";
      }

      activeRegion = "all";
      activeCount = "all";

      setActiveButton(regionButtons, "region", "all");
      setActiveButton(countButtons, "countFilter", "all");

      applyFilters();
    });

    mobileFilterToggle?.addEventListener("click", () => {
      if (!filterPanel) {
        return;
      }

      filterPanel.classList.toggle("filter-open");

      const isOpen = filterPanel.classList.contains("filter-open");

      const label = mobileFilterToggle.querySelector("span");

      if (label) {
        label.textContent = isOpen ? "絞り込みを閉じる" : "絞り込みを開く";
      }
    });
  </script>
</BaseLayout>
