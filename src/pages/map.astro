---
import BaseLayout from "../layouts/BaseLayout.astro";
import { spots, works } from "../data/portalData.js";

const title = "マップから探す | Seichi Atlas";
const description = "Seichi Atlasの聖地マップです。アニメや漫画の聖地巡礼スポットを作品・地域・地図から探せます。";

function normalizeTags(tags) {
  if (Array.isArray(tags)) {
    return tags;
  }

  if (typeof tags === "string") {
    return tags
      .split(",")
      .map((tag) => tag.trim())
      .filter(Boolean);
  }

  return [];
}

function normalizeOfficialLevel(level) {
  if (level === "official") {
    return "official";
  }

  if (level === "tourism") {
    return "tourism";
  }

  return "fan";
}

function officialLabel(level) {
  if (level === "official") {
    return "公式";
  }

  if (level === "tourism") {
    return "観光協会";
  }

  return "ファン考察";
}

const mapSpots = spots
  .map((spot, index) => {
    const work = works.find((item) => item.slug === spot.workSlug);
    const lat = Number(spot.lat);
    const lng = Number(spot.lng);
    const officialLevel = normalizeOfficialLevel(spot.officialLevel);

    return {
      id: String(spot.id || index + 1),
      name: spot.name || "名称未登録",
      slug: spot.slug || "",
      work: spot.work || spot.workTitle || work?.title || "",
      workSlug: spot.workSlug || work?.slug || "",
      areaSlug: spot.areaSlug || "",
      prefecture: spot.prefecture || "",
      station: spot.station || "",
      lat,
      lng,
      officialLevel,
      officialLabel: officialLabel(officialLevel),
      tags: normalizeTags(spot.tags),
    };
  })
  .filter((spot) => Number.isFinite(spot.lat) && Number.isFinite(spot.lng));

const workOptions = [
  ...new Set(mapSpots.map((spot) => spot.work).filter(Boolean)),
];

const prefectureOptions = [
  ...new Set(mapSpots.map((spot) => spot.prefecture).filter(Boolean)),
];

const mapSpotsJson = JSON.stringify(mapSpots).replace(/</g, "\\u003c");
---

<BaseLayout title={title} description={description} canonical="/map/">
  <main class="map-page">
    <section class="map-shell" aria-label="聖地マップ">
      <div class="map-stage">
        <div id="map" aria-label="聖地スポット地図"></div>

        <button class="filter-panel-toggle" type="button" id="filter-panel-toggle" aria-expanded="false" aria-controls="map-filter-panel">
          <span aria-hidden="true">⌕</span>
          検索条件
        </button>

        <aside class="map-filter-panel" id="map-filter-panel" aria-label="スポット絞り込み">
          <div class="panel-head">
            <div class="map-title">
              <p>MAP</p>
              <h1>地図検索</h1>
            </div>

            <button class="panel-close" type="button" id="filter-panel-close" aria-label="絞り込みを閉じる">×</button>
          </div>

          <div class="filter-bar">
            <label class="filter-field keyword-field">
              <span>Search</span>
              <input
                id="map-search"
                type="search"
                placeholder="スポット名・作品名・地域"
                autocomplete="off"
              />
            </label>

            <div class="filter-menu" data-popover-root>
              <button class="filter-trigger" type="button" data-popover-trigger="work">
                <span>作品</span>
                <strong id="work-filter-label">すべて</strong>
              </button>
              <div class="filter-popover" id="work-popover" hidden>
                <button class="filter-option active" type="button" data-filter-option="work" data-value="all">すべて</button>
                {workOptions.map((workName) => (
                  <button class="filter-option" type="button" data-filter-option="work" data-value={workName}>
                    {workName}
                  </button>
                ))}
              </div>
            </div>

            <div class="filter-menu" data-popover-root>
              <button class="filter-trigger" type="button" data-popover-trigger="prefecture">
                <span>地域</span>
                <strong id="prefecture-filter-label">すべて</strong>
              </button>
              <div class="filter-popover" id="prefecture-popover" hidden>
                <button class="filter-option active" type="button" data-filter-option="prefecture" data-value="all">すべて</button>
                {prefectureOptions.map((prefecture) => (
                  <button class="filter-option" type="button" data-filter-option="prefecture" data-value={prefecture}>
                    {prefecture}
                  </button>
                ))}
              </div>
            </div>

            <label class="filter-field station-field">
              <span>駅</span>
              <input
                id="station-search"
                type="search"
                placeholder="最寄駅"
                autocomplete="off"
              />
            </label>

            <div class="filter-menu" data-popover-root>
              <button class="filter-trigger" type="button" data-popover-trigger="official">
                <span>関連</span>
                <strong id="official-filter-label">すべて</strong>
              </button>
              <div class="filter-popover" id="official-popover" hidden>
                <button class="filter-option active" type="button" data-filter-option="official" data-value="all">すべて</button>
                <button class="filter-option" type="button" data-filter-option="official" data-value="official">公式</button>
                <button class="filter-option" type="button" data-filter-option="official" data-value="tourism">観光協会</button>
                <button class="filter-option" type="button" data-filter-option="official" data-value="fan">ファン考察</button>
              </div>
            </div>

            <button class="reset-button" type="button" id="filter-reset">リセット</button>
          </div>

          <div class="panel-railway-row">
            <button class="railway-toggle" type="button" id="railway-toggle" aria-pressed="false">
              路線
            </button>
          </div>
        </aside>

        <div class="map-toolbar" aria-label="地図表示設定">
          <div class="tile-switch" role="group" aria-label="地図表示">
            <button class="tile-button active" type="button" data-map-style="light">淡色</button>
            <button class="tile-button" type="button" data-map-style="standard">標準</button>
            <button class="tile-button" type="button" data-map-style="black">黒</button>
          </div>
        </div>

        <div class="map-result-pill" id="result-count">
          {mapSpots.length}件
        </div>

        <button class="fit-button" type="button" id="fit-visible-button">
          全体表示
        </button>

        <div class="map-empty-overlay" id="map-empty-overlay" hidden>
          <div>
            <h2>該当なし</h2>
            <p>条件を変えてください。</p>
          </div>
        </div>

        <article class="selected-card" id="selected-card" hidden>
          <button class="selected-close" type="button" id="selected-close" aria-label="選択を閉じる">×</button>
          <h2 id="selected-name"></h2>
          <p id="selected-work"></p>
          <dl>
            <div>
              <dt>都道府県</dt>
              <dd id="selected-prefecture"></dd>
            </div>
            <div>
              <dt>最寄駅</dt>
              <dd id="selected-station"></dd>
            </div>
          </dl>
          <a class="selected-link" id="selected-link" href="/spots/">詳細を見る</a>
        </article>
      </div>
    </section>

    <script type="application/json" id="map-data" set:html={mapSpotsJson}></script>
  </main>

  <style is:global>
    .map-page {
      width: calc(100% - 24px);
      max-width: 1920px;
      margin: 0 auto;
      padding: 14px 0 24px;
    }

    .map-shell {
      display: grid;
      min-height: calc(100vh - 120px);
    }

    .panel-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 14px;
      margin-bottom: 18px;
    }

    .map-title {
      min-width: 0;
    }

    .map-title p {
      margin: 0;
      color: var(--accent-dark);
      font-size: 11px;
      font-weight: 950;
      letter-spacing: 0.08em;
    }

    .map-title h1 {
      margin: 2px 0 0;
      color: var(--text);
      font-size: 22px;
      line-height: 1.25;
      letter-spacing: -0.03em;
    }

    .filter-bar {
      display: grid;
      gap: 10px;
    }

    .filter-field,
    .filter-trigger {
      position: relative;
      display: flex;
      align-items: center;
      min-width: 0;
      min-height: 44px;
      border: 1px solid var(--border-soft);
      border-radius: 14px;
      background: var(--card-subtle);
      transition: border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
    }

    .filter-field span,
    .filter-trigger span {
      flex: 0 0 auto;
      padding-left: 13px;
      color: var(--accent-dark);
      font-size: 10px;
      font-weight: 950;
      letter-spacing: 0.04em;
    }

    .filter-field input {
      width: 100%;
      min-width: 0;
      min-height: 42px;
      border: 0;
      border-radius: 14px;
      padding: 8px 12px 8px 8px;
      outline: none;
      background: transparent;
      color: var(--text);
      font-size: 13px;
      font-weight: 750;
    }

    .filter-trigger {
      width: 100%;
      justify-content: space-between;
      gap: 8px;
      padding: 0 11px 0 0;
      cursor: pointer;
      font: inherit;
    }

    .filter-trigger strong {
      min-width: 0;
      overflow: hidden;
      color: var(--text);
      font-size: 13px;
      font-weight: 850;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .filter-trigger::after {
      content: "";
      flex: 0 0 auto;
      width: 7px;
      height: 7px;
      border-right: 2px solid var(--muted);
      border-bottom: 2px solid var(--muted);
      transform: translateY(-2px) rotate(45deg);
    }

    .filter-field:focus-within,
    .filter-menu.open .filter-trigger {
      border-color: var(--accent);
      background: #ffffff;
      box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.14);
    }

    .keyword-field {
      min-height: 48px;
      background: #ffffff;
      border-color: rgba(14, 165, 233, 0.32);
      box-shadow: inset 0 0 0 1px rgba(14, 165, 233, 0.04);
    }

    .keyword-field input {
      min-height: 46px;
      font-size: 14px;
      font-weight: 800;
    }

    .filter-menu {
      position: relative;
      min-width: 0;
    }

    .filter-popover {
      position: absolute;
      z-index: 900;
      top: calc(100% + 8px);
      left: 0;
      width: 100%;
      min-width: 240px;
      max-height: 330px;
      overflow-y: auto;
      padding: 8px;
      border: 1px solid var(--border-soft);
      border-radius: 16px;
      background: #ffffff;
      box-shadow: 0 20px 48px rgba(15, 23, 42, 0.16);
    }

    .filter-menu:nth-last-of-type(-n+2) .filter-popover {
      right: auto;
      left: 0;
    }

    .filter-popover[hidden] {
      display: none;
    }

    .filter-option {
      width: 100%;
      min-height: 36px;
      border: 0;
      border-radius: 11px;
      padding: 8px 10px;
      background: transparent;
      color: var(--text);
      cursor: pointer;
      font-size: 13px;
      font-weight: 800;
      text-align: left;
    }

    .filter-option:hover,
    .filter-option.active {
      background: var(--accent-soft);
      color: var(--accent-dark);
    }

    .reset-button,
    .fit-button,
    .tile-button,
    .railway-toggle {
      min-height: 38px;
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 8px 13px;
      background: #ffffff;
      color: var(--text);
      cursor: pointer;
      font-size: 12px;
      font-weight: 900;
      white-space: nowrap;
      transition: transform 0.16s ease, background 0.16s ease, color 0.16s ease, border-color 0.16s ease;
    }

    .reset-button:hover,
    .fit-button:hover,
    .tile-button:hover,
    .railway-toggle:hover {
      transform: translateY(-1px);
      border-color: var(--accent-soft);
      background: var(--accent-soft);
      color: var(--accent-dark);
    }

    .reset-button {
      min-height: 40px;
      border-color: transparent;
      background: transparent;
      color: var(--muted);
      padding-inline: 10px;
      justify-self: start;
    }

    .map-toolbar {
      position: absolute;
      z-index: 660;
      top: 14px;
      right: 14px;
    }

    .tile-switch {
      display: inline-flex;
      gap: 3px;
      padding: 3px;
      border: 1px solid var(--border-soft);
      border-radius: 999px;
      background: var(--card-subtle);
    }

    .tile-button {
      min-height: 32px;
      border-color: transparent;
      padding: 7px 11px;
      background: transparent;
      color: var(--sub);
    }

    .tile-button.active {
      background: var(--accent);
      color: #ffffff;
      box-shadow: 0 8px 20px rgba(14, 165, 233, 0.22);
    }

    .railway-toggle {
      position: relative;
      min-height: 36px;
      border-color: var(--border-soft);
      padding: 7px 12px 7px 30px;
      background: var(--card-subtle);
      color: var(--sub);
    }

    .railway-toggle::before {
      content: "";
      position: absolute;
      left: 10px;
      top: 50%;
      width: 13px;
      height: 13px;
      border-radius: 999px;
      background: #cbd5e1;
      transform: translateY(-50%);
      box-shadow: inset 0 0 0 2px #ffffff;
    }

    .railway-toggle.active {
      background: var(--accent-soft);
      color: var(--accent-dark);
    }

    .railway-toggle.active::before {
      background: var(--accent);
    }

    .map-stage {
      position: relative;
      height: calc(100vh - 128px);
      min-height: 640px;
      overflow: hidden;
      border: 1px solid var(--border-soft);
      border-radius: 24px;
      background: #dbeafe;
      box-shadow: 0 18px 44px rgba(15, 23, 42, 0.11);
    }

    .filter-panel-toggle {
      position: absolute;
      z-index: 720;
      top: 18px;
      left: 18px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      height: 44px;
      border: 1px solid var(--border-soft);
      border-radius: 14px;
      padding: 0 16px 0 12px;
      background: rgba(255, 255, 255, 0.97);
      color: var(--text);
      cursor: pointer;
      font-size: 13px;
      font-weight: 950;
      letter-spacing: 0.04em;
      box-shadow: 0 14px 34px rgba(15, 23, 42, 0.2);
      backdrop-filter: blur(12px);
      transition: transform 0.2s ease, background 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;
    }

    .filter-panel-toggle span {
      display: inline-grid;
      place-items: center;
      width: 18px;
      height: 18px;
      border-radius: 8px;
      background: var(--accent-soft);
      color: var(--accent-dark);
      font-size: 13px;
      line-height: 1;
    }

    .filter-panel-toggle:hover {
      transform: translateY(-1px);
      background: var(--accent);
      color: #ffffff;
      box-shadow: 0 18px 40px rgba(14, 165, 233, 0.24);
    }

    .filter-panel-toggle:hover span {
      background: rgba(255, 255, 255, 0.22);
      color: #ffffff;
    }

    .filter-panel-toggle.has-active-filter::after {
      content: "";
      position: absolute;
      top: 7px;
      right: 7px;
      width: 8px;
      height: 8px;
      border: 2px solid #ffffff;
      border-radius: 999px;
      background: var(--accent);
      box-shadow: 0 4px 10px rgba(14, 165, 233, 0.32);
    }

    .map-stage.filter-open .filter-panel-toggle {
      transform: translateX(318px);
      background: var(--accent);
      color: #ffffff;
      box-shadow: 0 18px 40px rgba(14, 165, 233, 0.24);
    }

    .map-stage.filter-open .filter-panel-toggle span {
      background: rgba(255, 255, 255, 0.22);
      color: #ffffff;
    }

    .map-filter-panel {
      position: absolute;
      z-index: 710;
      top: 14px;
      bottom: 14px;
      left: 14px;
      width: 320px;
      max-width: calc(100% - 28px);
      overflow: visible;
      padding: 20px;
      border: 1px solid var(--border-soft);
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 24px 70px rgba(15, 23, 42, 0.22);
      backdrop-filter: blur(16px);
      transform: translateX(calc(-100% - 28px));
      transition: transform 0.28s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .map-stage.filter-open .map-filter-panel {
      transform: translateX(0);
    }

    .panel-close {
      flex: 0 0 auto;
      width: 34px;
      height: 34px;
      border: 1px solid var(--border);
      border-radius: 12px;
      background: #ffffff;
      color: var(--sub);
      cursor: pointer;
      font-size: 18px;
      font-weight: 900;
      line-height: 1;
    }

    .panel-railway-row {
      margin-top: 14px;
      padding-top: 14px;
      border-top: 1px solid var(--border-soft);
    }

    .map-stage.map-dark {
      background: #020617;
      border-color: #1e293b;
    }

    #map {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      min-height: 0;
      background: #e2e8f0;
    }

    .map-result-pill,
    .fit-button {
      position: absolute;
      z-index: 650;
    }

    .map-result-pill {
      top: 72px;
      left: 18px;
      display: inline-flex;
      align-items: center;
      min-height: 34px;
      padding: 7px 13px;
      border: 1px solid var(--border-soft);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.94);
      color: var(--text);
      font-size: 13px;
      font-weight: 950;
      box-shadow: 0 12px 28px rgba(15, 23, 42, 0.12);
      backdrop-filter: blur(10px);
    }

    .fit-button {
      right: 14px;
      top: 62px;
      box-shadow: 0 12px 28px rgba(15, 23, 42, 0.12);
      backdrop-filter: blur(10px);
    }

    .map-empty-overlay {
      position: absolute;
      z-index: 640;
      inset: 0;
      display: grid;
      place-items: center;
      pointer-events: none;
    }

    .map-empty-overlay[hidden] {
      display: none;
    }

    .map-empty-overlay > div {
      padding: 18px 22px;
      border: 1px solid var(--border-soft);
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.92);
      text-align: center;
      box-shadow: 0 18px 42px rgba(15, 23, 42, 0.16);
      backdrop-filter: blur(10px);
    }

    .map-empty-overlay h2 {
      margin: 0 0 4px;
      border: 0;
      padding: 0;
      color: var(--text);
      font-size: 18px;
    }

    .map-empty-overlay p {
      margin: 0;
      color: var(--sub);
      font-size: 13px;
      font-weight: 750;
    }

    .selected-card {
      position: absolute;
      z-index: 700;
      left: 18px;
      bottom: 18px;
      width: min(360px, calc(100% - 36px));
      padding: 20px;
      border: 1px solid var(--border-soft);
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 24px 60px rgba(15, 23, 42, 0.2);
      backdrop-filter: blur(14px);
      animation: selectedCardIn 0.22s ease-out;
    }

    .selected-card[hidden] {
      display: none;
    }

    .selected-close {
      position: absolute;
      top: 10px;
      right: 10px;
      width: 32px;
      height: 32px;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: #ffffff;
      color: var(--sub);
      cursor: pointer;
      font-size: 18px;
      font-weight: 800;
      line-height: 1;
    }

    .selected-card h2 {
      margin: 0;
      padding: 0 34px 0 0;
      border: 0;
      color: var(--text);
      font-size: 20px;
      line-height: 1.45;
      letter-spacing: -0.02em;
    }

    .selected-card p {
      margin: 6px 0 14px;
      color: var(--accent-dark);
      font-size: 13px;
      font-weight: 900;
    }

    .selected-card dl {
      display: grid;
      gap: 8px;
      margin: 0;
    }

    .selected-card dl div {
      display: flex;
      justify-content: space-between;
      gap: 14px;
      padding-top: 8px;
      border-top: 1px solid var(--border-soft);
    }

    .selected-card dt {
      color: var(--muted);
      font-size: 12px;
      font-weight: 900;
    }

    .selected-card dd {
      margin: 0;
      color: var(--text);
      font-size: 13px;
      font-weight: 800;
      text-align: right;
    }

    .selected-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      min-height: 40px;
      margin-top: 16px;
      border-radius: 14px;
      background: var(--accent);
      color: #ffffff;
      font-size: 13px;
      font-weight: 950;
    }

    .work-pin-wrap {
      position: relative;
      display: grid;
      place-items: center;
      width: 32px;
      height: 32px;
      z-index: 1;
    }

    .work-pin-wrap.selected {
      width: 42px;
      height: 42px;
    }

    .work-pin {
      position: relative;
      width: 22px;
      height: 22px;
      border: 4px solid #ffffff;
      border-radius: 50% 50% 50% 0;
      background: var(--pin-color, var(--accent));
      box-shadow:
        0 0 0 2px rgba(2, 6, 23, 0.2),
        0 0 0 1px rgba(15, 23, 42, 0.12),
        0 10px 22px rgba(15, 23, 42, 0.28);
      transform: rotate(-45deg);
      transition: transform 0.18s ease, box-shadow 0.18s ease, border-width 0.18s ease;
    }

    .work-pin::after {
      content: "";
      position: absolute;
      inset: 5px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.9);
    }

    .work-pin.selected {
      width: 32px;
      height: 32px;
      border-width: 5px;
      box-shadow:
        0 0 0 7px rgba(255, 255, 255, 0.55),
        0 16px 34px rgba(15, 23, 42, 0.32);
    }

    .work-marker {
      background: transparent;
      border: 0;
      overflow: visible;
      cursor: pointer;
      transform-origin: center bottom;
      z-index: 610;
    }

    .work-marker.selected-marker {
      z-index: 680;
    }

    .maplibregl-ctrl-attrib {
      font-size: 10px;
    }

    @keyframes selectedCardIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 1180px) {
      .map-stage.filter-open .filter-panel-toggle {
        transform: translateX(318px);
      }
    }

    @media (max-width: 760px) {
      .map-page {
        width: calc(100% - 16px);
        padding: 10px 0 18px;
      }

      .map-shell {
        min-height: calc(100vh - 100px);
      }

      .map-title h1 {
        font-size: 22px;
      }

      .filter-bar {
        display: grid;
        gap: 9px;
      }

      .map-filter-panel {
        top: 10px;
        bottom: 10px;
        left: 10px;
        width: min(90vw, 360px);
        max-width: 90vw;
        padding: 18px;
      }

      .filter-panel-toggle {
        top: 12px;
        left: 12px;
      }

      .map-stage.filter-open .filter-panel-toggle {
        transform: translateX(calc(min(90vw, 360px) + 8px));
      }

      .map-toolbar {
        top: 10px;
        right: 10px;
      }

      .tile-button {
        min-height: 30px;
        padding: 6px 9px;
        font-size: 11px;
      }

      .map-stage {
        height: 70vh;
        min-height: 520px;
        border-radius: 20px;
      }

      #map {
        height: 100%;
        min-height: 0;
      }

      .map-result-pill {
        top: 62px;
        left: 12px;
      }

      .fit-button {
        top: 54px;
        right: 10px;
      }

      .selected-card {
        left: 8px;
        right: 8px;
        bottom: 8px;
        width: auto;
        padding: 18px;
        border-radius: 20px 20px 18px 18px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      *,
      *::before,
      *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
        scroll-behavior: auto !important;
      }
    }
  </style>

  <script>
    import maplibregl from "maplibre-gl";
    import "maplibre-gl/dist/maplibre-gl.css";

    const mapDataElement = document.getElementById("map-data");
    const locations = JSON.parse(mapDataElement?.textContent || "[]");

    const searchInput = document.getElementById("map-search");
    const stationInput = document.getElementById("station-search");
    const workFilterLabel = document.getElementById("work-filter-label");
    const prefectureFilterLabel = document.getElementById("prefecture-filter-label");
    const officialFilterLabel = document.getElementById("official-filter-label");
    const popoverTriggers = Array.from(document.querySelectorAll("[data-popover-trigger]"));
    const popovers = Array.from(document.querySelectorAll(".filter-popover"));
    const filterOptions = Array.from(document.querySelectorAll("[data-filter-option]"));
    const resetButton = document.getElementById("filter-reset");
    const fitVisibleButton = document.getElementById("fit-visible-button");
    const railwayToggle = document.getElementById("railway-toggle");
    const tileButtons = Array.from(document.querySelectorAll("[data-map-style]"));
    const mapStage = document.querySelector(".map-stage");
    const filterPanelToggle = document.getElementById("filter-panel-toggle");
    const filterPanelClose = document.getElementById("filter-panel-close");
    const resultCount = document.getElementById("result-count");
    const emptyOverlay = document.getElementById("map-empty-overlay");
    const selectedCard = document.getElementById("selected-card");
    const selectedClose = document.getElementById("selected-close");
    const selectedName = document.getElementById("selected-name");
    const selectedWork = document.getElementById("selected-work");
    const selectedPrefecture = document.getElementById("selected-prefecture");
    const selectedStation = document.getElementById("selected-station");
    const selectedLink = document.getElementById("selected-link");

    const urlParams = new URLSearchParams(window.location.search);
    const initialSpotSlug = urlParams.get("spot") || "";
    const initialWorkSlug = urlParams.get("work") || "";
    const initialAreaSlug = urlParams.get("area") || "";
    const kantoCenter = [139.55, 35.60];

    const colorPalette = [
      "#0ea5e9",
      "#22c55e",
      "#f97316",
      "#8b5cf6",
      "#ec4899",
      "#14b8a6",
      "#eab308",
      "#ef4444",
      "#6366f1",
      "#06b6d4",
      "#84cc16",
    ];

    const tileConfigs = {
      light: {
        style: "https://tiles.openfreemap.org/styles/positron",
      },
      standard: {
        style: "https://tiles.openfreemap.org/styles/liberty",
      },
      black: {
        style: "https://tiles.openfreemap.org/styles/dark",
      },
    };

    let mapInstance = null;
    let currentMapStyle = "light";
    let railwayGeoJson = null;
    let railwayLoadAttempted = false;
    let railwayVisible = false;
    let markerMap = {};
    let selectedSpotId = "";
    let currentFilteredLocations = locations;
    let activeAreaSlug = initialAreaSlug;
    let selectedWorkValue = "all";
    let selectedPrefectureValue = "all";
    let selectedOfficialValue = "all";
    let pinchZoomSetupDone = false;

    function escapeHtml(value) {
      return String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    function normalizeText(value) {
      return String(value || "").toLowerCase();
    }

    function detailUrl(location) {
      return location.slug ? "/spots/" + location.slug + "/" : "/spots/";
    }

    function workColor(location) {
      const key = String(location.workSlug || location.work || "unknown");
      let hash = 0;

      for (let index = 0; index < key.length; index += 1) {
        hash = (hash * 31 + key.charCodeAt(index)) % 9973;
      }

      return colorPalette[hash % colorPalette.length];
    }

    function createMarkerElement(location, isSelected) {
      const color = workColor(location);
      const element = document.createElement("div");
      const pinWrap = document.createElement("div");
      const pin = document.createElement("div");

      element.className = "work-marker" + (isSelected ? " selected-marker" : "");
      pinWrap.className = "work-pin-wrap" + (isSelected ? " selected" : "");
      pin.className = "work-pin" + (isSelected ? " selected" : "");
      pin.style.setProperty("--pin-color", color);

      pinWrap.appendChild(pin);
      element.appendChild(pinWrap);

      return element;
    }

    function setMarkerSelected(markerEntry, isSelected) {
      if (!markerEntry) {
        return;
      }

      const element = markerEntry.element;
      const pinWrap = element.querySelector(".work-pin-wrap");
      const pin = element.querySelector(".work-pin");

      element.classList.toggle("selected-marker", isSelected);
      pinWrap?.classList.toggle("selected", isSelected);
      pin?.classList.toggle("selected", isSelected);
    }

    function setupPinchZoomOnly() {
      if (!mapInstance || pinchZoomSetupDone) {
        return;
      }

      const canvasContainer = mapInstance.getCanvasContainer();

      if (!canvasContainer) {
        return;
      }

      pinchZoomSetupDone = true;

      canvasContainer.addEventListener("wheel", (event) => {
        if (!event.ctrlKey && !event.metaKey) {
          return;
        }

        event.preventDefault();

        const currentZoom = mapInstance.getZoom();
        const zoomDelta = Math.max(-0.75, Math.min(0.75, -event.deltaY * 0.014));
        const nextZoom = Math.max(
          mapInstance.getMinZoom(),
          Math.min(mapInstance.getMaxZoom(), currentZoom + zoomDelta)
        );
        const rect = canvasContainer.getBoundingClientRect();
        const point = [
          event.clientX - rect.left,
          event.clientY - rect.top,
        ];
        const around = mapInstance.unproject(point);

        mapInstance.easeTo({
          zoom: nextZoom,
          around,
          duration: 40,
          easing: (t) => t,
        });
      }, {
        passive: false,
      });
    }

    function setMapStyle(style) {
      if (!mapInstance || !tileConfigs[style]) {
        return;
      }

      currentMapStyle = style;
      mapInstance.setStyle(tileConfigs[style].style);

      tileButtons.forEach((button) => {
        button.classList.toggle("active", button.dataset.mapStyle === style);
      });

      if (mapStage) {
        mapStage.classList.toggle("map-dark", style === "black");
      }
    }

    function railwayStyle() {
      return currentMapStyle === "black" ? "#a855f7" : "#111827";
    }

    function isRailwayBaseLayer(layer) {
      if (!layer || layer.type !== "line") {
        return false;
      }

      const id = String(layer.id || "").toLowerCase();
      const sourceLayer = String(layer["source-layer"] || "").toLowerCase();
      const text = id + " " + sourceLayer;
      const strongRailMatch =
        text.includes("rail") ||
        text.includes("railway") ||
        text.includes("train");

      if (strongRailMatch) {
        return true;
      }

      const transitMatch =
        text.includes("transit") ||
        text.includes("transportation") ||
        text.includes("transport");

      return transitMatch && !text.includes("road") && !text.includes("highway") && !text.includes("street");
    }

    function applyRailwayPaint() {
      if (!mapInstance || !mapInstance.isStyleLoaded()) {
        return;
      }

      const layers = mapInstance.getStyle().layers || [];
      const railwayColor = railwayStyle();
      const railwayWidth = currentMapStyle === "black" ? 2.8 : 2.4;

      layers
        .filter(isRailwayBaseLayer)
        .forEach((layer) => {
          try {
            mapInstance.setPaintProperty(layer.id, "line-color", railwayColor);
            mapInstance.setPaintProperty(layer.id, "line-opacity", 0.82);
            mapInstance.setPaintProperty(layer.id, "line-width", railwayWidth);
          } catch (error) {
            // Some style layers may not accept direct paint overrides; ignore quietly.
          }
        });
    }

    function updateRailwayStyle() {
      if (mapInstance?.getLayer("railways-line")) {
        mapInstance.setPaintProperty("railways-line", "line-color", railwayStyle());
        mapInstance.setPaintProperty("railways-line", "line-width", currentMapStyle === "black" ? 3.2 : 2.8);
      }

      applyRailwayPaint();
    }

    async function ensureRailwayLayer() {
      if (!mapInstance || railwayGeoJson || railwayLoadAttempted) {
        return;
      }

      railwayLoadAttempted = true;

      try {
        const response = await fetch("/railways/railways-lite.geojson", {
          cache: "force-cache",
        });

        if (!response.ok) {
          return;
        }

        railwayGeoJson = await response.json();
      } catch (error) {
        railwayGeoJson = null;
      }
    }

    function addRailwaySourceAndLayer() {
      if (!mapInstance || !railwayGeoJson || !railwayVisible || !mapInstance.isStyleLoaded()) {
        return;
      }

      if (!mapInstance.getSource("railways")) {
        mapInstance.addSource("railways", {
          type: "geojson",
          data: railwayGeoJson,
        });
      }

      if (!mapInstance.getLayer("railways-line")) {
        mapInstance.addLayer({
          id: "railways-line",
          type: "line",
          source: "railways",
          paint: {
            "line-color": railwayStyle(),
            "line-width": currentMapStyle === "black" ? 3.2 : 2.8,
            "line-opacity": 0.82,
          },
          layout: {
            "line-cap": "round",
            "line-join": "round",
          },
        });
      }

      updateRailwayStyle();
    }

    async function setRailwayVisible(isVisible) {
      if (!mapInstance) {
        return;
      }

      railwayVisible = isVisible;

      if (isVisible) {
        await ensureRailwayLayer();
        addRailwaySourceAndLayer();
        return;
      }

      if (mapInstance.getLayer("railways-line")) {
        mapInstance.removeLayer("railways-line");
      }

      if (mapInstance.getSource("railways")) {
        mapInstance.removeSource("railways");
      }
    }

    function fitMapToLocations(items, options = {}) {
      if (!mapInstance || !items.length) {
        return;
      }

      const points = items
        .map((location) => [location.lng, location.lat])
        .filter((point) => Number.isFinite(point[0]) && Number.isFinite(point[1]));

      if (!points.length) {
        return;
      }

      if (points.length === 1) {
        mapInstance.flyTo({
          center: points[0],
          zoom: options.singleZoom || 14,
          duration: 500,
        });
        return;
      }

      const bounds = points.reduce((nextBounds, point) => {
        return nextBounds.extend(point);
      }, new maplibregl.LngLatBounds(points[0], points[0]));

      mapInstance.fitBounds(bounds, {
        padding: options.padding || 80,
        maxZoom: options.maxZoom || 13,
        duration: 500,
      });
    }

    function fitInitialKantoView() {
      if (!mapInstance) {
        return;
      }

      mapInstance.jumpTo({
        center: kantoCenter,
        zoom: 8,
      });
    }

    function renderSelectedCard(location) {
      if (!selectedCard || !location) {
        return;
      }

      selectedName.textContent = location.name || "名称未登録";
      selectedWork.textContent = location.work || "作品名未登録";
      selectedPrefecture.textContent = location.prefecture || "未登録";
      selectedStation.textContent = location.station || "未登録";
      selectedLink.href = detailUrl(location);
      selectedCard.hidden = false;
    }

    function updateMarkerSelection() {
      Object.keys(markerMap).forEach((id) => {
        const marker = markerMap[id];
        const location = locations.find((item) => String(item.id) === id);

        if (!marker || !location) {
          return;
        }

        setMarkerSelected(marker, id === selectedSpotId);
      });
    }

    function selectSpot(locationId, shouldMove = true) {
      const id = String(locationId || "");
      const location = locations.find((item) => String(item.id) === id);
      const markerEntry = markerMap[id];

      if (!location || !markerEntry || !mapInstance) {
        return;
      }

      selectedSpotId = id;
      updateMarkerSelection();
      renderSelectedCard(location);

      if (shouldMove) {
        mapInstance.flyTo({
          center: [location.lng, location.lat],
          zoom: Math.max(mapInstance.getZoom(), 14),
          duration: 450,
        });
      }
    }

    function clearSelectedSpot() {
      selectedSpotId = "";

      if (selectedCard) {
        selectedCard.hidden = true;
      }

      updateMarkerSelection();
    }

    function syncMarkers(filtered) {
      if (!mapInstance) {
        return;
      }

      const visibleMap = {};

      filtered.forEach((location) => {
        visibleMap[String(location.id)] = true;
      });

      Object.keys(markerMap).forEach((id) => {
        const markerEntry = markerMap[id];

        if (!markerEntry) {
          return;
        }

        if (visibleMap[id]) {
          if (!markerEntry.visible) {
            markerEntry.marker.addTo(mapInstance);
            markerEntry.visible = true;
          }
        } else if (markerEntry.visible) {
          markerEntry.marker.remove();
          markerEntry.visible = false;
        }
      });

      if (selectedSpotId && !visibleMap[selectedSpotId]) {
        clearSelectedSpot();
      }
    }

    function updateResultCount(count) {
      if (resultCount) {
        resultCount.textContent = count + "件";
      }

      if (emptyOverlay) {
        emptyOverlay.hidden = count !== 0;
      }
    }

    function officialDisplayName(value) {
      if (value === "official") {
        return "公式";
      }

      if (value === "tourism") {
        return "観光協会";
      }

      if (value === "fan") {
        return "ファン考察";
      }

      return "すべて";
    }

    function updateFilterLabels() {
      if (workFilterLabel) {
        workFilterLabel.textContent = selectedWorkValue === "all" ? "すべて" : selectedWorkValue;
      }

      if (prefectureFilterLabel) {
        prefectureFilterLabel.textContent = selectedPrefectureValue === "all" ? "すべて" : selectedPrefectureValue;
      }

      if (officialFilterLabel) {
        officialFilterLabel.textContent = officialDisplayName(selectedOfficialValue);
      }
    }

    function updateOptionStates() {
      filterOptions.forEach((option) => {
        const type = option.dataset.filterOption;
        let value = "all";

        if (type === "work") {
          value = selectedWorkValue;
        }

        if (type === "prefecture") {
          value = selectedPrefectureValue;
        }

        if (type === "official") {
          value = selectedOfficialValue;
        }

        option.classList.toggle("active", option.dataset.value === value);
      });
    }

    function updateFilterToggleState() {
      if (!filterPanelToggle) {
        return;
      }

      const hasActiveFilter =
        Boolean(searchInput?.value.trim()) ||
        Boolean(stationInput?.value.trim()) ||
        selectedWorkValue !== "all" ||
        selectedPrefectureValue !== "all" ||
        selectedOfficialValue !== "all";

      filterPanelToggle.classList.toggle("has-active-filter", hasActiveFilter);
    }

    function closePopovers(exceptType = "") {
      popovers.forEach((popover) => {
        if (exceptType && popover.id === exceptType + "-popover") {
          return;
        }

        popover.hidden = true;
      });

      popoverTriggers.forEach((trigger) => {
        const isOpen = exceptType && trigger.dataset.popoverTrigger === exceptType;
        trigger.closest(".filter-menu")?.classList.toggle("open", Boolean(isOpen));
        trigger.setAttribute("aria-expanded", isOpen ? "true" : "false");
      });
    }

    function togglePopover(type) {
      const popover = document.getElementById(type + "-popover");

      if (!popover) {
        return;
      }

      const willOpen = popover.hidden;
      closePopovers(willOpen ? type : "");
      popover.hidden = !willOpen;
    }

    function setFilterValue(type, value) {
      if (type === "work") {
        selectedWorkValue = value || "all";
      }

      if (type === "prefecture") {
        selectedPrefectureValue = value || "all";
      }

      if (type === "official") {
        selectedOfficialValue = value || "all";
      }

      updateFilterLabels();
      updateOptionStates();
      updateFilterToggleState();
      closePopovers();
      applyFilters({ fit: true });
    }

    function setFilterPanelOpen(isOpen) {
      if (!mapStage || !filterPanelToggle) {
        return;
      }

      mapStage.classList.toggle("filter-open", isOpen);
      filterPanelToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");

      if (mapInstance) {
        setTimeout(() => {
          mapInstance.resize();
        }, 300);
      }
    }

    function toggleFilterPanel() {
      const isOpen = mapStage?.classList.contains("filter-open") || false;
      setFilterPanelOpen(!isOpen);
    }

    function applyFilters(options = {}) {
      const shouldFit = options.fit === true;
      const keyword = normalizeText(searchInput?.value);
      const stationKeyword = normalizeText(stationInput?.value);
      const selectedWork = selectedWorkValue;
      const selectedPrefecture = selectedPrefectureValue;
      const selectedOfficial = selectedOfficialValue;

      const filtered = locations.filter((location) => {
        const keywordTarget = normalizeText([
          location.name,
          location.work,
          location.prefecture,
          location.station,
          (location.tags || []).join(" "),
        ].join(" "));
        const stationTarget = normalizeText(location.station);

        const keywordMatch = !keyword || keywordTarget.includes(keyword);
        const stationMatch = !stationKeyword || stationTarget.includes(stationKeyword);
        const workMatch = selectedWork === "all" || location.work === selectedWork;
        const prefectureMatch = selectedPrefecture === "all" || location.prefecture === selectedPrefecture;
        const officialMatch = selectedOfficial === "all" || location.officialLevel === selectedOfficial;
        const areaMatch = !activeAreaSlug || location.areaSlug === activeAreaSlug;

        return keywordMatch && stationMatch && workMatch && prefectureMatch && officialMatch && areaMatch;
      });

      currentFilteredLocations = filtered;
      syncMarkers(filtered);
      updateResultCount(filtered.length);
      updateFilterToggleState();

      if (shouldFit) {
        fitMapToLocations(filtered);
      }
    }

    function resetFilters() {
      if (searchInput) {
        searchInput.value = "";
      }

      if (stationInput) {
        stationInput.value = "";
      }

      selectedWorkValue = "all";
      selectedPrefectureValue = "all";
      selectedOfficialValue = "all";
      updateFilterLabels();
      updateOptionStates();

      activeAreaSlug = "";
      clearSelectedSpot();
      applyFilters({ fit: true });
      fitMapToLocations(currentFilteredLocations);
    }

    function applyInitialUrlParams() {
      if (initialWorkSlug) {
        const targetWorkLocation = locations.find((location) => location.workSlug === initialWorkSlug);

        if (targetWorkLocation?.work) {
          selectedWorkValue = targetWorkLocation.work;
          updateFilterLabels();
          updateOptionStates();
        }
      }

      applyFilters();

      const targetLocation = locations.find((location) => location.slug === initialSpotSlug);

      if (!targetLocation) {
        if (initialWorkSlug || initialAreaSlug) {
          fitMapToLocations(currentFilteredLocations);
        } else {
          fitInitialKantoView();
        }
        return;
      }

      if (!currentFilteredLocations.some((location) => location.slug === initialSpotSlug)) {
        activeAreaSlug = "";
        selectedWorkValue = "all";
        updateFilterLabels();
        updateOptionStates();
        applyFilters();
      }

      setTimeout(() => {
        selectSpot(targetLocation.id);
      }, 120);
    }

    function initMap() {
      if (!locations.length || typeof maplibregl === "undefined") {
        updateResultCount(0);
        return;
      }

      mapInstance = new maplibregl.Map({
        container: "map",
        style: tileConfigs.light.style,
        center: kantoCenter,
        zoom: 8,
        scrollZoom: false,
        dragPan: true,
        touchZoomRotate: true,
        doubleClickZoom: true,
        attributionControl: true,
      });

      mapInstance.addControl(new maplibregl.NavigationControl({
        showCompass: false,
      }), "bottom-right");

      mapInstance.on("styleimagemissing", (event) => {
        if (mapInstance.hasImage(event.id)) {
          return;
        }

        const data = new Uint8Array(4);
        mapInstance.addImage(event.id, {
          width: 1,
          height: 1,
          data,
        });
      });

      mapInstance.on("style.load", () => {
        applyRailwayPaint();

        if (railwayVisible) {
          addRailwaySourceAndLayer();
        }
      });

      locations.forEach((location) => {
        const element = createMarkerElement(location, false);
        const marker = new maplibregl.Marker({
          element,
          anchor: "bottom",
        })
          .setLngLat([location.lng, location.lat])
          .addTo(mapInstance);

        element.addEventListener("click", (event) => {
          event.stopPropagation();
          selectSpot(location.id, false);
        });

        markerMap[String(location.id)] = {
          marker,
          element,
          visible: true,
        };
      });

      mapInstance.on("click", () => {
        clearSelectedSpot();
      });

      mapInstance.on("load", () => {
        mapInstance.resize();
        setupPinchZoomOnly();
        applyRailwayPaint();
        applyInitialUrlParams();
      });
    }

    searchInput?.addEventListener("input", () => applyFilters({ fit: true }));
    stationInput?.addEventListener("input", () => applyFilters({ fit: true }));
    popoverTriggers.forEach((trigger) => {
      trigger.setAttribute("aria-expanded", "false");
      trigger.addEventListener("click", (event) => {
        event.stopPropagation();
        togglePopover(trigger.dataset.popoverTrigger || "");
      });
    });

    filterOptions.forEach((option) => {
      option.addEventListener("click", (event) => {
        event.stopPropagation();
        setFilterValue(option.dataset.filterOption || "", option.dataset.value || "all");
      });
    });

    document.addEventListener("click", () => {
      closePopovers();
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closePopovers();
      }
    });

    resetButton?.addEventListener("click", resetFilters);
    filterPanelToggle?.addEventListener("click", (event) => {
      event.stopPropagation();
      toggleFilterPanel();
    });
    filterPanelClose?.addEventListener("click", () => {
      setFilterPanelOpen(false);
    });
    selectedClose?.addEventListener("click", clearSelectedSpot);
    fitVisibleButton?.addEventListener("click", () => {
      fitMapToLocations(currentFilteredLocations);
    });

    tileButtons.forEach((button) => {
      button.addEventListener("click", () => {
        setMapStyle(button.dataset.mapStyle || "light");
      });
    });

    railwayToggle?.addEventListener("click", async () => {
      railwayToggle.classList.toggle("active");
      railwayToggle.setAttribute(
        "aria-pressed",
        railwayToggle.classList.contains("active") ? "true" : "false"
      );
      await setRailwayVisible(railwayToggle.classList.contains("active"));
    });

    updateFilterLabels();
    updateOptionStates();
    updateFilterToggleState();

    // Next phase: generate public/railways/railways-lite.geojson from National Land Numerical Information N02.
    initMap();
  </script>
</BaseLayout>
