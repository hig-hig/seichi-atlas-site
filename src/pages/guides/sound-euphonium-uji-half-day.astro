---
import RouteGuide from "../../components/guides/RouteGuide.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import publicData from "../../data/publicData.json";
import { soundEuphoniumUjiHalfDay as route } from "../../data/routes.js";
import routeGeometryRaw from "../../data/routeGeometries/sound-euphonium-uji-half-day.geojson?raw";

const { canonicalPath, seoTitle: title, seoDescription: description } = route.guide;
const siteUrl = "https://seichi-atlas-site.vercel.app";
const spots = publicData.spots ?? [];

const routeSpots = route.steps.map((step, index) => {
  const spot = spots.find((item) => item.slug === step.slug);

  if (!spot) {
    throw new Error(`Route spot not found: ${step.slug}`);
  }

  return {
    ...spot,
    ...step,
    order: index + 1,
    lat: Number(spot.lat),
    lng: Number(spot.lng),
    detailUrl: `/spots/${spot.slug}/`,
    googleMapsUrl: `https://www.google.com/maps/search/?api=1&query=${spot.lat},${spot.lng}`,
  };
});

const optionSpot = spots.find((item) => item.slug === route.option.slug);
if (!optionSpot) {
  throw new Error(`Route option spot not found: ${route.option.slug}`);
}

const routeGeometry = JSON.parse(routeGeometryRaw);

const content = route.guide;

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "HOME", item: `${siteUrl}/` },
    { "@type": "ListItem", position: 2, name: "響け！ユーフォニアム", item: `${siteUrl}/works/sound-euphonium/` },
    { "@type": "ListItem", position: 3, name: route.title, item: `${siteUrl}${canonicalPath}` },
  ],
};

const itemListJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: route.title,
  description,
  numberOfItems: routeSpots.length,
  itemListOrder: "https://schema.org/ItemListOrderAscending",
  itemListElement: routeSpots.map((spot) => ({
    "@type": "ListItem",
    position: spot.order,
    name: spot.name,
    url: `${siteUrl}${spot.detailUrl}`,
  })),
};
---

<BaseLayout title={title} description={description} canonical={canonicalPath}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)}></script>
  <RouteGuide
    route={route}
    routeSpots={routeSpots}
    optionSpot={optionSpot}
    routeGeometry={routeGeometry}
    content={content}
  />
</BaseLayout>
