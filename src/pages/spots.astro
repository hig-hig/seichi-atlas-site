---
import BaseLayout from "../layouts/BaseLayout.astro";
import { spots, works } from "../data/portalData.js";

const title = "スポットから探す | Seichi Atlas";
const description =
  "Seichi Atlasの聖地スポット一覧ページです。アニメや漫画の聖地巡礼スポットを、作品・地域・タグから探せます。";

function normalizeTags(tags) {
  if (Array.isArray(tags)) {
    return tags;
  }

  if (typeof tags === "string") {
    return tags
      .split(/[、,\n|/／]+/)
      .map((tag) => tag.trim())
      .filter(Boolean);
  }

  return [];
}

function normalizeOfficialLevel(level) {
  if (level === "official") {
    return "official";
  }

  if (level === "tourism") {
    return "tourism";
  }

  return "fan";
}

function officialLabel(level) {
  if (level === "official") {
    return "公式";
  }

  if (level === "tourism") {
    return "観光協会・自治体";
  }

  return "ファン考察";
}

const normalizedSpots = spots.map((spot, index) => {
  const work = works.find((item) => item.slug === spot.workSlug);
  const officialLevel = normalizeOfficialLevel(spot.officialLevel);
  const tags = normalizeTags(spot.tags);

  return {
    ...spot,
    id: spot.id || index + 1,
    name: spot.name || "名称未登録",
    slug: spot.slug || "",
    work: spot.work || spot.workTitle || work?.title || "",
    workSlug: spot.workSlug || work?.slug || "",
    areaSlug: spot.areaSlug || "",
    prefecture: spot.prefecture || "",
    station: spot.station || "",
    officialLevel,
    officialLabel: officialLabel(officialLevel),
    descriptionText: spot.description || "",
    accessText: spot.access || spot.address || "",
    noteText: spot.note || "",
    tags,
  };
});

const workOptions = [
  ...new Set(
    normalizedSpots
      .map((spot) => spot.work)
      .filter(Boolean)
  ),
];

const prefectureOptions = [
  ...new Set(
    normalizedSpots
      .map((spot) => spot.prefecture)
      .filter(Boolean)
  ),
];

const tagOptions = [
  ...new Set(
    normalizedSpots
      .flatMap((spot) => spot.tags)
      .filter(Boolean)
  ),
];

const totalSpots = normalizedSpots.length;
const totalWorks = workOptions.length;
const totalPrefectures = prefectureOptions.length;
---

<BaseLayout title={title} description={description} canonical="/spots/">
  <main class="spots-page">
    <section class="spots-hero reveal-item">
      <div>
        <div class="section-kicker">SPOTS</div>

        <h1>スポットから探す</h1>

        <p>
          登録されている聖地巡礼スポットを一覧で探せます。
          作品・都道府県・関連度・タグで絞り込み、気になるスポットの詳細ページへ移動できます。
        </p>
      </div>

      <div class="spots-hero-stats">
        <div class="stat-card">
          <span>スポット</span>
          <strong class="count-up" data-count={totalSpots}>0</strong>
        </div>

        <div class="stat-card">
          <span>作品</span>
          <strong class="count-up" data-count={totalWorks}>0</strong>
        </div>

        <div class="stat-card">
          <span>地域</span>
          <strong class="count-up" data-count={totalPrefectures}>0</strong>
        </div>
      </div>
    </section>

    <section class="spots-filter-card reveal-item">
      <div class="filter-head">
        <div>
          <div class="section-kicker">FILTER</div>
          <h2>条件で絞り込む</h2>
        </div>

        <button class="filter-reset-button" type="button" id="filter-reset">
          条件をリセット
        </button>
      </div>

      <div class="filter-grid">
        <label class="filter-field search-field">
          <span>キーワード</span>
          <input
            id="spot-search"
            class="filter-input"
            type="search"
            placeholder="スポット名・作品名・駅名・都道府県"
            autocomplete="off"
          />
        </label>

        <label class="filter-field">
          <span>作品</span>
          <select id="work-filter" class="filter-select">
            <option value="all">すべて</option>
            {workOptions.map((workName) => (
              <option value={workName}>{workName}</option>
            ))}
          </select>
        </label>

        <label class="filter-field">
          <span>都道府県</span>
          <select id="prefecture-filter" class="filter-select">
            <option value="all">すべて</option>
            {prefectureOptions.map((prefecture) => (
              <option value={prefecture}>{prefecture}</option>
            ))}
          </select>
        </label>

        <label class="filter-field">
          <span>関連度</span>
          <select id="official-filter" class="filter-select">
            <option value="all">すべて</option>
            <option value="official">公式</option>
            <option value="tourism">観光協会・自治体</option>
            <option value="fan">ファン考察</option>
          </select>
        </label>
      </div>

      {tagOptions.length > 0 && (
        <div class="tag-filter-section">
          <div class="tag-filter-head">
            <span>タグ</span>
            <small>スポットに登録されたタグで絞り込みます</small>
          </div>

          <div class="tag-filter-list">
            <button class="tag-filter-chip active" type="button" data-tag="all">
              #すべて
            </button>

            {tagOptions.map((tag) => (
              <button class="tag-filter-chip" type="button" data-tag={tag}>
                #{tag}
              </button>
            ))}
          </div>
        </div>
      )}
    </section>

    <section class="spots-main reveal-item">
      <div class="section-header">
        <div>
          <div class="section-kicker">LIST</div>
          <h2>スポット一覧</h2>
          <p id="result-count">{normalizedSpots.length}件のスポットを表示中</p>
        </div>

        <a class="section-link" href="/map/">地図で見る</a>
      </div>

      <div id="filter-summary" class="filter-summary muted">
        すべてのスポットを表示中
      </div>

      <div class="spots-grid" id="spots-grid">
        {normalizedSpots.map((spot, index) => (
          <article
            class={`spot-card level-${spot.officialLevel}`}
            style={`--card-delay:${index * 36}ms;`}
            data-name={spot.name}
            data-work={spot.work}
            data-work-slug={spot.workSlug}
            data-area-slug={spot.areaSlug}
            data-prefecture={spot.prefecture}
            data-station={spot.station}
            data-official={spot.officialLevel}
            data-tags={spot.tags.join(",")}
            data-description={spot.descriptionText}
            data-access={spot.accessText}
            data-note={spot.noteText}
          >
            <div class="spot-card-main">
              <div class="spot-card-top">
                <div>
                  <h3>{spot.name}</h3>

                  <div class="spot-meta-row">
                    {spot.work && <span>{spot.work}</span>}
                    {spot.prefecture && <span>{spot.prefecture}</span>}
                    {spot.station && <span>{spot.station}</span>}
                  </div>
                </div>

                <div class={`level-pill level-${spot.officialLevel}`}>
                  {spot.officialLabel}
                </div>
              </div>

              {spot.descriptionText && (
                <p class="spot-description">
                  {spot.descriptionText}
                </p>
              )}

              {spot.tags.length > 0 && (
                <div class="spot-tags">
                  {spot.tags.slice(0, 5).map((tag) => (
                    <span>#{tag}</span>
                  ))}
                </div>
              )}

              <div class="spot-actions">
                <a
                  class="spot-button primary"
                  href={spot.slug ? `/spots/${spot.slug}/` : "/spots/"}
                >
                  詳細を見る
                </a>

                <a
                  class="spot-button"
                  href={spot.slug ? `/map/?spot=${spot.slug}` : "/map/"}
                >
                  地図で見る
                </a>

                {spot.workSlug && (
                  <a
                    class="spot-button"
                    href={`/works/${spot.workSlug}/`}
                  >
                    作品ページ
                  </a>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="empty-result-card" id="empty-result" hidden>
        <div class="empty-icon">📍</div>
        <h3>表示できるスポットがありません</h3>
        <p>検索条件を変更するか、条件をリセットしてください。</p>
      </div>
    </section>
  </main>

  <style is:global>
    .spots-page {
      width: calc(100% - 32px);
      max-width: 1180px;
      margin: 0 auto;
      padding: 44px 0 72px;
    }

    .section-kicker {
      color: var(--accent-dark);
      font-size: 12px;
      font-weight: 950;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .spots-hero {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
      gap: 24px;
      align-items: stretch;
      margin-bottom: 22px;
      padding: 30px;
      border-radius: var(--radius-large);
      background: linear-gradient(135deg, #ffffff 0%, var(--card-subtle) 100%);
      border: 1px solid var(--border-soft);
      box-shadow: var(--shadow);
    }

    .spots-hero h1 {
      margin: 8px 0 12px;
      color: var(--text);
      font-size: clamp(34px, 5vw, 54px);
      line-height: 1.12;
      letter-spacing: -0.05em;
    }

    .spots-hero p {
      max-width: 720px;
      margin: 0;
      color: var(--sub);
      font-size: 15px;
      font-weight: 750;
      line-height: 1.8;
    }

    .spots-hero-stats {
      display: grid;
      gap: 12px;
    }

    .stat-card {
      padding: 20px;
      border-radius: 22px;
      background: #ffffff;
      border: 1px solid var(--border-soft);
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.04);
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }
    .spot-card[hidden] {
      display: none !important;
    }

    .stat-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-strong);
    }

    .stat-card span {
      display: block;
      margin-bottom: 8px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 900;
    }

    .stat-card strong {
      display: block;
      color: var(--text);
      font-size: 36px;
      font-weight: 950;
      line-height: 1;
      letter-spacing: -0.04em;
    }

    .spots-filter-card,
    .spots-main {
      border-radius: var(--radius-card);
      background: #ffffff;
      border: 1px solid var(--border-soft);
      box-shadow: var(--shadow);
    }

    .spots-filter-card {
      margin-bottom: 18px;
      padding: 22px;
    }

    .filter-head,
    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
      margin-bottom: 18px;
    }

    .filter-head h2,
    .section-header h2 {
      margin: 4px 0 0;
      padding: 0;
      border: none;
      color: var(--text);
      font-size: 24px;
      letter-spacing: -0.03em;
    }

    .section-header p {
      margin: 6px 0 0;
      color: var(--sub);
      font-size: 13px;
      font-weight: 750;
    }

    .filter-reset-button,
    .section-link {
      min-height: 40px;
      border-radius: 999px;
      padding: 8px 14px;
      font-size: 13px;
      font-weight: 900;
      cursor: pointer;
      transition: transform 0.18s ease, background 0.18s ease, color 0.18s ease;
    }

    .filter-reset-button {
      border: 1px solid var(--border);
      background: #ffffff;
      color: var(--sub);
    }

    .section-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: var(--accent-soft);
      color: var(--accent-dark);
      text-decoration: none;
    }

    .filter-reset-button:hover,
    .section-link:hover {
      transform: translateY(-1px);
      background: var(--card-subtle);
      color: var(--text);
    }

    .filter-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.4fr) repeat(3, minmax(160px, 0.75fr));
      gap: 12px;
      align-items: end;
    }

    .filter-field {
      display: grid;
      gap: 7px;
    }

    .filter-field span {
      color: var(--muted);
      font-size: 12px;
      font-weight: 950;
      letter-spacing: 0.04em;
    }

    .filter-input,
    .filter-select {
      width: 100%;
      min-height: 42px;
      padding: 10px 12px;
      border-radius: 14px;
      border: 1px solid var(--border);
      background: #ffffff;
      color: var(--text);
      font-size: 14px;
      font-weight: 750;
      outline: none;
      transition: border-color 0.18s ease, box-shadow 0.18s ease;
    }

    .filter-input:focus,
    .filter-select:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.14);
    }

    .tag-filter-section {
      margin-top: 18px;
      padding-top: 16px;
      border-top: 1px solid var(--border-soft);
    }

    .tag-filter-head {
      display: flex;
      align-items: baseline;
      gap: 10px;
      margin-bottom: 10px;
    }

    .tag-filter-head span {
      color: var(--muted);
      font-size: 12px;
      font-weight: 950;
    }

    .tag-filter-head small {
      color: var(--muted);
      font-size: 12px;
      font-weight: 750;
    }

    .tag-filter-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .tag-filter-chip {
      border: none;
      border-radius: 999px;
      padding: 8px 12px;
      background: var(--card-subtle);
      color: var(--sub);
      font-size: 13px;
      font-weight: 850;
      cursor: pointer;
      transition: transform 0.18s ease, background 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;
    }

    .tag-filter-chip:hover {
      transform: translateY(-1px);
      background: #e8eef6;
      color: var(--text);
    }

    .tag-filter-chip.active {
      background: var(--accent);
      color: #ffffff;
      box-shadow: 0 10px 22px rgba(14, 165, 233, 0.22);
      animation: chipPop 0.24s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .spots-main {
      padding: 22px;
    }

    .filter-summary {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 8px;
      margin: 0 0 14px;
      padding: 12px 14px;
      border-radius: 18px;
      background: var(--card-subtle);
      border: 1px solid var(--border-soft);
      color: var(--sub);
      font-size: 13px;
      font-weight: 850;
    }

    .filter-summary.muted {
      color: var(--muted);
    }

    .summary-label {
      color: var(--accent-dark);
      font-weight: 950;
    }

    .summary-pill {
      display: inline-flex;
      padding: 5px 9px;
      border-radius: 999px;
      background: #ffffff;
      border: 1px solid var(--border-soft);
      color: var(--sub);
      font-size: 12px;
      font-weight: 850;
    }

    .spots-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 16px;
    }

    .spots-grid.filter-refreshing .spot-card:not([hidden]) {
      animation: filterResultFadeIn 0.28s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .spot-card {
      min-height: 260px;
      display: flex;
      border-left: 5px solid var(--sub);
      border-radius: var(--radius-card);
      background: #ffffff;
      border-top: 1px solid var(--border-soft);
      border-right: 1px solid var(--border-soft);
      border-bottom: 1px solid var(--border-soft);
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.05);
      opacity: 0;
      animation: cardIn 0.42s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      animation-delay: var(--card-delay);
      transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }

    .spot-card.level-official {
      border-left-color: var(--accent);
    }

    .spot-card.level-tourism {
      border-left-color: var(--visited);
    }

    .spot-card.level-fan {
      border-left-color: var(--sub);
    }

    .spot-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-strong);
    }

    .spot-card-main {
      width: 100%;
      display: flex;
      flex-direction: column;
      padding: 22px;
    }

    .spot-card-top {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 14px;
      align-items: start;
    }

    .spot-card h3 {
      margin: 0;
      color: var(--text);
      font-size: 20px;
      font-weight: 950;
      line-height: 1.35;
      letter-spacing: -0.02em;
      word-break: keep-all;
      overflow-wrap: anywhere;
    }

    .spot-meta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
      margin-top: 10px;
    }

    .spot-meta-row span {
      display: inline-flex;
      padding: 6px 10px;
      border-radius: 999px;
      background: var(--card-subtle);
      color: var(--sub);
      font-size: 13px;
      font-weight: 750;
    }

    .level-pill {
      flex-shrink: 0;
      display: inline-flex;
      width: fit-content;
      padding: 7px 11px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 950;
      letter-spacing: 0.03em;
    }

    .level-pill.level-official {
      background: var(--accent-soft);
      color: var(--accent-dark);
    }

    .level-pill.level-tourism {
      background: var(--visited-soft);
      color: var(--visited-dark);
    }

    .level-pill.level-fan {
      background: var(--card-subtle);
      color: var(--sub);
    }

    .spot-description {
      display: -webkit-box;
      margin: 16px 0 0;
      color: var(--sub);
      font-size: 13px;
      font-weight: 750;
      line-height: 1.7;
      overflow: hidden;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
    }

    .spot-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
      margin-top: 14px;
    }

    .spot-tags span {
      display: inline-flex;
      padding: 5px 9px;
      border-radius: 999px;
      background: var(--accent-soft);
      color: var(--accent-dark);
      font-size: 12px;
      font-weight: 850;
    }

    .spot-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: auto;
      padding-top: 18px;
    }

    .spot-button {
      min-height: 38px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 8px 12px;
      background: var(--card-subtle);
      color: var(--text);
      font-size: 12px;
      font-weight: 900;
      text-decoration: none;
      cursor: pointer;
      transition: transform 0.16s ease, background 0.16s ease, color 0.16s ease;
    }

    .spot-button.primary {
      background: var(--accent);
      border-color: var(--accent);
      color: #ffffff;
      box-shadow: 0 10px 22px rgba(14, 165, 233, 0.18);
    }

    .spot-button:hover {
      transform: translateY(-1px);
      background: var(--accent-soft);
      color: var(--accent-dark);
    }

    .spot-button.primary:hover {
      background: var(--accent-dark);
      color: #ffffff;
    }

    .empty-result-card {
      margin-top: 18px;
      padding: 42px 28px;
      border-radius: var(--radius-large);
      background: #ffffff;
      border: 1px solid var(--border-soft);
      box-shadow: var(--shadow);
      text-align: center;
      animation: emptyStateIn 0.28s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .empty-icon {
      margin-bottom: 12px;
      font-size: 34px;
      animation: emptyIconFloat 1.8s ease-in-out infinite;
    }

    .empty-result-card h3 {
      margin: 0 0 8px;
      color: var(--text);
      font-size: 22px;
    }

    .empty-result-card p {
      margin: 0;
      color: var(--sub);
      font-size: 14px;
      font-weight: 750;
    }

    .reveal-item {
      opacity: 0;
      animation: contentFadeUp 0.42s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes contentFadeUp {
      from {
        opacity: 0;
        transform: translateY(14px) scale(0.99);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @keyframes cardIn {
      from {
        opacity: 0;
        transform: translateY(14px) scale(0.985);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @keyframes filterResultFadeIn {
      from {
        opacity: 0.42;
        transform: translateY(8px) scale(0.99);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @keyframes chipPop {
      from {
        transform: scale(0.94);
      }

      65% {
        transform: scale(1.05);
      }

      to {
        transform: scale(1);
      }
    }

    @keyframes emptyStateIn {
      from {
        opacity: 0;
        transform: translateY(10px) scale(0.98);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @keyframes emptyIconFloat {
      0% {
        transform: translateY(0) rotate(0deg);
      }

      35% {
        transform: translateY(-3px) rotate(-2deg);
      }

      70% {
        transform: translateY(1px) rotate(2deg);
      }

      100% {
        transform: translateY(0) rotate(0deg);
      }
    }

    @media (max-width: 1000px) {
      .spots-hero {
        grid-template-columns: 1fr;
      }

      .spots-hero-stats {
        grid-template-columns: repeat(3, 1fr);
      }

      .filter-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 760px) {
      .spots-page {
        width: calc(100% - 24px);
        padding: 26px 0 52px;
      }

      .spots-hero {
        padding: 22px;
        border-radius: 24px;
      }

      .spots-hero h1 {
        font-size: 34px;
      }

      .spots-hero-stats {
        grid-template-columns: repeat(3, 1fr);
      }

      .stat-card {
        padding: 14px 10px;
      }

      .stat-card strong {
        font-size: 26px;
      }

      .filter-head,
      .section-header {
        display: block;
      }

      .filter-reset-button,
      .section-link {
        width: 100%;
        margin-top: 12px;
      }

      .tag-filter-list {
        flex-wrap: nowrap;
        overflow-x: auto;
        padding-bottom: 4px;
        -webkit-overflow-scrolling: touch;
      }

      .tag-filter-chip {
        flex: 0 0 auto;
      }

      .spots-main {
        padding: 18px;
      }

      .spots-grid {
        grid-template-columns: 1fr;
      }

      .spot-card {
        min-height: auto;
      }

      .spot-card-top {
        display: block;
      }

      .level-pill {
        margin-top: 12px;
      }

      .spot-actions {
        display: grid;
        grid-template-columns: 1fr;
      }

      .spot-button {
        width: 100%;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      *,
      *::before,
      *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
        scroll-behavior: auto !important;
      }
    }
  </style>

  <script is:inline>
    const searchInput = document.getElementById("spot-search");
    const workFilter = document.getElementById("work-filter");
    const prefectureFilter = document.getElementById("prefecture-filter");
    const officialFilter = document.getElementById("official-filter");
    const resetButton = document.getElementById("filter-reset");
    const tagButtons = Array.from(document.querySelectorAll("[data-tag]"));
    const cards = Array.from(document.querySelectorAll(".spot-card"));
    const resultCount = document.getElementById("result-count");
    const summary = document.getElementById("filter-summary");
    const emptyResult = document.getElementById("empty-result");
    const grid = document.getElementById("spots-grid");

    const urlParams = new URLSearchParams(window.location.search);

    const initialWorkSlug = urlParams.get("work") || "";
    const initialAreaSlug = urlParams.get("area") || "";
    const initialTag = urlParams.get("tag") || "";
    const initialPrefecture = urlParams.get("prefecture") || "";

    let activeTag = "all";
    let activeWorkSlug = initialWorkSlug;
    let activeAreaSlug = initialAreaSlug;

    function normalizeText(value) {
      return String(value || "").toLowerCase();
    }

    function escapeHtml(value) {
      return String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    function animateCountUp(element, target, duration) {
      const endValue = Number(target || 0);
      const startTime = performance.now();

      function update(now) {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const value = Math.round(endValue * eased);

        element.textContent = String(value);

        if (progress < 1) {
          requestAnimationFrame(update);
        } else {
          element.textContent = String(endValue);
        }
      }

      requestAnimationFrame(update);
    }

    function triggerFilterMotion() {
      if (!grid) {
        return;
      }

      grid.classList.remove("filter-refreshing");

      void grid.offsetWidth;

      grid.classList.add("filter-refreshing");

      setTimeout(() => {
        grid.classList.remove("filter-refreshing");
      }, 300);
    }

    function setActiveTagButton(tag) {
      tagButtons.forEach((button) => {
        if (button.dataset.tag === tag) {
          button.classList.add("active");
        } else {
          button.classList.remove("active");
        }
      });
    }

    function renderSummary(count) {
      if (!summary) {
        return;
      }

      const labels = [];
      const keyword = searchInput ? searchInput.value.trim() : "";
      const work = workFilter?.value || "all";
      const prefecture = prefectureFilter?.value || "all";
      const official = officialFilter?.value || "all";

      if (keyword) {
        labels.push("検索: " + keyword);
      }

      if (activeWorkSlug) {
        const targetCard = cards.find((card) => {
          return card.dataset.workSlug === activeWorkSlug;
        });

        labels.push("作品: " + (targetCard?.dataset.work || activeWorkSlug));
      } else if (work !== "all") {
        labels.push("作品: " + work);
      }

      if (activeAreaSlug) {
        labels.push("地域: " + activeAreaSlug);
      }

      if (prefecture !== "all") {
        labels.push(prefecture);
      }

      if (official === "official") {
        labels.push("公式");
      }

      if (official === "tourism") {
        labels.push("観光協会・自治体");
      }

      if (official === "fan") {
        labels.push("ファン考察");
      }

      if (activeTag !== "all") {
        labels.push("#" + activeTag);
      }

      if (!labels.length) {
        summary.className = "filter-summary muted";
        summary.textContent = "すべてのスポットを表示中";
        return;
      }

      summary.className = "filter-summary";
      summary.innerHTML =
        '<span class="summary-label">絞り込み中</span>' +
        labels
          .map((label) => '<span class="summary-pill">' + escapeHtml(label) + '</span>')
          .join("") +
        '<span class="summary-pill">' + count + "件表示</span>";
    }

    function applyInitialUrlParams() {
      if (initialWorkSlug && workFilter) {
        const targetCard = cards.find((card) => {
          return card.dataset.workSlug === initialWorkSlug;
        });

        if (targetCard?.dataset.work) {
          workFilter.value = targetCard.dataset.work;
        }
      }

      if (initialPrefecture && prefectureFilter) {
        const decodedPrefecture = decodeURIComponent(initialPrefecture).trim();

        const hasPrefectureOption = Array.from(prefectureFilter.options).some((option) => {
          return option.value === decodedPrefecture;
        });

        if (hasPrefectureOption) {
          prefectureFilter.value = decodedPrefecture;
        }
      }

      if (initialTag) {
        activeTag = decodeURIComponent(initialTag).trim();
        setActiveTagButton(activeTag);
      }

      applyFilters();
    }

    function applyFilters() {
      const keyword = normalizeText(searchInput?.value);
      const work = workFilter?.value || "all";
      const prefecture = prefectureFilter?.value || "all";
      const official = officialFilter?.value || "all";

      let visibleCount = 0;

      cards.forEach((card) => {
        const name = normalizeText(card.dataset.name);
        const cardWork = String(card.dataset.work || "");
        const cardWorkSlug = String(card.dataset.workSlug || "");
        const cardAreaSlug = String(card.dataset.areaSlug || "");
        const cardPrefecture = String(card.dataset.prefecture || "");
        const station = normalizeText(card.dataset.station);
        const cardOfficial = String(card.dataset.official || "");
        const tags = String(card.dataset.tags || "");
        const description = normalizeText(card.dataset.description);
        const access = normalizeText(card.dataset.access);
        const note = normalizeText(card.dataset.note);

        const keywordTarget = normalizeText([
          name,
          cardWork,
          cardWorkSlug,
          cardAreaSlug,
          cardPrefecture,
          station,
          tags,
          description,
          access,
          note,
        ].join(" "));

        const keywordMatch = !keyword || keywordTarget.includes(keyword);

        const workMatch =
          (!activeWorkSlug && work === "all") ||
          cardWork === work ||
          cardWorkSlug === activeWorkSlug;

        const areaMatch =
          !activeAreaSlug ||
          cardAreaSlug === activeAreaSlug;

        const prefectureMatch =
          prefecture === "all" ||
          cardPrefecture === prefecture;

        const officialMatch =
          official === "all" ||
          cardOfficial === official;

        const tagMatch =
          activeTag === "all" ||
          tags.split(",").map((tag) => tag.trim()).includes(activeTag);

        const isVisible =
          keywordMatch &&
          workMatch &&
          areaMatch &&
          prefectureMatch &&
          officialMatch &&
          tagMatch;

        card.hidden = !isVisible;

        if (isVisible) {
          visibleCount += 1;
        }
      });

      if (resultCount) {
        resultCount.textContent = visibleCount + "件のスポットを表示中";
      }

      if (emptyResult) {
        emptyResult.hidden = visibleCount !== 0;
      }

      renderSummary(visibleCount);
      triggerFilterMotion();
    }

    function resetFilters() {
      if (searchInput) {
        searchInput.value = "";
      }

      if (workFilter) {
        workFilter.value = "all";
      }

      if (prefectureFilter) {
        prefectureFilter.value = "all";
      }

      if (officialFilter) {
        officialFilter.value = "all";
      }

      activeTag = "all";
      activeWorkSlug = "";
      activeAreaSlug = "";

      setActiveTagButton("all");

      applyFilters();
    }

    document.querySelectorAll(".count-up").forEach((element) => {
      animateCountUp(element, Number(element.dataset.count || 0), 720);
    });

    searchInput?.addEventListener("input", applyFilters);

    workFilter?.addEventListener("change", () => {
      activeWorkSlug = "";
      applyFilters();
    });

    prefectureFilter?.addEventListener("change", applyFilters);
    officialFilter?.addEventListener("change", applyFilters);
    resetButton?.addEventListener("click", resetFilters);

    tagButtons.forEach((button) => {
      button.addEventListener("click", () => {
        activeTag = button.dataset.tag || "all";
        setActiveTagButton(activeTag);
        applyFilters();
      });
    });

    applyInitialUrlParams();
  </script>
</BaseLayout>