---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { works, getSpotsByWorkSlug } from "../../data/portalData.js";

export function getStaticPaths() {
  return works.map((work) => ({
    params: { slug: work.slug },
    props: { work }
  }));
}

const { work } = Astro.props;
const relatedSpots = getSpotsByWorkSlug(work.slug);

const title = `${work.title}の聖地巡礼 | Seichi Atlas`;
const description = `${work.title}に関連する聖地巡礼スポットを紹介するページです。主な地域、登録スポット、訪問時の注意を確認できます。`;
---

<BaseLayout title={title} description={description} canonical={`/works/${work.slug}/`}>
  <main class="page">
    <section class="work-hero">
      <p class="kicker">Work</p>

      <h1>{work.title}の聖地巡礼</h1>

      <p class="lead">
        {work.summary}
      </p>

      <div class="work-meta-list">
        <span>{work.year}</span>
        <span>{work.area}</span>
        <span>{relatedSpots.length} spots</span>
      </div>

      <div class="tag-list">
        {work.tags.map((tag) => (
          <span>{tag}</span>
        ))}
      </div>
    </section>

    <section class="content-section">
      <h2>作品について</h2>
      <p>{work.description}</p>
      <p>
        このページでは、作品に関連する聖地巡礼スポットを公開情報として紹介します。
        この作品に関連する聖地巡礼スポットを確認できます。地図上で場所を見たい場合は、マップページから探せます。
      </p>
    </section>

    <section class="content-section">
      <h2>主な聖地スポット</h2>

      {relatedSpots.length === 0 ? (
        <p>
          現在、この作品に関連する公開スポットは登録されていません。
        </p>
      ) : (
        <div class="spot-list">
          {relatedSpots.map((spot) => (
            <article class="spot-card">
              <h3>{spot.name}</h3>
              <p class="spot-meta">
                {spot.prefecture} / 最寄り：{spot.station}
              </p>
              <p>{spot.description}</p>

              <a class="text-link" href={`/spots/${spot.slug}`}>
                スポット詳細を見る
              </a>
            </article>
          ))}
        </div>
      )}
    </section>

    <section class="content-section notice-box">
      <h2>訪問時の注意</h2>
      <p>
        掲載情報は訪問を推奨・保証するものではありません。
        実際に訪問する際は、現地のルール、立入可否、撮影可否、施設案内、交通状況を必ず確認してください。
      </p>
      <p>
        私有地や立入禁止区域への侵入、近隣住民や施設への迷惑行為は禁止です。
      </p>
    </section>

    <section class="cta-section">
      <div>
        <p class="kicker">Record</p>
        <h2>この作品の巡礼を記録する</h2>
        <p>
          この作品の関連スポットは、スポット一覧やマップページから確認できます。
        </p>
      </div>

      <a class="button-primary" href="/map/">マップで見る</a>
      <a class="button-secondary" href="/spots/">スポット一覧へ</a>
    </section>
  </main>

  <style>
    .work-hero {
      max-width: 840px;
      padding: 40px 0 16px;
    }

    .lead {
      color: var(--sub);
      font-size: 17px;
      max-width: 760px;
    }

    .work-meta-list {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 24px;
    }

    .work-meta-list span {
      padding: 8px 12px;
      border-radius: 999px;
      background: #ffffff;
      color: var(--sub);
      font-size: 13px;
      font-weight: 800;
      box-shadow: 0 8px 20px rgba(120, 90, 60, 0.05);
    }

    .tag-list {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 16px;
    }

    .tag-list span {
      padding: 6px 10px;
      border-radius: 999px;
      background: #f7f3ee;
      color: var(--sub);
      font-size: 12px;
      font-weight: 700;
    }

    .content-section {
      margin-top: 42px;
      padding: 28px;
      border-radius: 24px;
      background: #ffffff;
      box-shadow: 0 8px 24px rgba(120, 90, 60, 0.06);
    }

    .content-section h2 {
      margin-top: 0;
      border: none;
      padding-bottom: 0;
    }

    .content-section p {
      color: var(--sub);
    }

    .spot-list {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
      margin-top: 24px;
    }

    .spot-card {
      padding: 22px;
      border-radius: 20px;
      background: #f7f3ee;
    }

    .spot-card h3 {
      margin: 0 0 6px;
    }

    .spot-card p {
      margin-bottom: 12px;
    }

    .spot-meta {
      color: var(--accent-dark);
      font-size: 13px;
      font-weight: 800;
    }

    .text-link {
      color: var(--accent-dark);
      font-weight: 800;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .notice-box {
      border: 1px solid var(--border);
    }

    .cta-section {
      margin-top: 56px;
      padding: 32px;
      border-radius: 28px;
      background: #3f352d;
      color: #ffffff;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 28px;
    }

    .cta-section h2 {
      margin-top: 0;
      border: none;
      padding-bottom: 0;
      color: #ffffff;
    }

    .cta-section p {
      color: rgba(255, 255, 255, 0.74);
    }

    .cta-section .button-primary {
      background: #ffffff;
      color: #3f352d;
      flex-shrink: 0;
    }

    @media (max-width: 760px) {
      .spot-list {
        grid-template-columns: 1fr;
      }

      .cta-section {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</BaseLayout>
