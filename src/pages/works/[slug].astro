---
import BaseLayout from "../../layouts/BaseLayout.astro";
import publicData from "../../data/publicData.json";

export function getStaticPaths() {
  const worksForPaths = publicData.works ?? [];

  return worksForPaths
    .filter((work) => work.slug)
    .map((work) => ({
      params: { slug: work.slug },
      props: { currentWork: work },
    }));
}

const works = publicData.works ?? [];
const spots = publicData.spots ?? [];
const areas = publicData.areas ?? [];

const { currentWork } = Astro.props;

const workSlug = currentWork.slug;
const workTitle = currentWork.title ?? "作品詳細";

const workSummary =
  currentWork.summary ||
  currentWork.description ||
  `${workTitle}に関連する聖地巡礼スポットを、地図・地域・スポット一覧から探せる作品詳細ページです。`;

const workYear = currentWork.year ?? "";
const canonicalPath = `/works/${workSlug}/`;

function normalizeTags(value) {
  if (!value) return [];

  if (Array.isArray(value)) {
    return value.filter(Boolean).map((item) => String(item).trim()).filter(Boolean);
  }

  return String(value)
    .split(/[、,\n|/／]+/)
    .map((item) => item.trim())
    .filter(Boolean);
}

function getAreaName(areaSlug) {
  const area = areas.find((item) => item.slug === areaSlug);
  return area?.name || areaSlug || "";
}

function getSpotTitle(spot) {
  return spot.name || spot.title || "名称未設定のスポット";
}

function getOfficialLabel(value) {
  const key = String(value || "").toLowerCase();

  if (key === "official") return "公式・明示";
  if (key === "semi") return "関連度高め";
  if (key === "fan") return "ファン向け候補";
  if (key === "low") return "参考候補";

  return value || "関連度未設定";
}

function getCardImage(item) {
  return item.imageUrl || item.image || item.thumbnail || "";
}

const workSpots = spots.filter((spot) => spot.workSlug === workSlug);
const workImageSrc = getCardImage(currentWork);

const relatedAreas = areas
  .map((area) => {
    const areaSpots = workSpots.filter((spot) => spot.areaSlug === area.slug);

    return {
      ...area,
      count: areaSpots.length,
      spots: areaSpots,
    };
  })
  .filter((area) => area.count > 0)
  .sort((a, b) => b.count - a.count);

const prefectures = [
  ...new Set(
    workSpots
      .map((spot) => spot.prefecture)
      .filter(Boolean)
  ),
];

const tagCounts = new Map();

workSpots.forEach((spot) => {
  normalizeTags(spot.tags).forEach((tag) => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});

normalizeTags(currentWork.tags).forEach((tag) => {
  tagCounts.set(tag, Math.max(tagCounts.get(tag) || 0, 1));
});

const relatedTags = [...tagCounts.entries()]
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 16);

const featuredSpots = workSpots.slice(0, 8);

const mapPageUrl = `/map/?work=${workSlug}`;
const spotsPageUrl = `/spots/?work=${workSlug}`;

const pageTitle = `${workTitle}の聖地巡礼スポット一覧`;
const pageDescription =
  `${workTitle}に関連する聖地巡礼スポットを、地域・地図・スポット一覧から探せる作品詳細ページです。`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: pageTitle,
  description: pageDescription,
  url: `https://seichi-atlas-site.vercel.app${canonicalPath}`,
  isPartOf: {
    "@type": "WebSite",
    name: "Seichi Atlas",
    url: "https://seichi-atlas-site.vercel.app/",
  },
  about: {
    "@type": "CreativeWork",
    name: workTitle,
  },
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: workSpots.length,
    itemListElement: workSpots.slice(0, 20).map((spot, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: getSpotTitle(spot),
      url: `https://seichi-atlas-site.vercel.app/spots/${spot.slug}/`,
    })),
  },
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "HOME",
      item: "https://seichi-atlas-site.vercel.app/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "作品から探す",
      item: "https://seichi-atlas-site.vercel.app/works/",
    },
    {
      "@type": "ListItem",
      position: 3,
      name: workTitle,
      item: `https://seichi-atlas-site.vercel.app${canonicalPath}`,
    },
  ],
};

---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonicalPath}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)}></script>

  <main class="work-detail-page">
    <section class="hero-section">
      <div class="container">
        <div class="breadcrumb">
          <a href="/">HOME</a>
          <span>/</span>
          <a href="/works/">作品から探す</a>
          <span>/</span>
          <span>{workTitle}</span>
        </div>

        <div class="hero-card">
          <div class="detail-hero-media">
            {workImageSrc ? (
              <>
                <img
                  src={workImageSrc}
                  alt={`${workTitle}のイメージ`}
                  loading="lazy"
                  onerror="this.hidden = true; this.nextElementSibling.hidden = false;"
                />
                <div class="detail-hero-placeholder work-placeholder" aria-label={`${workTitle}の地図風プレースホルダー`} hidden>
                  <span>WORK MAP</span>
                  <strong>{workTitle}</strong>
                </div>
              </>
            ) : (
              <div class="detail-hero-placeholder work-placeholder" aria-label={`${workTitle}の地図風プレースホルダー`}>
                <span>WORK MAP</span>
                <strong>{workTitle}</strong>
              </div>
            )}
          </div>

          <div class="hero-main">
            <p class="eyebrow">作品から探す</p>
            <h1>{workTitle}の聖地巡礼スポット</h1>

            <p class="lead">
              {workSummary}
            </p>

            <div class="meta-list">
              {workYear && (
                <div class="meta-item">
                  <span class="meta-label">公開年</span>
                  <span class="meta-value">{workYear}</span>
                </div>
              )}

              <div class="meta-item">
                <span class="meta-label">スポット数</span>
                <span class="meta-value">{workSpots.length}件</span>
              </div>

              <div class="meta-item">
                <span class="meta-label">関連地域</span>
                <span class="meta-value">{relatedAreas.length}地域</span>
              </div>

              <div class="meta-item">
                <span class="meta-label">都道府県</span>
                <span class="meta-value">
                  {prefectures.length ? prefectures.join("・") : "未設定"}
                </span>
              </div>
            </div>

            <div class="hero-actions">
              <a class="primary-button" href={mapPageUrl}>この作品の聖地を地図で見る</a>
              <a class="secondary-button" href={spotsPageUrl}>スポット一覧で見る</a>
            </div>
          </div>

          <aside class="hero-side">
            <p class="side-title">この作品の探し方</p>
            <ul>
              <li>まずは地図で位置関係を確認</li>
              <li>気になる地域から代表スポットを確認</li>
              <li>各スポット詳細でアクセスや注意事項を確認</li>
            </ul>
          </aside>
        </div>
      </div>
    </section>

    <section class="content-section">
      <div class="container two-column-layout">
        <div class="main-column">
          <section class="info-card">
            <div class="section-heading">
              <p class="eyebrow">Spots</p>
              <h2>{workTitle}に関連するスポット</h2>
              <p>
                この作品に関連する巡礼候補スポットを一覧で確認できます。
                各スポットの詳細ページでは、所在地メモ・アクセス・関連タグなどを確認できます。
              </p>
            </div>

            {featuredSpots.length > 0 ? (
              <div class="spot-grid">
                {featuredSpots.map((spot) => {
                  const spotTags = normalizeTags(spot.tags).slice(0, 4);
                  const spotTitle = getSpotTitle(spot);
                  const areaName = getAreaName(spot.areaSlug);

                  return (
                    <article class="spot-card">
                      <div class="spot-card-header">
                        <p class="spot-area">
                          {spot.prefecture || "地域未設定"}
                          {areaName && ` / ${areaName}`}
                        </p>
                        <span class="official-badge">
                          {getOfficialLabel(spot.officialLevel)}
                        </span>
                      </div>

                      <h3>
                        <a href={`/spots/${spot.slug}/`}>{spotTitle}</a>
                      </h3>

                      {spot.description && (
                        <p class="spot-description">{spot.description}</p>
                      )}

                      <div class="spot-meta">
                        {spot.nearestStation && (
                          <span>最寄り：{spot.nearestStation}</span>
                        )}
                        {spot.access && (
                          <span>{spot.access}</span>
                        )}
                      </div>

                      {spotTags.length > 0 && (
                        <div class="tag-list">
                          {spotTags.map((tag) => (
                            <span>{tag}</span>
                          ))}
                        </div>
                      )}

                      <div class="card-actions">
                        <a href={`/spots/${spot.slug}/`}>詳細を見る</a>
                        <a href={`/map/?spot=${spot.slug}`}>地図で見る</a>
                      </div>
                    </article>
                  );
                })}
              </div>
            ) : (
              <div class="empty-card">
                <p>
                  この作品に関連するスポットは、まだ登録されていません。
                </p>
                <a href="/spots/">スポット一覧を見る</a>
              </div>
            )}

            {workSpots.length > featuredSpots.length && (
              <div class="more-link">
                <a href={spotsPageUrl}>
                  {workTitle}のスポットをすべて見る
                </a>
              </div>
            )}
          </section>

          <section class="info-card">
            <div class="section-heading">
              <p class="eyebrow">Areas</p>
              <h2>関連地域から探す</h2>
              <p>
                地域ごとにスポットを見たい場合は、地域ページから回遊できます。
              </p>
            </div>

            {relatedAreas.length > 0 ? (
              <div class="area-list">
                {relatedAreas.map((area) => (
                  <article class="area-card">
                    <div>
                      <p class="area-count">{area.count}スポット</p>
                      <h3>
                        <a href={`/areas/${area.slug}/`}>{area.name}</a>
                      </h3>
                      <p>
                        {area.name}周辺にある{workTitle}関連の巡礼候補スポットを確認できます。
                      </p>
                    </div>

                    <div class="card-actions">
                      <a href={`/areas/${area.slug}/`}>地域ページへ</a>
                      <a href={`/map/?area=${area.slug}`}>地図で見る</a>
                    </div>
                  </article>
                ))}
              </div>
            ) : (
              <div class="empty-card">
                <p>関連地域はまだ登録されていません。</p>
              </div>
            )}
          </section>

          <section class="info-card notice-card">
            <div class="section-heading">
              <p class="eyebrow">Notice</p>
              <h2>聖地巡礼時の注意</h2>
            </div>

            <p>
              掲載しているスポットは、作品を想起させる場所や関連地として整理したものです。
              訪問時は、現地のルール、交通マナー、撮影可否、私有地への立ち入りに十分注意してください。
            </p>

            <div class="notice-links">
              <a href="/manners/">聖地巡礼のマナーを見る</a>
              <a href="/how-to-use/">このサイトの使い方を見る</a>
            </div>
          </section>
        </div>

        <aside class="side-column">
          <section class="side-card">
            <h2>この作品の概要</h2>

            <dl>
              <div>
                <dt>作品名</dt>
                <dd>{workTitle}</dd>
              </div>

              {workYear && (
                <div>
                  <dt>公開年</dt>
                  <dd>{workYear}</dd>
                </div>
              )}

              <div>
                <dt>登録スポット</dt>
                <dd>{workSpots.length}件</dd>
              </div>

              <div>
                <dt>関連地域</dt>
                <dd>{relatedAreas.length}地域</dd>
              </div>
            </dl>
          </section>

          {relatedTags.length > 0 && (
            <section class="side-card">
              <h2>関連タグ</h2>

              <div class="tag-list side-tags">
                {relatedTags.map((tag) => (
                  <span>{tag.name}</span>
                ))}
              </div>
            </section>
          )}

          <section class="side-card">
            <h2>探し方リンク</h2>

            <div class="side-links">
              <a href={mapPageUrl}>地図で探す</a>
              <a href={spotsPageUrl}>スポット一覧で探す</a>
              <a href="/works/">他の作品を見る</a>
              <a href="/areas/">地域一覧を見る</a>
            </div>
          </section>
        </aside>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .work-detail-page {
    background:
      radial-gradient(circle at top left, rgba(14, 165, 233, 0.12), transparent 32rem),
      var(--bg);
    min-height: 100vh;
  }

  .container {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
  }

  .hero-section {
    padding: 40px 0 28px;
  }

  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    color: var(--sub);
    font-size: 0.88rem;
    margin-bottom: 18px;
  }

  .breadcrumb a {
    color: var(--accent-dark);
    text-decoration: none;
    font-weight: 700;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .hero-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 24px;
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid var(--border);
    border-radius: var(--radius-large);
    box-shadow: var(--shadow);
    padding: 32px;
  }

  .detail-hero-media {
    grid-column: 1 / -1;
    aspect-ratio: 21 / 8;
    min-height: 260px;
    border-radius: 24px;
    background: var(--card-subtle);
    border: 1px solid var(--border-soft);
    overflow: hidden;
  }

  .detail-hero-media img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .detail-hero-media img[hidden],
  .detail-hero-placeholder[hidden] {
    display: none !important;
  }

  .detail-hero-placeholder {
    position: relative;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 6px;
    padding: 28px;
    overflow: hidden;
    background:
      linear-gradient(90deg, rgba(14, 165, 233, 0.12) 1px, transparent 1px),
      linear-gradient(0deg, rgba(14, 165, 233, 0.12) 1px, transparent 1px),
      radial-gradient(circle at 78% 24%, rgba(14, 165, 233, 0.22), transparent 24%),
      linear-gradient(135deg, var(--card) 0%, var(--card-subtle) 100%);
    background-size: 34px 34px, 34px 34px, auto, auto;
  }

  .detail-hero-placeholder::after {
    content: "";
    position: absolute;
    right: 28px;
    top: 28px;
    width: 58px;
    height: 58px;
    border: 4px solid var(--accent);
    border-radius: 50% 50% 50% 0;
    opacity: 0.24;
    transform: rotate(-45deg);
  }

  .detail-hero-placeholder span,
  .detail-hero-placeholder strong {
    position: relative;
    z-index: 1;
  }

  .detail-hero-placeholder span {
    color: var(--accent-dark);
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.08em;
  }

  .detail-hero-placeholder strong {
    color: var(--text);
    font-size: clamp(1.8rem, 4vw, 3.2rem);
    font-weight: 950;
    line-height: 1.15;
    letter-spacing: -0.04em;
  }

  .eyebrow {
    color: var(--accent-dark);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.78rem;
    margin: 0 0 8px;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    color: var(--text);
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 1.15;
    letter-spacing: -0.04em;
    margin-bottom: 18px;
  }

  .lead {
    color: var(--sub);
    font-size: 1.04rem;
    line-height: 1.9;
    max-width: 760px;
    margin-bottom: 24px;
  }

  .meta-list {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-bottom: 24px;
  }

  .meta-item {
    background: var(--card-subtle);
    border: 1px solid var(--border-soft);
    border-radius: 18px;
    padding: 14px;
  }

  .meta-label {
    display: block;
    color: var(--sub);
    font-size: 0.78rem;
    font-weight: 700;
    margin-bottom: 4px;
  }

  .meta-value {
    color: var(--text);
    font-weight: 800;
  }

  .hero-actions,
  .card-actions,
  .notice-links,
  .side-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .primary-button,
  .secondary-button,
  .card-actions a,
  .notice-links a,
  .side-links a,
  .more-link a,
  .empty-card a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 16px;
    border-radius: 999px;
    font-weight: 800;
    text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
  }

  .primary-button {
    color: #fff;
    background: var(--accent);
    box-shadow: 0 12px 24px rgba(14, 165, 233, 0.22);
  }

  .secondary-button,
  .card-actions a,
  .notice-links a,
  .side-links a,
  .more-link a,
  .empty-card a {
    color: var(--accent-dark);
    background: var(--accent-soft);
  }

  .primary-button:hover,
  .secondary-button:hover,
  .card-actions a:hover,
  .notice-links a:hover,
  .side-links a:hover,
  .more-link a:hover,
  .empty-card a:hover {
    transform: translateY(-1px);
  }

  .hero-side {
    background: linear-gradient(180deg, var(--accent-soft), #fff);
    border: 1px solid var(--border-soft);
    border-radius: 22px;
    padding: 22px;
  }

  .side-title {
    color: var(--text);
    font-weight: 900;
    margin-bottom: 12px;
  }

  .hero-side ul {
    margin: 0;
    padding-left: 1.2em;
    color: var(--sub);
    line-height: 1.8;
  }

  .content-section {
    padding: 24px 0 64px;
  }

  .two-column-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 24px;
    align-items: start;
  }

  .main-column,
  .side-column {
    display: grid;
    gap: 24px;
  }

  .info-card,
  .side-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow);
    padding: 28px;
  }

  .section-heading {
    margin-bottom: 22px;
  }

  .section-heading h2,
  .side-card h2 {
    color: var(--text);
    font-size: 1.45rem;
    margin-bottom: 8px;
  }

  .section-heading p,
  .notice-card p,
  .empty-card p,
  .area-card p,
  .spot-description,
  .spot-meta {
    color: var(--sub);
    line-height: 1.8;
  }

  .spot-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .spot-card,
  .area-card,
  .empty-card {
    border: 1px solid var(--border-soft);
    background: var(--card-subtle);
    border-radius: 20px;
    padding: 18px;
  }

  .spot-card-header {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: center;
    margin-bottom: 10px;
  }

  .spot-area,
  .area-count {
    color: var(--accent-dark);
    font-size: 0.82rem;
    font-weight: 800;
    margin-bottom: 0;
  }

  .official-badge {
    flex: 0 0 auto;
    background: #fff;
    border: 1px solid var(--border);
    color: var(--sub);
    border-radius: 999px;
    padding: 5px 9px;
    font-size: 0.74rem;
    font-weight: 800;
  }

  .spot-card h3,
  .area-card h3 {
    margin-bottom: 10px;
  }

  .spot-card h3 a,
  .area-card h3 a {
    color: var(--text);
    text-decoration: none;
  }

  .spot-card h3 a:hover,
  .area-card h3 a:hover {
    color: var(--accent-dark);
  }

  .spot-description {
    font-size: 0.94rem;
    margin-bottom: 12px;
  }

  .spot-meta {
    display: grid;
    gap: 4px;
    font-size: 0.84rem;
    margin-bottom: 12px;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 14px;
  }

  .tag-list span {
    background: #fff;
    border: 1px solid var(--border);
    color: var(--sub);
    border-radius: 999px;
    padding: 6px 10px;
    font-size: 0.78rem;
    font-weight: 700;
  }

  .area-list {
    display: grid;
    gap: 14px;
  }

  .area-card {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: center;
  }

  .more-link {
    display: flex;
    justify-content: center;
    margin-top: 20px;
