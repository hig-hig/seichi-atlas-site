---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { spots } from "../../data/portalData.js";

export function getStaticPaths() {
  return spots.map((spot) => ({
    params: { slug: spot.slug },
    props: { spot }
  }));
}

const { spot } = Astro.props;

const title = `${spot.name}の聖地巡礼情報 | Seichi Atlas`;
const description = `${spot.name}に関連する聖地巡礼情報です。関連作品、地域、アクセス、訪問時の注意を確認できます。`;
---

<BaseLayout title={title} description={description} canonical={`/spots/${spot.slug}`}>
  <main class="page">
    <section class="spot-hero">
      <p class="kicker">Spot</p>

      <h1>{spot.name}</h1>

      <p class="lead">
        {spot.description}
      </p>

      <div class="spot-meta-list">
        <span>{spot.prefecture}</span>
        <span>最寄り：{spot.station}</span>
        <span>{spot.officialLevel}</span>
      </div>

      <div class="tag-list">
        {spot.tags.map((tag) => (
          <span>{tag}</span>
        ))}
      </div>
    </section>

    <section class="content-section">
      <h2>関連作品</h2>
      <p>
        このスポットは、<strong>{spot.work}</strong> に関連する聖地巡礼スポットとして整理しています。
      </p>

      <div class="link-row">
        <a class="text-link" href={`/works/${spot.workSlug}`}>
          作品ページを見る
        </a>
        <a class="text-link" href={`/areas/${spot.areaSlug}`}>
          {spot.prefecture}の地域ページを見る
        </a>
      </div>
    </section>

    <section class="content-section">
      <h2>アクセス概要</h2>
      <p>
        {spot.access}
      </p>
      <p>
        実際に訪問する際は、最新の交通情報、営業時間、立入可否、撮影可否を必ず確認してください。
      </p>
    </section>

    <section class="content-section notice-box">
      <h2>訪問時の注意</h2>
      <p>
        {spot.note}
      </p>
      <p>
        掲載情報は訪問を推奨・保証するものではありません。
        私有地や立入禁止区域への侵入、近隣住民や施設への迷惑行為は禁止です。
      </p>
    </section>

    <section class="content-section">
      <h2>このスポットを記録する</h2>
      <p>
        記録アプリでは、聖地を訪問済みとして保存し、マイページやマイ巡礼マップで振り返ることができます。
      </p>

      <div class="app-actions">
        <a class="button-primary" href="/app">記録アプリを開く</a>
        <a class="button-secondary" href="/spots">スポット一覧へ戻る</a>
      </div>
    </section>
  </main>

  <style>
    .spot-hero {
      max-width: 840px;
      padding: 40px 0 16px;
    }

    .lead {
      color: var(--sub);
      font-size: 17px;
      max-width: 760px;
    }

    .spot-meta-list {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 24px;
    }

    .spot-meta-list span {
      padding: 8px 12px;
      border-radius: 999px;
      background: #ffffff;
      color: var(--sub);
      font-size: 13px;
      font-weight: 800;
      box-shadow: 0 8px 20px rgba(120, 90, 60, 0.05);
    }

    .tag-list {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 16px;
    }

    .tag-list span {
      padding: 6px 10px;
      border-radius: 999px;
      background: #f7f3ee;
      color: var(--sub);
      font-size: 12px;
      font-weight: 700;
    }

    .content-section {
      margin-top: 42px;
      padding: 28px;
      border-radius: 24px;
      background: #ffffff;
      box-shadow: 0 8px 24px rgba(120, 90, 60, 0.06);
    }

    .content-section h2 {
      margin-top: 0;
      border: none;
      padding-bottom: 0;
    }

    .content-section p {
      color: var(--sub);
    }

    .content-section strong {
      color: var(--text);
    }

    .link-row {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      margin-top: 18px;
    }

    .text-link {
      color: var(--accent-dark);
      font-weight: 800;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .notice-box {
      border: 1px solid var(--accent);
      background: #fffaf7;
    }

    .app-actions {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      margin-top: 24px;
    }

    @media (max-width: 760px) {
      .app-actions {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</BaseLayout>
